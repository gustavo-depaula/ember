{
  "private": true,
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "dev": "turbo dev",
    "start": "pnpm --filter @ember/app run start",
    "start:web": "pnpm --filter @ember/app run web",
    "ios": "pnpm --filter @ember/app run ios",
    "android": "pnpm --filter @ember/app run android",
    "parse-propers": "pnpm --filter @ember/app run parse-propers",
    "build:libraries": "scripts/build-libraries.sh",
    "hearth:clean": "rm -f content/libraries/*.pray content/libraries/registry.json && find content/libraries -path '*/books/*/style.css' -delete",
    "build:webp": "scripts/convert-webp.sh",
    "build:hearth": "scripts/build-libraries.sh && scripts/convert-webp.sh",
    "hearth": "scripts/build-libraries.sh && scripts/convert-webp.sh && serve content -p 4100 --cors",
    "serve:content": "serve content -p 4100 --cors",
    "build:preview": "pnpm --filter @ember/app exec eas build --profile preview --platform ios",
    "build:production": "pnpm --filter @ember/app exec eas build --profile production --platform ios --auto-submit",
    "prepare": "husky"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/react": "~19.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "turbo": "^2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write --no-errors-on-unmatched"
  }
}
