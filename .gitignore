# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Claude Code session state (worktrees, scheduled tasks, etc.)
.claude/

# Hearth v2 build output (corpus blobs + catalog)
_site/

# Transient scraper output kept locally for re-runs only
**/html-cache/

# Archived source originals (kept locally, not in repo — see ~/Documents/ember-archive/)
content/_archive/*/sources/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
apps/app/ios
apps/app/android
.tamagui/
.turbo/

# Generated hearth assets (build:hearth output)
content/catechism/
content/saints/*.webp

# Divinum Officium source (cloned for parser script)
.divinum-officium/

# Python bytecode caches
__pycache__/
*.py[cod]
tmp/

# Python virtualenvs (import-script envs etc.)
.venv/
.venv-*/
venv/

# Cached source PDFs / large binaries downloaded by import scripts
.cache/
