    { "type": "divider" },
    { "type": "subheading", "text": { "en": "Petitions", "pt-BR": "Petições" } },
    {
      "type": "response",
      "verses": [
        { "v": { "en": "Be merciful,", "pt-BR": "Sede misericordioso," }, "r": { "en": "Spare us, O Lord.", "pt-BR": "Poupai-nos, Senhor." } },
        { "v": { "en": "Be merciful,", "pt-BR": "Sede misericordioso," }, "r": { "en": "Graciously hear us, O Lord.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "From all evil,", "pt-BR": "De todo o mal," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From all sin,", "pt-BR": "De todo pecado," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From Your wrath,", "pt-BR": "Da Vossa ira," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From a sudden and unprovided death,", "pt-BR": "De uma morte repentina e imprevista," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From the snares of the devil,", "pt-BR": "Das ciladas do demônio," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From anger, hatred, and all ill will,", "pt-BR": "Da ira, do ódio e de toda má vontade," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From the spirit of fornication,", "pt-BR": "Do espírito de fornicação," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From lightning and tempest,", "pt-BR": "Do raio e da tempestade," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "From everlasting death,", "pt-BR": "Da morte eterna," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through the mystery of Your holy Incarnation,", "pt-BR": "Pelo mistério da Vossa santa Encarnação," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your coming,", "pt-BR": "Pela Vossa vinda," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your birth,", "pt-BR": "Pelo Vosso nascimento," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your baptism and holy fasting,", "pt-BR": "Pelo Vosso batismo e santo jejum," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your cross and passion,", "pt-BR": "Pela Vossa cruz e paixão," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your death and burial,", "pt-BR": "Pela Vossa morte e sepultura," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your holy resurrection,", "pt-BR": "Pela Vossa santa ressurreição," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through Your wonderful ascension,", "pt-BR": "Pela Vossa admirável ascensão," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "Through the coming of the Holy Spirit,", "pt-BR": "Pela vinda do Espírito Santo," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "On the day of judgment,", "pt-BR": "No dia do juízo," }, "r": { "en": "Deliver us, O Lord.", "pt-BR": "Livrai-nos, Senhor." } },
        { "v": { "en": "We sinners,", "pt-BR": "Nós pecadores," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You spare us,", "pt-BR": "Para que nos poupeis," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You pardon us,", "pt-BR": "Para que nos perdoeis," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You bring us to true penance,", "pt-BR": "Para que nos levais à verdadeira penitência," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You govern and preserve Your holy Church,", "pt-BR": "Para que governeis e conserveis Vossa santa Igreja," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You preserve our Pope, and all orders of the Church, in holy religion,", "pt-BR": "Para que preserveis o nosso Papa e todas as ordens da Igreja na santa religião," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You humble the enemies of Holy Church,", "pt-BR": "Para que humilheis os inimigos da Santa Igreja," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You grant peace and true concord to Christian kings and princes,", "pt-BR": "Para que concedais paz e verdadeira concórdia aos reis e príncipes cristãos," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You give peace and unity to all Christian people,", "pt-BR": "Para que deis paz e unidade a todo o povo cristão," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You bring back to the unity of the Church all who have strayed, and lead all unbelievers to the light of the Gospel,", "pt-BR": "Para que reconduzais à unidade da Igreja todos os que se desviaram e guieis todos os incrédulos à luz do Evangelho," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You strengthen and preserve us in Your holy service,", "pt-BR": "Para que nos fortaleçais e conserveis no Vosso santo serviço," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You reward all our benefactors with eternal good,", "pt-BR": "Para que recompenseis todos os nossos benfeitores com o bem eterno," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You deliver our souls, and the souls of our brethren, relations, and benefactors, from eternal damnation,", "pt-BR": "Para que livreis as nossas almas e as almas de nossos irmãos, parentes e benfeitores da danação eterna," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "That You give and preserve the fruits of the earth,", "pt-BR": "Para que deis e conserveis os frutos da terra," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } },
        { "v": { "en": "Son of God,", "pt-BR": "Filho de Deus," }, "r": { "en": "We beseech Thee, hear us.", "pt-BR": "Ouvi-nos, Senhor." } }
      ]
    },
    { "type": "divider" },
    {
      "type": "response",
      "verses": [
        { "v": { "en": "Lamb of God, who takest away the sins of the world,", "pt-BR": "Cordeiro de Deus, que tirais os pecados do mundo," }, "r": { "en": "Spare us, O Lord.", "pt-BR": "Perdoai-nos, Senhor." } },
        { "v": { "en": "Lamb of God, who takest away the sins of the world,", "pt-BR": "Cordeiro de Deus, que tirais os pecados do mundo," }, "r": { "en": "Graciously hear us, O Lord.", "pt-BR": "Ouvi-nos, Senhor." } },
