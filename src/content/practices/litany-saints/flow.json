{
  "sections": [
    { "type": "prayer", "ref": "sign-of-cross" },
    {
      "type": "response",
      "verses": [
        { "v": { "en": "Lord, have mercy.", "pt-BR": "Senhor, tende piedade." }, "r": { "en": "Lord, have mercy.", "pt-BR": "Senhor, tende piedade." } },
        { "v": { "en": "Christ, have mercy.", "pt-BR": "Cristo, tende piedade." }, "r": { "en": "Christ, have mercy.", "pt-BR": "Cristo, tende piedade." } },
        { "v": { "en": "Lord, have mercy.", "pt-BR": "Senhor, tende piedade." }, "r": { "en": "Lord, have mercy.", "pt-BR": "Senhor, tende piedade." } },
        { "v": { "en": "Christ, hear us.", "pt-BR": "Cristo, ouvi-nos." }, "r": { "en": "Christ, graciously hear us.", "pt-BR": "Cristo, atendei-nos." } },
        { "v": { "en": "God the Father of Heaven,", "pt-BR": "Deus Pai do Céu," }, "r": { "en": "Have mercy on us.", "pt-BR": "Tende piedade de nós." } },
        { "v": { "en": "God the Son, Redeemer of the world,", "pt-BR": "Deus Filho, Redentor do mundo," }, "r": { "en": "Have mercy on us.", "pt-BR": "Tende piedade de nós." } },
        { "v": { "en": "God the Holy Spirit,", "pt-BR": "Deus Espírito Santo," }, "r": { "en": "Have mercy on us.", "pt-BR": "Tende piedade de nós." } },
        { "v": { "en": "Holy Trinity, one God,", "pt-BR": "Santíssima Trindade, um só Deus," }, "r": { "en": "Have mercy on us.", "pt-BR": "Tende piedade de nós." } }
      ]
    },
    { "type": "divider" },
