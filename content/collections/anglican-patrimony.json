{
  "id": "collection/anglican-patrimony",
  "version": "1.0.0",
  "name": {
    "en-US": "Anglican Patrimony"
  },
  "description": {
    "en-US": "The Coverdale-Cranmer-BCP strain of Catholic prayer — the Daily Office, the Office of the Dead, and the great collects of the English tradition, restored to full communion through the Personal Ordinariates."
  },
  "icon": "clock",
  "languages": ["en-US"],
  "tags": ["office", "breviary", "ordinariate", "bcp", "anglican-patrimony"],
  "defaults": { "autoSeed": false },
  "prologue": {
    "body": {
      "en-US": "When Pope Benedict XVI established the Personal Ordinariates in 2009, he received not only Anglican souls but a treasury of prayer — the Coverdale Psalter, Cranmer's collects, the rhythms of Mattins and Evensong — and asked that they be preserved as a gift to the wider Church. This collection gathers that patrimony in a Catholic key: the Daily Office in two complementary forms, the Office of the Dead, and the prayers most beloved of the tradition."
    }
  },
  "sections": [
    {
      "id": "the-daily-office",
      "title": { "en-US": "The Daily Office" },
      "description": {
        "body": {
          "en-US": "Two complementary forms of the Office: DWDO (Mattins–Evensong on a 30-day Psalter cycle) and ODOD (the Office of the Dead in BCP form, prayed in November and at the death of one we love)."
        }
      },
      "blocks": [
        { "kind": "item", "ref": "practice/dwdo" },
        {
          "kind": "item",
          "ref": "practice/odod",
          "seeAlso": ["collection/for-the-dead"]
        }
      ]
    },
    {
      "id": "coverdale-prayers",
      "title": { "en-US": "Coverdale & BCP Prayers" },
      "description": {
        "body": {
