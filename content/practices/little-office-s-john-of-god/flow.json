              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Felix sanctus Joannes, cui Dominus ad exemplum Moysis erga proximos caritatem et fraternae salutis zelum inspiravit."
              }
            },
