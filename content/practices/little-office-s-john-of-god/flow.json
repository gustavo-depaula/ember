    {
      "type": "subheading",
      "text": {
        "en-US": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Sancte Pater, hoc oblatum\nSuscipe officium.\nFac ut Deo fiat gratum\nMeum hoc servitium."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Cura, sana, me tuere,\nOmni purga vitio.\nTibi me fac congaudere\nCoeli in hospitio."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Antiphona"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "O zelator fidei et amator pacis, lumen virtutum et speculum caritatis, Pater pauperum et spiritus humilitatis, qui incepisti ordinem super hospitalitatem:\nintercede pro nobis apud sanctam et individuam Trinitatem."
      }
    },
    {
      "type": "response",
      "verses": [
