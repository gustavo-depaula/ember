                  },
                  "r": {
                    "la": "Benedicamus."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Et Fidelium, etc."
              }
            }
          ]
        }
      ]
    },
    {
      "type": "subheading",
      "text": {
        "la": "Commendatio",
        "en-US": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "O Diva, Sponsa Numinis;\nDecusque, Diva, caeli;\nSpes certa te vocantium:\nSodaliumque scutum:\nFuga dolores, grandines,\nMorbosque, Daemonesque,\nIsteque mortis omnibus,\nO Diva, redde tuum."
      }
    }
  ]
}
