{
  "sections": [
    {
      "type": "select",
      "on": "hour",
      "label": {
        "en-US": "Hour",
        "pt-BR": "Hora"
      },
      "map": {
        "0-2": "matins",
        "3-5": "prime",
        "6-9": "terce",
        "10-12": "sext",
        "13-16": "none",
        "17-19": "vespers",
        "20-23": "compline"
      },
      "options": [
        {
          "id": "matins",
          "label": {
            "en-US": "Matins",
            "pt-BR": "Matinas",
            "la": "Matutinum"
          },
          "sections": [
            {
              "type": "prayer",
              "inline": {
                "la": "Narrabo nomen tuum fratribus meis:\nin medio Ecclesiae laudabo te."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Domine, labia mea aperies."
                  },
                  "r": {
                    "la": "Et os meum annuntiabit laudem tuam."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus, in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto.\nSicut erat in principio, et nunc, et semper, et in saecula saeculorum. Amen."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Illustre sidus Principum,\nFrancisce salve maxime;\nQui foetido cadavere\nViso, horruisti saeculum.\n\nAverte nostra lumina,\nNe vanitates hauriant,\nSed in supernam caelitum\nSint fixa saeculum jugiter."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Taeduit me vitae meae, videns me mala universae sub sole,\net cohorruit aeternitas vanitatem et afflictionem spiritus."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Non aspiciam hominem ultra, et habitatorum quietis."
                  },
                  "r": {
                    "la": "Haec requies mea in saeculum saeculi: quoniam elegi eam."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Omnipotens, sempiterne Deus,\nqui spreta vanitate, beatum Franciscum Borgiam\net Societatem Filii tui vocare dignatus es:\npraesta, quaesumus, ut, quem eximia sanctimoniae exempla\npar habuimus in terris,\nejus coronae participes fieri mereamur in caelis.\nPer Christum Dominum nostrum. Amen."
              }
            }
          ]
        },
        {
          "id": "prime",
          "label": {
            "en-US": "Prime",
            "pt-BR": "Prima",
            "la": "Prima"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve columna Gandiae,\nEt Religionis gloria:\nQui aula relicta Principis,\nAulam petisti Numinis.\n\nServos fideles caelitum\nServire fac nos Principi,\nUt tecum eodem praemio\nPerfruamur perpetuo."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Coacervavi mihi argentum, et aurum, et substantias Regum et Provinciarum:\nvidi in omnibus vanitatem, et afflictionem animi,\net nihil permanere sub sole."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Beatus vir, qui timet Dominum:"
                  },
                  "r": {
                    "la": "Et non respexit in vanitates, et insanias falsas."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "terce",
          "label": {
            "en-US": "Terce",
            "pt-BR": "Terça",
            "la": "Tertia"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve, o speculum pauperum,\nOpumque spretor inclite,\nFelicitatem divitum\nQui vanitatem duxeras:\n\nFac spiritu nos pauperes,\nVirtute vero divites,\nGazas caducas spernere,\nSolumque Christum quaerere."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Coacervavi mihi argentum, et aurum, et substantias Regum et Provinciarum:\nvidi in omnibus vanitatem, et afflictionem animi,\net nihil permanere sub sole."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Beatus vir, cujus est nomen Domini spes ejus."
                  },
                  "r": {
                    "la": "Et non respexit in vanitates, et insanias falsas."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "sext",
          "label": {
            "en-US": "Sext",
            "pt-BR": "Sexta",
            "la": "Sexta"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve polaris flammula,\nCaeli voluptas, Borgia,\nDevotionis lachryma\nCui madebant lumina:\n\nRores supernos gratiae\nDevotionis depule,\nCor incalescat frigidum,\nFlammis amoris affluat."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Cor suum tradet ad vigilandum diluculo ad Dominum, qui fecit illum:\net in conspectu Altissimi deprecabitur."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Tanquam imbres mittet eloquia sapientiae tuae."
                  },
                  "r": {
                    "la": "Et in oratione constituitur Domino."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "none",
          "label": {
            "en-US": "None",
            "pt-BR": "Nona",
            "la": "Nona"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve pudicitiae rosa,\nEt castitatis lilium:\nHostis voluptae maxime,\nCarnisque victor hostium:\n\nTu puritatem corporis,\nMentisque serves integram:\nCor munda ab omni crimine,\nDignus thorus sit Numine."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "O quam pulchra et casta generatio cum claritate:\nimmortalis est enim memoria illius:\nquoniam apud Deum nota est, et apud homines."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Retribuet mihi Dominus secundum justitiam meam."
                  },
                  "r": {
                    "la": "Et secundum puritatem manuum mearum in conspectu oculorum ejus."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "vespers",
          "label": {
            "en-US": "Vespers",
            "pt-BR": "Vésperas",
            "la": "Vesperae"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve culmen humilium,\nExemplum obedientiae,\nCalcata honoris purpura,\nDemissionis gratia.\n\nQui claruit maxima,\nMotus superbos comprime,\nMentes rebelles doma,\nHumilesque veros effice."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Sapientiam humilitati exaltabit caput illius,\nin medio Magnatum considerare illum faciet."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Memoriam superborum perdidit Deus."
                  },
                  "r": {
                    "la": "Reliquit memoriam humilium sensu."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "compline",
          "label": {
            "en-US": "Compline",
            "pt-BR": "Completas",
            "la": "Completorium"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Converte nos Deus salutaris noster."
                  },
                  "r": {
                    "la": "Et averte iram tuam a nobis."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve potestas daemonum,\nBellator invincibilis,\nQui nobilis victoriae\nPlaudens migrasti e corpore.\n\nAdversus infernalium\nTentationes hostium,\nNobis adis fortissimum\nIn morte propugnaculum."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Justus, si morte praeoccupatus fuerit, in refrigerio erit.\nSenectus enim venerabilis est, non diuturna,\nnec numero annorum numerata computata."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Gloriosa in conspectu Domini."
                  },
                  "r": {
                    "la": "Mors Sanctorum ejus."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        }
      ]
    }
  ]
}
