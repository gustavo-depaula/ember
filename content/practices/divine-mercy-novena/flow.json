{
  "sections": [
    {
      "type": "prayer",
      "ref": "base:sign-of-cross"
    },
    {
      "type": "heading",
      "text": {
        "en-US": "Divine Mercy Novena",
        "pt-BR": "Novena da Divina Misericórdia"
      }
    },
    {
      "type": "rubric",
      "text": {
        "en-US": "Offer today's intention and prayer, then pray the Divine Mercy Chaplet.",
        "pt-BR": "Ofereça a intenção e a oração do dia e, em seguida, reze o Terço da Misericórdia."
      }
    },
    {
      "type": "cycle",
      "data": "novena-days",
      "as": "template",
      "sections": [
        {
          "type": "subheading",
          "text": "{{dayTitle}}"
        },
        {
          "type": "meditation",
          "text": "{{meditation}}"
        },
        {
          "type": "divider"
        },
        {
          "type": "rubric",
          "text": {
            "en-US": "Today's intention:",
            "pt-BR": "Intenção do dia:"
          }
        },
        {
          "type": "rubric",
          "text": "{{intention}}"
        },
        {
          "type": "divider"
        },
        {
          "type": "rubric",
          "text": {
            "en-US": "Prayer for this intention:",
            "pt-BR": "Oração por esta intenção:"
          }
        },
        {
          "type": "prayer",
          "inline": "{{petitionText}}"
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "subheading",
      "text": {
        "en-US": "Divine Mercy Chaplet",
        "pt-BR": "Terço da Misericórdia Divina"
      }
    },
    {
      "type": "prayer",
      "ref": "base:our-father"
    },
    {
      "type": "prayer",
      "ref": "base:hail-mary"
    },
    {
      "type": "prayer",
      "ref": "base:apostles-creed"
    },
    {
      "type": "divider"
    },
    {
      "type": "repeat",
      "count": 5,
      "sections": [
        {
          "type": "rubric",
          "text": {
            "en-US": "On the Our Father bead:",
            "pt-BR": "Na conta do Pai Nosso:"
          }
        },
        {
          "type": "prayer",
          "ref": "divine-mercy:eternal-father"
        },
        {
          "type": "rubric",
          "text": {
            "en-US": "On each of the ten Hail Mary beads:",
            "pt-BR": "Em cada uma das dez contas da Ave Maria:"
          }
        },
        {
          "type": "repeat",
          "count": 10,
          "sections": [
            {
              "type": "prayer",
              "ref": "divine-mercy:divine-mercy-response"
            }
          ]
        },
        {
          "type": "divider"
        }
      ]
    },
    {
      "type": "rubric",
      "text": {
        "en-US": "Concluding prayer (three times):",
        "pt-BR": "Oração final (três vezes):"
      }
    },
    {
      "type": "repeat",
      "count": 3,
      "sections": [
        {
          "type": "prayer",
          "ref": "divine-mercy:holy-god"
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "prayer",
      "inline": {
        "en-US": "Eternal God, in whom mercy is endless and the treasury of compassion inexhaustible, look kindly upon us and increase Your mercy in us, that in difficult moments we might not despair nor become despondent, but with great confidence submit ourselves to Your holy will, which is Love and Mercy itself.\nAmen.",
        "pt-BR": "Deus Eterno, em quem a misericórdia é infinita e o tesouro de compaixão inesgotável, olhai bondosamente para nós e aumentai em nós a Vossa misericórdia, para que em momentos difíceis não nos desesperemos nem desanimemos, mas com grande confiança nos submetamos à Vossa santa vontade, que é o próprio Amor e Misericórdia.\nAmém."
      }
    },
    {
      "type": "prayer",
      "ref": "base:sign-of-cross"
    }
  ]
}
