              "type": "subheading",
              "text": {
                "la": "Oratio"
              }
            },
            {
              "type": "rubric",
              "text": {
                "la": "Sancta Maria, Regina caelorum, Mater Domini nostri Jesu Christi, et mundi Domina, etc. ut supra."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Domina exaudi, etc."
                  },
                  "r": {
