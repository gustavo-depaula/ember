{
  "sections": [
    {
      "type": "subheading",
      "text": {
        "en-US": "From Rosetum Deiparae Virginis Mariae (1641)"
      }
    },
    {
      "type": "select",
      "on": "hour",
      "label": {
        "en-US": "Hour",
        "pt-BR": "Hora"
      },
      "map": {
        "0-2": "matins",
        "3-5": "prime",
        "6-9": "terce",
        "10-12": "sext",
