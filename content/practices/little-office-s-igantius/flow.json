                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Gloria Patri, et Filio, et Spiritui Sancto."
                  },
                  "r": {
                    "la": "Sicut erat in principio, et nunc, et semper, et in saecula saeculorum."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Amen. Alleluia."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Sublimis inter aera Ignatius tenetur:\nQuando te ulgens sidera precando conatur\nApostolos in judicium ab legat hinc vereptum:\nCum caeteris exotiicum hic, excolit rosetum.\nAufert suorum cordibus sodalium pavorem\nCum Christus ipsis omnibus proponit et favorem."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona Isai. 18."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Iste Angeli vescas ad gentem praecentantem,\net sonum exculcantium diriperunt flumina terram ejus."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "In doctrinis glorificate Dominum. Eccli. 14."
                  },
                  "r": {
                    "la": "Et docete homines legem Dei. 4 Reg."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui, etc. ut supra."
              }
            }
          ]
        },
        {
          "id": "vespers",
          "label": {
            "en-US": "Vespers",
            "pt-BR": "Vésperas",
            "la": "Vesperae"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Gloria Patri, et Filio, et Spiritui Sancto."
                  },
                  "r": {
                    "la": "Sicut erat in principio, et nunc, et semper, et in saecula saeculorum."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Amen. Alleluia."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Mox Ordo Jesu nomine vocatus, inchoatur\nFausto deinceps, omine firmatus approbatur.\nSacco jubetur caetui Ignatius praeesse,\nPastoris hujus mutui grex gessit subsellere.\nCutam suorum sodalium fructu ferace gessit,\nEt Coelique juxta regulam res cuncta vitae cessit."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona Agg. 2."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Assumam te Zorobabel serve meus, et ponam te quasi signaculum: quia te elegi."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Caput in tribubus Israel factus est."
              }
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui, etc. ut supra."
              }
            }
          ]
        },
        {
          "id": "compline",
          "label": {
            "en-US": "Compline",
            "pt-BR": "Completas",
            "la": "Completorium"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Convertere nos Deus salutaris noster."
                  },
                  "r": {
                    "la": "Et averte iram tuam a nobis."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Gloria Patri, et Filio, et Spiritui Sancto."
                  },
                  "r": {
                    "la": "Sicut erat in principio, et nunc, et semper, et in saecula saeculorum."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Amen. Alleluia."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Jam vitis illicae sersperat Ignatio fatore,\nOrbemque ferme sersperat coelestium favore.\nCum strenui mens militis post haec relicta castra\nInepta nomen coelitis poli subivit astra.\nO Patriarcha, lumine dignare nos paterno!\nOpemque natis, lumine transmittente de superno."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Hic est frater noster, et populus Israel:\nqui multum orat pro populo, et universa sancta civitate. Machab."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Respexit in orationem humilium."
                  },
                  "r": {
                    "la": "Et non sprevit precem eorum. Psalm 101."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui, etc."
              }
            }
          ]
        }
      ]
    },
    {
      "type": "subheading",
      "text": {
        "en-US": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Haec vota supplex offero Ignatio praesenti,\nEt hunc honorem defero majora potenti.\nExopto per te maximi nunc ponderis favorem,\nTum Numinis, tum proximi terris in his amorem.\nUt mens soluta corpore festaret ad superna,\nEt pace pleno pectore fruatur cive aeterna."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Oratio recitanda ante Imaginem S. Ignatii"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Salve Sancte Patriarcha Ignati, imitator Jesu Christi;\ntemplum Spiritus Sancti; serve amantissime SS. Trinitatis!\nSalve emulator Martyrum; imago Apostolorum, Vas electionis.\nSalve expugnator vitiorum, compendium virtutum, idea perfectionis.\nSalve norma patientiae; castitatis lilium, modestiae speculum.\nSalve obedientiae prodigium, charitatis ignis, pauperum refugium.\nSalve exemplar abstinentiae, humilitatis prototypon, afflictorum solatium.\nAuxiliare Magister ignorantium, dux poenitentium, reformator Christi;\nnorum illumina mentem meam, dux infidelium\nGuberna cor meum, magne affectuum tuorum moderator.\nImpetra mihi veniam, felicissimae pacis conciliator.\nExcra in bono perseverantiam, firma Ecclesiae columna.\nIntercede pro me, meisque omnibus, tum consanguineis, tum amicis et benefactoribus;\nstrenue clientium tuorum Protector.\nSis mihi scutum in adversitatibus;\ndefende me in tentationibus, et omnibus in vita malis, nec me deferas in hora mortis meae.\nAmen."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Antiphona"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Ego Dominus vocavi te in justitia, et apprehendi manum tuam, et servavi te,\net dedi te in foedus populi; in lucem gentium,\nut aperies oculos caecorum, et educeres de conclusione vinctum,\nde domo carceris sedentem in tenebris."
      }
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "la": "Annunciate inter gentes gloriam ejus."
          },
          "r": {
            "la": "In omnibus populis mirabilia ejus."
          }
        }
      ]
    },
    {
      "type": "rubric",
      "text": {
        "la": "Oremus."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Deus, qui servum tuum S. Ignatium de mundi caesis\nad spiritualis militiae triumphos evocasti;\npraesta quaesumus: ut eum sequamur lucem morum,\net protectorem consequamur.\nPer Christum Dominum nostrum."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Antiphona"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Judicio posui te, ut ostenderem te fortitudinem meam,\net narretur nomen meum in omni terra."
      }
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "la": "Ora pro nobis, Sancte Pater Ignati."
          },
          "r": {
            "la": "Ut digni efficiamur promissionibus Christi."
          }
        }
      ]
    },
    {
      "type": "rubric",
      "text": {
        "la": "Oremus."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Deus, qui glorificantes te, glorificas,\net in Sanctorum tuorum honoribus honoraris;\nconcede propitius: ut, qui sancti tui Ignatii gloriosa merita colimus\nejus apud te pia patrocinia sentiamus.\nPer Christum Dominum nostrum."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Amen."
      }
    }
  ]
}
