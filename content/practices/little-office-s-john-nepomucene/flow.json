    },
    {
      "type": "subheading",
      "text": {
        "en-US": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Acliente poenitente\nVota Martyr accipe:\nPraesto prone sis Patrone,\nAnxium me respice;"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Pelle moestum cordis aestum,\nAufer ignominiam:\nPerque fata duc beata\nAd aeternam patriam.\nAmen."
      }
    }
  ]
}
