            "la": "Nona"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto.\nSicut erat in principio, et nunc, et semper, et in saecula saeculorum.\nAmen."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Salve, cui mors horrida\nNon ante fata struxit,\nQuam, quos in antra torrida\nAbduxerat, reduxit.\nVicena namque funera\nEt quinque suscitasti,\nMortemque post tot vulnera\nIn temet incitasti."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona"
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Joannes Baptista resurrexit a mortuis,\net propterea virtutes operantur in illo."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Dii facti similes hominibus descenderunt ad nos. Actor. 14."
                  },
                  "r": {
                    "la": "Et resurrectione mortuorum, lumen annunciantes populo, et gentibus. Actor. 26."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui Evangelium, etc."
              }
            }
          ]
        },
        {
          "id": "vespers",
          "label": {
            "en-US": "Vespers",
            "pt-BR": "Vésperas",
            "la": "Vesperae"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto.\nSicut erat in principio, et nunc, et semper, et in saecula saeculorum.\nAmen."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Francisce, magne Nominis,\nEt proximorum amator,\nFrancisce, veri luminis\nIn orbe seminator:\nSalve, cui dum patria\nAngustiora castra\nDescriberet, tunc atria\nDat Numen inter astra."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona 2 Cor. 5."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Scimus, quoniam si terrestris domus nostra hujus habitationis dissolvatur,\nquod aedificationem ex Deo habemus,\ndomum non manu factam aeternam in caelis."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Pretiosa in conspectu Domini."
                  },
                  "r": {
                    "la": "Mors Sanctorum ejus."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui Evangelium, etc."
              }
            }
          ]
        },
        {
          "id": "compline",
          "label": {
            "en-US": "Compline",
            "pt-BR": "Completas",
            "la": "Completorium"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Converte nos Deus salutaris noster."
                  },
                  "r": {
                    "la": "Et averte iram tuam a nobis."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri, et Filio, et Spiritui Sancto.\nSicut erat in principio, et nunc, et semper, et in saecula saeculorum.\nAmen."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Francisce, nec labecula\nPutredinis notate,\nPost fata nec nubecula\nPalloris inquinate,\nSalve, tuoque lumine\nSic Indias ferena,\nEuropa vero Numine\nUt sit, Deoque plena."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Antiphona Dan. 3."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Qui ad justitiam erudiunt multos fulgebunt quasi stellae in perpetuas aeternitates."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Quoniam non derelinques animam meam in inferno."
                  },
                  "r": {
                    "la": "Nec dabis, Sanctum tuum videre corruptionem."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Deus, qui Evangelium, etc."
              }
            }
          ]
        }
      ]
    },
    {
      "type": "subheading",
      "text": {
        "en-US": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Haec Indiarum Apostolo,\nHaec vota Thaumaturgo,\nJaponarium Apostolo;\nDicata amoris ergo:\nErgo tuis compendiis\nSic per vix salebras,\nEt sic tuis stipendiis\nMe duc per has latebras;\nUt ceu tuis ab ignibus\nCalente corde mundum\nContemno, sic insignibus\nVitem tuis profundum,\nDicamque tecum, o amplius,\nDomine, amplius, dolores,\nDicamque tecum crebrius,\nSatis est, fatis favores."
      }
    }
  ]
}
