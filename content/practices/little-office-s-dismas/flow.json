{
  "sections": [
    {
      "type": "subheading",
      "text": {
        "la": "Ingressus"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Disma poenitens praeclare,\nRecolli non dedignare\nOda hac canonica,\nCui post seram poenitere\nPrimo tamen patuere\nParadisi ostia."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Ant."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "In domo Patris mei multae sunt mansiones: erunt novissimi primi, et primi erunt novissimi."
      }
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "la": "In quacunque die conversus fuerit ab impietate sua"
          },
          "r": {
            "la": "Impietas impii non nocebit ei."
          }
        }
      ]
    },
    {
      "type": "select",
      "on": "hour",
      "label": {
        "en-US": "Hour",
        "pt-BR": "Hora"
      },
      "map": {
        "0-2": "matins",
        "3-5": "lauds",
        "6-8": "prime",
        "9-11": "terce",
        "12-14": "sext",
        "15-17": "none",
        "18-20": "vespers",
        "21-23": "compline"
      },
      "options": [
        {
          "id": "matins",
          "label": {
            "en-US": "Matins",
            "pt-BR": "Matinas",
            "la": "Matutinum"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Domine labia mea aperies."
                  },
                  "r": {
                    "la": "Et os meum annuntiabit laudem tuam."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Non Aegyptus thura dabat\nTot Idolis: abundabat\nSaevis quot latronibus;\nInter quales et fuisse,\nDisma! datur, te legisse,\nHuc dum fugit Jesulus."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Dispendentur a facie ejus idola Aegypti: lappa et tribulus ascendet super aras eorum."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Lucernas accendit illis,"
                  },
                  "r": {
                    "la": "Ne a latronibus exspolientur."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oremus."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Misericordissime Jesu, qui pendens in Cruce, ineffabile infinitae misericordiae tuae specimen in conversione sancti Dismas latronis ostendisti: per sanguinem tuum pretiosum in Cruce effusum, obsecro te, concede mihi ingratissimo peccatori efficacem tuam gratiam, ut peccata mea deplorare, te toto corde amare, et in hora mortis meae audire a te merear: Hodie mecum eris in Paradiso. Qui vivis et regnas cum Deo Patre etc."
              }
            }
          ]
        },
        {
          "id": "lauds",
          "label": {
            "en-US": "Lauds",
            "pt-BR": "Laudes",
            "la": "Laudes"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Dum sub palma Joseph pater\nSedet, atque nato mater\nJesulo advigilat,\nTu cum assectis prorumpis,\nSupplex vero mox procumbis,\nPupus te dum advocat."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Quare posuisti me contrarium tibi, et arbitratus es me inimicum tuum?"
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Ego cum exaltatus fuero de terra,"
                  },
                  "r": {
                    "la": "Omnia traham ad meipsum."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "prime",
          "label": {
            "en-US": "Prime",
            "pt-BR": "Prima",
            "la": "Prima"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Quin jam sociis relictis,\nHospitem te das afflictis,\nDucem et itineris;\nAt non diu! nam reversus\nAd sodales, mox immersus\nPriscis es flagitiis."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Odisti disciplinam, et projecisti sermones meos retrorsum: cum videbas furem, currebas cum eo."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Cum electo electus eris,"
                  },
                  "r": {
                    "la": "Et cum perverso perverteris."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "terce",
          "label": {
            "en-US": "Terce",
            "pt-BR": "Terça",
            "la": "Tertia"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "En! jam Christus, instar Ducis,\nPer virtutes viam Crucis\nIntrat et miracula,\nNum et tu ad Crucem perges?\nImo certe! sed huc verges\nProbra per et scelera."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Fecit oriri solem suum super bonos et malos, et pluit super justos et injustos."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Justum autem deducet Dominus per vias rectas,"
                  },
                  "r": {
                    "la": "Et impii in circuitu ambulabunt."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "sext",
          "label": {
            "en-US": "Sext",
            "pt-BR": "Sexta",
            "la": "Sexta"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "At, quam multum obliquabas\nIter Dismae, et distabas\nRecta Christi semita,\nTamen hi, per pares mortes,\nViae sancti sunt consortes\nRursum in Calvaria."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Pro eo enim, quod tradidit in mortem animam suam, et peccata multorum tulit, cum sceleratis reputatus est."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Ducebantur autem et alii duo nequam cum eo,"
                  },
                  "r": {
                    "la": "Ut interficerentur."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "none",
          "label": {
            "en-US": "None",
            "pt-BR": "Nona",
            "la": "Nona"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Disma, quae haec paradoxa?\nPar est poena, dispar noxa,\nTu sons, Christus innocens:\nPorro nec vercundaris,\nSons insolens, criminari,\nProbrum terrae, summum Ens."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Nequitiam et iniquitatem in excelso locuti sunt: posuerunt in coelum os suum."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Si tu es Christus, salvum fac temetipsum et nos,"
                  },
                  "r": {
                    "la": "Alios salvos facis, te ipsum non potes salvum facere."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "vespers",
          "label": {
            "en-US": "Vespers",
            "pt-BR": "Vésperas",
            "la": "Vesperae"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Unus Christi sed aspectus\nSic contudit tibi pectus\nAlta missus arbore,\nMox ut totus indoleres,\nCaedes, spolia defleres,\nNoxas et blasphemiae."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Exaudi me Domine, quoniam benigna est misericordia tua: secundum multitudinem miserationum tuarum respice in me."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Et nos quidem digna factis recipimus,"
                  },
                  "r": {
                    "la": "Hic vero nihil mali gessit."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        },
        {
          "id": "compline",
          "label": {
            "en-US": "Compline",
            "pt-BR": "Completas",
            "la": "Completorium"
          },
          "sections": [
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Sis Disma memor omnium"
                  },
                  "r": {
                    "la": "Cum morte confligantium."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Convertere nos Deus salutaris noster."
                  },
                  "r": {
                    "la": "Et averte iram tuam a nobis."
                  }
                }
              ]
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Deus in adjutorium meum intende."
                  },
                  "r": {
                    "la": "Domine ad adjuvandum me festina."
                  }
                }
              ]
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Gloria Patri etc."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Hymnus"
              }
            },
            {
              "type": "hymn",
              "inline": {
                "la": "Venia sic impetrata,\nDismae Paradisi grata\nJam et regna exspectat;\nCui et Jesus prompto ore,\nHodie se adhuc fore\nIbi secum, innuit."
              }
            },
            {
              "type": "subheading",
              "text": {
                "la": "Ant."
              }
            },
            {
              "type": "prayer",
              "inline": {
                "la": "Apud Dominum propitiatio est, et copiosa apud eum redemptio: et ipse redimet Israel ex omnibus iniquitatibus ejus."
              }
            },
            {
              "type": "response",
              "verses": [
                {
                  "v": {
                    "la": "Domine, memento mei, cum veneris in regnum tuum."
                  },
                  "r": {
                    "la": "Amen. dico tibi: hodie mecum eris in Paradiso."
                  }
                }
              ]
            },
            {
              "type": "rubric",
              "text": {
                "la": "Oratio ut supra."
              }
            }
          ]
        }
      ]
    },
    {
      "type": "subheading",
      "text": {
        "la": "Commendation"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Disma, fac et nos sincero,\nSed dolore non tam sero\nPortum coeli tangere;\nQuodsi vero id sit sero,\nLuctu fac hoc plus severo\nCulpas nostras plangere."
      }
    },
    {
      "type": "subheading",
      "text": {
        "la": "Ant."
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Suavis Dominus universis, patiens et multum misericors: et miserationes ejus super omnia opera ejus."
      }
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "la": "Sacrificium Deo spiritus contribulatus,"
          },
          "r": {
            "la": "Cor contritum et humiliatum Deus non despicies."
          }
        }
      ]
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "la": "Ora pro nobis beate Disma,"
          },
          "r": {
            "la": "Ut digni efficiamur promissionibus Christi."
          }
        }
      ]
    },
    {
      "type": "subheading",
      "text": {
        "la": "Oratio"
      }
    },
    {
      "type": "prayer",
      "inline": {
        "la": "Sancte Disma, qui mira Dei providentia ex nefario latrone in eximium poenitentiae speculum evasisti, et paucas intra horas aeterna tibi gaudia comparasti: dignare de excelso gloriae tuae throno, sicut in te de Cruce aspexit Christus, super miseriam hanc lachrymarum vallem oculos tuos defigere; et quoniam tibi cognita est mentis humanae fragilitas, semper ad malum magis, quam ad bonum proclivis; igitur nobis, apud dulcissimum Redemptorem nostrum, precibus tuis impetra, ut sicut per gratiam suam efficacem ad poenitentiam et Paradisi coelestis gloriam te perduxit, ita et nos famulos suos eadem efficaci gratia ad dignos poenitentiae fructus impellat, quo commissis nostris corditus deploratis, pie quondam tibi commoremur, ac una tandem in Deo Salvatori nostro jugiter exultemus, qui vivit et regnat in saecula saeculorum.\nAmen."
      }
    }
  ]
}
