  {
   "name": "Responsory11",
   "lines": [
    "R. Allelúja, audívimus ea in Ephrata, invénimus eam in campis silvæ:",
    "* Introívimus in tabernáculum ejus, adorávimus in loco, ubi stetérunt pedes ejus, † allelúja, allelúja.",
    "V. Surge, Dómine, in réquiem tuam, tu et arca sanctificatiónis tuæ.",
    "R. Introívimus in tabernáculum ejus, adorávimus in loco, ubi stetérunt pedes ejus, † allelúja, allelúja.",
    ""
   ]
  },
  {
   "name": "Lectio12",
   "lines": [
    "@Tempora/Pasc4-0:Lectio9",
    ""
   ]
  },
  {
   "name": "Responsory12",
   "lines": [
    "R. Deduc me in sémita mandatórum tuórum, allelúja, † quóniam ipsam vólui, allelúja",
    "* Inclína cor meum in testimónia tua, † allelúja, allelúja, allelúja.",
    "V. Avérte óculos meos ne vídeant vanitátem, in via tua vivífica me.",
    "R. Inclína cor meum in testimónia tua, † allelúja, allelúja, allelúja."
   ]
  }
 ]
