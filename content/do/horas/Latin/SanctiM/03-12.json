  {
   "name": "Ant Laudes",
   "lines": [
    "Beátus Gregórius * in cáthedra Petri sublimátus, Vigilántis nomen factis implévit.",
    "Pastor exímius * pastorális vitæ spécimen trádidit et régulam.",
    "Dum páginæ sacræ * mystéria pánderet, colúmba nive candídior appáruit.",
    "Servi Dómini * benedícite Dóminum: servus vester Gregórius cælos ascéndit.",
    "Gregórius, * monachórum spéculum, pater Urbis, orbis delíciæ.",
    ""
   ]
  },
  {
   "name": "Capitulum Laudes",
   "lines": [
    "!Eccl 50:1",
    "v. Ecce sacérdos magnus, qui in vita sua suffúlsit domum, et in diébus suis corroborávit templum.",
    "$Deo gratias",
    ""
   ]
  },
  {
   "name": "Hymnus Laudes",
   "lines": [
    "v. Mella cor obdulcántia",
    "Tua distíllant lábia:",
    "Fragrántum vim arómatum",
    "Tuum vincit elóquium.",
    "_",
    "Scriptúræ sacræ mýstica",
    "Mire solvis ænígmata:",
    "Theórica mystéria",
    "Te docet ipsa Véritas.",
    "_",
    "Tu nactus apostólicam",
    "Vicem simul et glóriam:",
    "Nos solve culpæ néxibus,",
    "Redde polórum sédibus.",
    "_",
    "O Póntifex egrégie,",
    "Lux et decus Ecclésiæ,",
    "Non sinas in perículis,",
    "Quos tot mandátis ínstruis.",
    "_",
    "Sit Patri laus ingénito,",
    "Sit decus Unigénito:",
    "Sit utriúsque párili",
    "Majéstas summa Flámini.",
    "Amen.",
    ""
   ]
  },
  {
   "name": "Ant 2",
   "lines": [
    "Gregórius, * respíciens Anglórum júvenes, ait: Angélicam habent fáciem, et tales Angelórum in cælis decet esse consórtes.",
    ""
   ]
  },
  {
   "name": "Capitulum Sexta",
   "lines": [
    "!Eccl 47:11-12",
    "v. Stare fecit cantóres contra altáre, et in sono eórum dulces fecit modos. Et dedit in celebratiónibus decus, et ornávit témpora usque ad consummatiónem vitæ.",
    "$Deo gratias",
    ""
   ]
  },
  {
   "name": "Capitulum Nona",
   "lines": [
    "!Eccl 50:4-5",
    "v. Curávit gentem suam, et liberávit eam a perditióne. Qui præváluit amplificáre civitátem, qui adéptus est glóriam in conversatióne gentis.",
    "$Deo gratias",
    ""
   ]
  },
