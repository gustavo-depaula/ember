  {
   "name": "Responsory8",
   "lines": [
    "R. Per signum Crucis de inimícis nostris",
    "* Líbera nos, Deus noster.",
    "V. Salva nos, Christe Salvátor, per virtútem crucis.",
    "R. Líbera nos, Deus noster.",
    ""
   ]
  },
