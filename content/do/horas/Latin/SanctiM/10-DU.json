  {
   "name": "Responsory11",
   "lines": [
    "R. Non est símilis tui, Dómine, magnus nomen tuum in fortitúdine,",
    "* Quis non timébit te, o Rex géntium?",
    "V. Tuum est enim decus inter cunctos sapiéntes géntium: † Tu Deus vivens et Rex sempitérnus",
    "R. Quis non timébit te, o Rex géntium?",
    ""
   ]
  },
  {
   "name": "Lectio12",
   "lines": [
