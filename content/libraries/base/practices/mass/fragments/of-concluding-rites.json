{
  "fragments": {
    "of-concluding-rites": [
      {
        "type": "section-marker",
        "title": {
          "en-US": "Concluding Rites",
          "pt-BR": "Ritos Finais"
        },
        "colorFrom": "celebration.primary.liturgicalColor"
      },
      {
        "type": "call",
        "ref": "of-lord-be-with-you"
      },
      {
        "type": "rubric",
        "text": {
          "en-US": "The Priest, extending his hands, greets the people. Then, joining his hands and placing his left hand on his breast, he raises his right hand and blesses the people, making the Sign of the Cross over them.",
          "pt-BR": "O sacerdote, abrindo os braços, saúda o povo. Depois, juntando as mãos e colocando a mão esquerda sobre o peito, levanta a mão direita e abençoa o povo, fazendo o Sinal da Cruz sobre eles."
        }
      },
      {
        "type": "select",
        "on": "celebration.primary.season",
        "default": "default",
        "options": [
          {
            "id": "advent",
            "label": {
              "pt-BR": "Advento",
              "en-US": "Advent"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-advent"
              }
            ]
          },
          {
            "id": "christmas",
            "label": {
              "pt-BR": "Natal",
              "en-US": "Christmas"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-christmas"
              }
            ]
          },
          {
            "id": "lent",
            "label": {
              "pt-BR": "Quaresma",
              "en-US": "Lent"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-lent"
              }
            ]
          },
          {
            "id": "easter",
            "label": {
              "pt-BR": "Tempo Pascal",
              "en-US": "Easter Time"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-easter"
              }
            ]
          },
          {
            "id": "ordinary-time",
            "label": {
              "pt-BR": "Tempo Comum",
              "en-US": "Ordinary Time"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-ordinary-time"
              }
            ]
          },
          {
            "id": "default",
            "label": {
              "pt-BR": "Geral",
              "en-US": "General"
            },
            "sections": [
              {
                "type": "call",
                "ref": "of-blessing-default"
              }
            ]
          }
        ]
      },
      {
        "type": "rubric",
        "text": {
          "en-US": "With hands joined, the Priest adds the Dismissal.",
          "pt-BR": "De mãos juntas, o sacerdote acrescenta a despedida."
        }
      },
      {
        "type": "options",
        "label": {
          "en-US": "Dismissal",
          "pt-BR": "Despedida"
        },
        "options": [
          {
            "id": "of-dismiss-a",
            "label": {
              "en-US": "Form A",
              "pt-BR": "Forma A"
            },
            "sections": [
              {
                "type": "prayer",
                "speaker": "priest",
                "inline": {
                  "en-US": "Go and announce the Gospel of the Lord.",
                  "la": "Ite, ad Evangélium Dómini annuntiándum.",
                  "pt-BR": "Ide anunciar o Evangelho do Senhor."
                }
              },
              {
                "type": "prayer",
                "speaker": "people",
                "inline": {
                  "en-US": "Thanks be to God.",
                  "la": "Deo grátias.",
                  "pt-BR": "Graças a Deus."
                }
              }
            ]
          },
          {
            "id": "of-dismiss-b",
            "label": {
              "en-US": "Form B",
              "pt-BR": "Forma B"
            },
            "sections": [
              {
                "type": "prayer",
                "speaker": "priest",
                "inline": {
                  "en-US": "Go in peace, glorifying the Lord by your life.",
                  "la": "Ite in pace, glorificándo vita vestra Dóminum.",
                  "pt-BR": "Glorificai o Senhor com a vossa vida. Ide em paz, e o Senhor vos acompanhe."
                }
              },
              {
                "type": "prayer",
                "speaker": "people",
                "inline": {
                  "en-US": "Thanks be to God.",
                  "la": "Deo grátias.",
                  "pt-BR": "Graças a Deus."
                }
              }
            ]
          },
          {
            "id": "of-dismiss-c",
            "label": {
              "en-US": "Form C",
              "pt-BR": "Forma C"
            },
            "sections": [
              {
                "type": "prayer",
                "speaker": "priest",
                "inline": {
                  "en-US": "Go in peace.",
                  "la": "Ite in pace.",
                  "pt-BR": "Ide em paz, e o Senhor vos acompanhe."
                }
              },
              {
                "type": "prayer",
                "speaker": "people",
                "inline": {
                  "en-US": "Thanks be to God.",
                  "la": "Deo grátias.",
                  "pt-BR": "Graças a Deus."
                }
              }
            ]
          },
          {
            "id": "of-dismiss-d",
            "label": {
              "en-US": "Form D",
              "pt-BR": "Forma D"
            },
            "sections": [
              {
                "type": "prayer",
                "speaker": "priest",
                "inline": {
                  "en-US": "Go forth, the Mass is ended.",
                  "la": "Ite, missa est.",
                  "pt-BR": "A Missa terminou. Ide em paz, e o Senhor vos acompanhe."
                }
              },
              {
                "type": "prayer",
                "speaker": "people",
                "inline": {
                  "en-US": "Thanks be to God.",
                  "la": "Deo grátias.",
                  "pt-BR": "Graças a Deus."
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
