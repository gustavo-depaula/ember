    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "en-US": "O Jesus, meek and humble of heart,",
            "pt-BR": "Ó Jesus, manso e humilde de coração,"
          },
          "r": {
            "en-US": "Hear me.",
            "pt-BR": "Ouvi-me."
          }
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "en-US": "From the desire of being esteemed,",
            "pt-BR": "Do desejo de ser estimado,"
          },
          "r": {
            "en-US": "Deliver me, Jesus.",
            "pt-BR": "Livrai-me, Jesus."
          }
        },
        {
          "v": {
            "en-US": "From the desire of being loved,",
