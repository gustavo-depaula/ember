    {
      "type": "divider"
    },
    {
      "type": "response",
      "verses": [
        {
          "v": {
            "en-US": "That others may be loved more than I,",
            "pt-BR": "Que os outros sejam mais amados do que eu,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That others may be esteemed more than I,",
            "pt-BR": "Que os outros sejam mais estimados do que eu,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That, in the opinion of the world, others may increase and I may decrease,",
            "pt-BR": "Que, na opinião do mundo, os outros cresçam e eu diminua,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That others may be chosen and I set aside,",
            "pt-BR": "Que os outros sejam escolhidos e eu posto de lado,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That others may be praised and I go unnoticed,",
            "pt-BR": "Que os outros sejam louvados e eu passe despercebido,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That others may be preferred to me in everything,",
            "pt-BR": "Que os outros sejam preferidos a mim em tudo,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        },
        {
          "v": {
            "en-US": "That others may become holier than I, provided that I may become as holy as I should,",
            "pt-BR": "Que os outros se tornem mais santos do que eu, contanto que eu me torne tão santo quanto devo,"
          },
          "r": {
            "en-US": "Jesus, grant me the grace to desire it.",
            "pt-BR": "Jesus, dai-me a graça de desejá-lo."
          }
        }
      ]
    }
