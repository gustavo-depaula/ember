{
  "id": "sanctorale.10-10.spain",
  "kind": "sanctoral",
  "scope": "spain",
  "structure": "mass",
  "title": {
    "es": "Santo Tomás de Villanueva, obispo"
  },
  "description": {
    "es": "Aun cuando sus padres vivieron en Villanueva de los Infantes, Tomás nació en Fuenllana, el año 1486. Estudió en la universidad de Alcalá, de la que, más tarde, fue maestro preclaro, dada su gran preparación en las ciencias humanas y sagradas. Nombrado arzobispo de Valencia, fue un verdadero modelo de buen pastor, sobresaliendo por su caridad, pobreza, prudencia y celo apostólico. Murió el 8 de septiembre de 1555, y fue canonizado el año 1658."
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que quisiste asociar a santo Tomás de Villanueva,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "insigne por su doctrina y caridad,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "al número de los santos pastores de tu Iglesia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la gracia de permanecer continuamente"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "entre los miembros de tu familia santa."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Las ofrendas que te presentamos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en la fiesta de santo Tomás de Villanueva,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos merezcan una vida iluminada por la ciencia"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y una ciencia enriquecida por la vida."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, Dios nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que los sacramentos recibidos"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "acrecienten en nosotros aquel ardor de la caridad"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que abrasó a santo Tomás de Villanueva"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y le impulsaba a entregarse constantemente"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "al servicio de tu Iglesia."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
