{
  "id": "sanctorale.01-04.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "Saint Elizabeth Ann Seton, Religious"
  },
  "color": "white",
  "rank": "memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Praise to the holy woman whose home is built on faithful love and whose pathway leads to God."
                },
                {
                  "type": "rubric",
                  "text": "Or:"
                },
                {
                  "type": "reference",
                  "text": "Cf. Ps 24 (23):6"
                },
                {
                  "type": "text",
                  "text": "This is the generation"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "which seeks the face of the God of Jacob."
                }
              ]
            ]
          },
          "citation": {
            "en-US": "Cf. Prv 14:1-2"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, who crowned with the gift of true faith"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Saint Elizabeth Ann Seton's burning zeal to find you,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant by her intercession and example"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that we may always seek you with diligent love"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and find you in daily service with sincere faith."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O Lord, we ask that you look graciously"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "upon our gifts placed on your altar"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in celebration of Saint Elizabeth Ann Seton, and grant by the power at work in this sacrifice, that we may be more deeply inserted"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "into the mystery of your Son."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Who lives and reigns for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "As we partake of the sacrament of our salvation,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "while recalling the memory of Saint Elizabeth Ann Seton,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "we humbly ask you, O Lord,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that we may be inflamed with a burning desire for the heavenly table, and by its power consecrate our life faithfully to you."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
