{
  "id": "sanctorale.05-15.spain",
  "kind": "sanctoral",
  "scope": "spain",
  "structure": "mass",
  "title": {
    "es": "San Isidro, labrador"
  },
  "description": {
    "es": "A finales del siglo XI nace san Isidro en Madrid, en cuya parroquia de san Andrés fue bautizado. Contrajo matrimonio en Torrelaguna con María de la Cabeza. Trabajó como jornalero agricultor. Murió muy anciano. La tradición popular reservó la memoria de su espíritu de oración y de generosidad con los necesitados. Es patrono del campo español. Fue canonizado por Gregorio XV el año 1622. Su cuerpo se conserva incorrupto en la Colegiata de San Isidro, en Madrid."
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "El labrador aguarda paciente el fruto precioso de la tierra, esperando con paciencia hasta que recibe la lluvia temprana y la tardía"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ]
          },
          "citation": {
            "es": "St 5,7"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, Dios nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que en la humildad y sencillez"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de san Isidro, labrador, nos dejaste un ejemplo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de vida escondida en ti, con Cristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos que el trabajo de cada día"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "humanice nuestro mundo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y sea al mismo tiempo plegaria de alabanza a tu nombre."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Acepta y santifica, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "estos dones de pan y de vino,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fruto de la tierra que cultivó san Isidro, labrador,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "regándola con el sudor de su frente."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oró y el cielo dio la lluvia y la tierra produjo su fruto"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "O bien:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Yo soy la verdadera vid y mi Padre es el labrador"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ]
          },
          "citation": {
            "es": "St 5, 18 (o bien:) Jn 15,1"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te pedimos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que el alimento santo que hemos recibido sea en nosotros"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "siembra prometedora de cosecha abundante de caridad,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, a imitación de san Isidro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "cuya memoria hemos celebrado,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sepamos compartir nuestro pan de cada día"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "con nuestros hermanos los hombres."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
