{
  "id": "sanctorale.10-11.spain",
  "kind": "sanctoral",
  "scope": "spain",
  "structure": "mass",
  "title": {
    "es": "Santa Soledad Torres Acosta, virgen"
  },
  "description": {
    "es": "María Soledad Torres Acosta nació en Madrid, el 2 de diciembre de 1826, y murió, también en Madrid, el 11 de octubre de 1887. Cuando el párroco de Chamberí se propuso fundar un instituto de religiosas dedicadas a la asistencia a los enfermos en su domicilio, Soledad fue la pieza clave de dicho instituto, que se llamó Congregación de Siervas de María, Ministras de los enfermos."
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tú que concediste a santa María Soledad, virgen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "servirte con amor generoso en los enfermos que visitaba,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos luz y tu gracia"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, descubriendo tu presencia en los que sufren,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "merezcamos tu compañía en el cielo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
