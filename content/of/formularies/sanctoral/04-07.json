                      "text": "nicht auf dem Weg der Sünder geht,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "nicht im Kreis der Spötter sitzt,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "sondern Freude hat an der Weisung des Herrn,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "über seine Weisung nachsinnt bei Tag und bei Nacht."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "sich verlässt."
                    }
                  ],
                  [
                    {
                      "type": "rubric",
                      "text": "Oder:"
                    },
                    {
                      "type": "text",
                      "text": "Der Gerechte gedeiht"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "wie die Palme in den Vorhöfen unseres Gottes."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Er ist wie ein Baum, der an Wasserbächen gepflanzt ist,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "der zur rechten Zeit seine Frucht bringt und dessen Blätter nicht welken."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Alles, was er tut, wird ihm gut gelingen."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "sich verlässt."
                    }
                  ],
                  [
                    {
                      "type": "rubric",
                      "text": "Oder:"
                    },
                    {
                      "type": "text",
                      "text": "Der Gerechte gedeiht"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "wie die Palme in den Vorhöfen unseres Gottes."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Nicht so die Frevler:"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Sie sind wie Spreu, die der Wind verweht."
                    }
