                    ]
                  ]
                }
              },
              {
                "lines": {
                  "la": [
                    [
                      {
                        "type": "text",
                        "text": "Iustus ut palma florébit in átriis Dei nostri."
                      }
                    ]
                  ]
                }
              }
            ],
            "verses": {
              "la": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Beátus vir qui non ábiit in consílio impiórum,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et in via peccatórum non stetit,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et in convéntu derisórum non sedit;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "sed in lege Dómini volúntas eius,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et in lege eius meditátur die ac nocte."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Et erit tamquam lignum plantátum secus decúrsus aquárum,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "quod fructum suum dabit in témpore suo;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et fólium eius non défluet,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et ómnia quæcúmque fáciet prosperabúntur."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Non sic ímpii, non sic,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "sed tamquam pulvis quem próicit ventus."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Quóniam novit Dóminus viam iustórum,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et iter impiórum períbit."
                    }
                  ]
                ]
              ],
              "es": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Dichoso el hombre que no sigue el consejo de los impíos,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ni entra por la senda de los pecadores,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ni se sienta en la reunión de los cínicos;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "sino que su gozo es la ley del Señor,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "y medita su ley día y noche."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Será como un árbol plantado al borde de la acequia:"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "da fruto en su sazón y no se marchitan sus hojas;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "y cuanto emprende tiene buen fin."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "No así los impíos, no así;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "serán paja que arrebata el viento."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Porque el Señor protege el camino de los justos,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "pero el camino de los impíos acaba mal."
                    }
                  ]
                ]
              ],
              "en-US": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Happy indeed is the man who follows not the counsel of the wicked; nor lingers in the way of sinners nor sits in the company of scorners, but whose delight is the law of the Lord and who ponders his law day and night."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "He is like a tree that is planted beside the flowing waters, that yields its fruit in due season and whose leaves shall never fade; and all that he does shall prosper."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Not so are the wicked, not so! For they like winnowed chaff shall be driven away by the wind. For the Lord guards the way of the just but the way of the wicked leads to doom."
                    }
                  ]
                ]
              ],
              "pt-BR": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Feliz é todo aquele que não anda conforme os conselhos dos perversos; que não entra no caminho dos malvados, nem junto aos zombadores vai sentar-se; mas encontra seu prazer na lei de Deus e a medita, dia e noite, sem cessar."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Eis que ele é semelhante a uma árvore que à beira da torrente está plantada;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ela sempre dá seus frutos a seu tempo, e jamais as suas folhas vão murchar."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Eis que tudo o que ele faz vai prosperar."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Mas bem outra é a sorte dos perversos. Ao contrário, são iguais à palha seca espalhada e dispersada pelo vento. Pois Deus vigia o caminho dos eleitos, mas a estrada dos malvados leva à morte."
                    }
                  ]
                ]
              ],
              "it": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Beato l’uomo che non entra nel consiglio dei malvagi,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "non resta nella via dei peccatori e non siede in compagnia degli arroganti,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ma nella legge del Signore trova la sua gioia,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "la sua legge medita giorno e notte."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "È come albero piantato lungo corsi d’acqua,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "che dà frutto a suo tempo:"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "le sue foglie non appassiscono e tutto quello che fa, riesce bene."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Non così, non così i malvagi,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ma come pula che il vento disperde;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "poiché il Signore veglia sul cammino dei giusti,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "mentre la via dei malvagi va in rovina."
                    }
                  ]
                ]
              ],
              "fr": [
                [
                  [
                    {
                      "type": "text",
                      "text": "Heureux est l’homme qui n’entre pas au conseil des méchants,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "qui ne suit pas le chemin des pécheurs,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "ne siège pas avec ceux qui ricanent,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "mais se plaît dans la loi du Seigneur et murmure sa loi jour et nuit !"
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Il est comme un arbre planté près d’un ruisseau,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "qui donne du fruit en son temps,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "et jamais son feuillage ne meurt ;"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "tout ce qu’il entreprend réussira."
                    }
                  ]
                ],
                [
                  [
                    {
                      "type": "text",
                      "text": "Tel n’est pas le sort des méchants."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Mais ils sont comme la paille balayée par le vent."
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "Le Seigneur connaît le chemin des justes,"
                    }
                  ],
                  [
                    {
                      "type": "text",
                      "text": "mais le chemin des méchants se perdra."
                    }
                  ]
                ]
              ],
              "de": [
                [
                  [
                    {
                      "type": "text",
                      "text": "sich verlässt."
                    }
                  ],
                  [
                    {
                      "type": "rubric",
                      "text": "Oder:"
