{
  "id": "sanctorale.03-03.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "Saint Katharine Drexel, Virgin"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "God of love,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "you called Saint Katharine Drexel"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to teach the message of the Gospel"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and to bring the life of the Eucharist"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to the Native American and African American peoples;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "by her prayers and example,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "enable us to work for justice"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "among the poor and the oppressed,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and keep us undivided in love"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in the eucharistic community of your Church."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
