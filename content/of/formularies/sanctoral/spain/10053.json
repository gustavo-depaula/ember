{
  "id": "sanctorale.spain.10053",
  "kind": "sanctoral",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "es": "Témporas de acción de gracias y de petición Día penitencial"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te compadeces de todos, Señor, y no aborreces nada de lo que hiciste: pasas por alto los pecados de los hombres para que se arrepientan, y los perdonas, porque tú eres nuestro Dios y Señor."
                }
              ]
            ]
          },
          "citation": {
            "es": "Sb 11, 24. 25"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te pedimos, Señor, que bondadosamente"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "escuches las súplicas y perdones las culpas"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de quienes ante ti nos reconocemos pecadores,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y nos concedas benigno la misericordia y la paz."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te ofrecemos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "estos dones de expiación y alabanza,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que perdones misericordiosamente nuestros pecados"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y dirijas nuestros corazones vacilantes."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "sanctorale.spain.10053.proper",
      "label": {
        "pt-BR": "Prefácio"
      },
      "body": {
        "lines": {
          "es": [
            [
              {
                "type": "text",
                "text": "El más apropiado es el Prefacio común IV."
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Habrá gran alegría entre los ángeles de Dios por un solo pecador que se convierta."
                }
              ]
            ]
          },
          "citation": {
            "es": "Lc 15, 10"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Concédenos, Dios misericordioso,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, al apreciar por esta comunión el perdón de los pecados,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en adelante podamos evitarlos con tu ayuda"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y servirte con sincero corazón."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
