{
  "id": "sanctorale.08-12.africa",
  "kind": "sanctoral",
  "scope": "africa",
  "structure": "mass",
  "title": {
    "en-US": "Blessed Isidoro Bakanja, Martyr"
  },
  "color": "red",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "God of power and mercy,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who called your Martyr, Blessed Isidoro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to be a disciple of Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and made him a fearless and courageous witness of the Christian faith;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant that we, who celebrate the day of his triumph,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "may be strengthened in our call to be true witnessess of the Gospel."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
