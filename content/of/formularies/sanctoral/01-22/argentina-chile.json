{
  "id": "sanctorale.01-22.argentina-chile",
  "kind": "sanctoral",
  "scope": "argentina-chile",
  "structure": "mass",
  "title": {
    "es": "Beata Laura Vicuña, Virgen"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Esta virgen sabia y prudente salió al encuentro de Cristo con la lámpara encendida."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Padre de inmensa ternura,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que en la adolescente Laura Vicuña uniste de modo admirable"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la fortaleza de espíritu y el candor de la inocencia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "valentía para superar las dificultades de la vida"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "v dar testimonio ante el mundo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de las bienaventuranzas de los limpios de corazón."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo, tu Hijo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que vive y reina contigo en la unidad del Espíritu Santo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y es Dios, por los siglos de los siglos."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te proclamamos admirable"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en la conmemoración de la beata Laura, virgen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y te pedimos humildemente"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, así como sus méritos fueron de tu agrado,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aceptes esta liturgia que celebramos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "sanctorale.01-22.argentina-chile.proper",
      "label": {
        "pt-BR": "Prefácio"
      },
      "body": {
        "lines": {
          "es": [
            [
              {
                "type": "rubric",
                "text": "Prefacio: La gloria de la Virgen María"
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación"
              }
            ],
            [
              {
                "type": "text",
                "text": "darte gracias siempre y en todo lugar"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por todas las grandes maravillas que has realizado"
              }
            ],
            [
              {
                "type": "text",
                "text": "en la Virgen, Madre de tu Hijo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Ella, concebida sin pecado,"
              }
            ],
            [
              {
                "type": "text",
                "text": "no fue contaminada por la corrupción del sepulcro;"
              }
            ],
            [
              {
                "type": "text",
                "text": "pues, siendo intacta en su virginidad,"
              }
            ],
            [
              {
                "type": "text",
                "text": "gloriosa en su descendencia"
              }
            ],
            [
              {
                "type": "text",
                "text": "y triunfante en su asunción,"
              }
            ],
            [
              {
                "type": "text",
                "text": "fue Madre de Cristo, esposo de la Iglesia,"
              }
            ],
            [
              {
                "type": "text",
                "text": "luz de las gentes,"
              }
            ],
            [
              {
                "type": "text",
                "text": "esperanza de los fieles"
              }
            ],
            [
              {
                "type": "text",
                "text": "y gozo de todo nuestro pueblo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "al celebrar ahora la fiesta del Pilar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos con los ángeles y los arcángeles,"
              }
            ],
            [
              {
                "type": "text",
                "text": "y con todos los coros celestiales,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando sin cesar el himno de tu gloria:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Ya viene el esposo, salgan al encuentro de Cristo, el Señor."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "O bien:"
                },
                {
                  "type": "reference",
                  "text": "Cf. Sal 26,4"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Una sola cosa he pedido al Señor, y esto es lo que quiero:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "vivir en la casa del Señor todos los días de mi vida."
                }
              ]
            ]
          },
          "citation": {
            "es": "Cf. Mt 25,6"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor y Dios nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fortalecidos con esta eucaristía"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te pedimos que, a ejemplo de la beata Laura,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "asumiendo en nuestro cuerpo los sufrimientos de Cristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos esforcemos por vivir unidos solamente a ti."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
