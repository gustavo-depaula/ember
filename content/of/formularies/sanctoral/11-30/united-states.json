{
  "id": "sanctorale.11-30.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "Thanksgiving Day Fourth Thursday in November"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Sing and make music to the Lord in your hearts, always thanking God the Father for all things"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in the name of our Lord Jesus Christ."
                }
              ]
            ]
          },
          "citation": {
            "en-US": "Eph 5:19-20"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Father all-powerful,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "your gifts of love are countless"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and your goodness infinite;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "as we come before you on Thanksgiving Day with gratitude for your kindness,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "open our hearts to have concern"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "for every man, woman, and child,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that we may share your gifts in loving service."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "God our Father,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "from whose hand we have received generous gifts"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that we might learn to share your blessings in gratitude,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accept these gifts of bread and wine,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and let the perfect sacrifice of Jesus"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "draw us closer to all our brothers and sisters in the human family."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "sanctorale.11-30.united-states.proper",
      "label": {
        "pt-BR": "Prefácio"
      },
      "body": {
        "lines": {
          "en-US": [
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation, always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God, through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "You have entrusted to us"
              }
            ],
            [
              {
                "type": "text",
                "text": "the great gift of freedom,"
              }
            ],
            [
              {
                "type": "text",
                "text": "a gift that calls forth"
              }
            ],
            [
              {
                "type": "text",
                "text": "responsibility and commitment"
              }
            ],
            [
              {
                "type": "text",
                "text": "to the truth that all have a fundamental dignity before you."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Jesus, through his death and resurrection,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we find our ultimate redemption,"
              }
            ],
            [
              {
                "type": "text",
                "text": "freedom from sin,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and every blessing."
              }
            ],
            [
              {
                "type": "text",
                "text": "As so, with hearts full of love,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we join the angels,"
              }
            ],
            [
              {
                "type": "text",
                "text": "today and every day of our lives,"
              }
            ],
            [
              {
                "type": "text",
                "text": "to sing your glory as we acclaim:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "How can I repay the Lord for all his goodness to me? The chalice of salvation I will raise,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and I will call on the name of the Lord."
                }
              ]
            ]
          },
          "citation": {
            "en-US": "Ps 138 (137 (138):1"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "In this celebration, O Lord our God,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "you have shown us the depths of your love for all your children; help us, we pray, to reach out in love to all your people,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that we may share with them"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "the good things of time and eternity."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
