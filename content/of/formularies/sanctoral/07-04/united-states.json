{
  "id": "sanctorale.07-04.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "July 4 Independence Day"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Give peace, Lord, to those who wait for you; listen to the prayers of your servants,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and guide us in the way of justice."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "God of justice, Father of truth,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who guide creation in wisdom and goodness"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to fulfillment in Christ your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "open our hearts to the truth of his gospel,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that your peace may rule in our hearts"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and your justice guide our lives."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                },
                {
                  "type": "rubric",
                  "text": "Or:"
                },
                {
                  "type": "text",
                  "text": "Father of all nations and ages,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "we recall the day when our country"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "claimed its place among the family of nations;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "for what has been achieved we give you thanks,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "for the work that still remains we ask your help,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and as you have called us from many peoples to be one nation, grant that, under your providence,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "our country may share your blessings"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "with all the peoples of the earth."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Accept, Lord God, these gifts we bring to this altar"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and, having taught us through the wisdom of the gospel, lead us to true justice and lasting peace."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                },
                {
                  "type": "rubric",
                  "text": "Or:"
                },
                {
                  "type": "text",
                  "text": "Father, who have molded into one our nation, drawn from the peoples of many lands;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant, that as the grains of wheat become one bread and the many grapes one cup of wine,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so before all others be instruments of your peace."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "sanctorale.07-04.united-states.proper",
      "label": {
        "pt-BR": "Prefácio"
      },
      "body": {
        "lines": {
          "en-US": [
            [
              {
                "type": "text",
                "text": "O_BIEN"
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation, always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "He spoke to us a message of peace"
              }
            ],
            [
              {
                "type": "text",
                "text": "and taught us to live as brothers and sisters."
              }
            ],
            [
              {
                "type": "text",
                "text": "His message took form in the vision of our founding fathers as they fashioned a nation"
              }
            ],
            [
              {
                "type": "text",
                "text": "where we might live as one."
              }
            ],
            [
              {
                "type": "text",
                "text": "His message lives on in our midst"
              }
            ],
            [
              {
                "type": "text",
                "text": "as our task for today"
              }
            ],
            [
              {
                "type": "text",
                "text": "and a promise for tomorrow."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with hearts full of love,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we join the angels today and every day of our lives, to sing your glory as we acclaim:"
              }
            ],
            [
              {
                "type": "text",
                "text": "O_BIEN"
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation, always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God, through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "For we praise you as the God of creation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "as the Father of Jesus, the Savior of the world,"
              }
            ],
            [
              {
                "type": "text",
                "text": "in whose image we seek to live."
              }
            ],
            [
              {
                "type": "text",
                "text": "He loved the children of the lands he walked"
              }
            ],
            [
              {
                "type": "text",
                "text": "and enriched them with his witness of justice and truth. He lived and died that we might be reborn in the Spirit and filled with love for all people."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with hearts full of love,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we join the angels today and every day of our lives,"
              }
            ],
            [
              {
                "type": "text",
                "text": "to sing your glory as we acclaim:"
              }
            ]
          ]
        }
      }
    }
  ],
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "By showing us in this Eucharist, O Lord, a glimpse of the unity and joy"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "of your people in heaven,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "deepen our unity and intensify our joy, that all who believe in you"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "may work together to build the city of lasting peace."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                },
                {
                  "type": "rubric",
                  "text": "Or:"
                },
                {
                  "type": "text",
                  "text": "May the love we share in this Eucharist, heavenly Father, flow in rich blessing throughout our land"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and by your grace may we as a nation"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "place our trust in you"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and seek to do your will."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverPeople": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "May God the Father who has called us to be one human family"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fill your hearts with deep longing"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "for peace and harmony."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "℟."
                },
                {
                  "type": "text",
                  "text": "Amen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "May the Son of God who came to share our life and make us children of the one Father"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "enable you to grow in wisdom and grace"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "before God and the human family."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "℟."
                },
                {
                  "type": "text",
                  "text": "Amen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "And may the Holy Spirit who is the bond of love between the Father and the Son"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "unite in love all here present;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "may he be the bond of love among you, our nation, and all peoples."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "℟."
                },
                {
                  "type": "text",
                  "text": "Amen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "And may the blessing of almighty God,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "the Father, and the Son, ✠ and the Holy Spirit, come down on you and remain with you for ever."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "℟."
                },
                {
                  "type": "text",
                  "text": "Amen."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
