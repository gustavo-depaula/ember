{
  "id": "sanctorale.05-10.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "Saint Damien de Veuster, Priest"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Father of mercy,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who gave us in Saint Damien"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a shining witness of love for the poorest and most abandoned, grant that, by his intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "as faithful witnesses of the heart of your Son Jesus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "we too may be servants of the most needy and rejected. Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
