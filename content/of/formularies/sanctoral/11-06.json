  "prefaces": [
    {
      "id": "pf054",
      "label": {
        "la": "PRÆFATIO I DE SANCTIS MARTYRIBUS",
        "es": "PREFACIO I DE LOS SANTOS MÁRTIRES",
        "en-US": "Preface I of Holy Martyrs",
        "pt-BR": "Prefácio dos Santos Mártires I o",
        "it": "PREFAZIO DEI SANTI MARTIRI",
        "fr": "PRÉFACE DES SAINTS MARTYRS I",
        "de": "PRÄFATION VON DEN MÄRTYRERN I"
      },
      "excerpt": {
        "la": "De signo et exemplo martyrii",
        "es": "Significado y ejemplaridad del martirio",
        "en-US": "The sign and example of martyrdom",
        "pt-BR": "testemunho do martírio",
        "it": "Il segno e l’esempio del martirio",
        "fr": "Signification et valeur exemplaire du martyre",
        "de": "Der Märtyrer als Zeuge der Kraft Gottes"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Ss. Martyrum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Quóniam beáti mártyris"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "pro confessióne nóminis tui,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ad imitatiónem Christi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sanguis effúsus tua mirabília maniféstat,"
              }
            ],
            [
              {
                "type": "text",
                "text": "quibus pérficis in fragilitáte virtútem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et vires infírmas ad testimónium róboras,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum cælórum Virtútibus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "in terris te iúgiter celebrámus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "maiestáti tuæ sine fine clamántes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de los santos Mártires. Se puede decir también en las memorias de los mismos"
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque la sangre del glorioso mártir san"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              }
            ],
            [
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "derramada, como la de Cristo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "para confesar tu nombre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "manifiesta las maravillas de tu poder;"
              }
            ],
            [
              {
                "type": "text",
                "text": "pues en su martirio, Señor,"
              }
            ],
            [
              {
                "type": "text",
                "text": "has sacado fuerza de lo débil,"
              }
            ],
            [
              {
                "type": "text",
                "text": "haciendo de la fragilidad tu propio testimonio;"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con las virtudes del cielo te aclamamos continuamente en la tierra,"
              }
            ],
            [
              {
                "type": "text",
                "text": "alabando tu gloria sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Martyrs. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For the blood of your blessed Martyr"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "poured out like Christ's to glorify your name,"
              }
            ],
            [
              {
                "type": "text",
                "text": "shows forth your marvellous works,"
              }
            ],
            [
              {
                "type": "text",
                "text": "by which in our weakness you perfect your power and on the feeble bestow strength to bear you witness,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with the Powers of heaven,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we worship you constantly on earth,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and before your majesty without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas dos Santos Mártires; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "O sangue que o"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "a"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "Santo"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "a"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "Mártir"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "derramou,"
              }
            ],
            [
              {
                "type": "text",
                "text": "à imitação de Cristo, para a glória do vosso nome,"
              }
            ],
            [
              {
                "type": "text",
                "text": "manifesta as vossas maravilhas;"
              }
            ],
            [
              {
                "type": "text",
                "text": "assim, transformais a fragilidade humana em força e aos fracos dais coragem para o testemunho,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com as Virtudes celestes,"
              }
            ],
            [
              {
                "type": "text",
                "text": "vos celebramos na terra louvando vossa majestade,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Il seguente prefazio si dice nelle solennità e nelle feste dei santi martiri. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta, nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "rendere grazie sempre e in ogni luogo * a te, Signore, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Il sangue versato dal santo martire N.,"
              }
            ],
            [
              {
                "type": "text",
                "text": "a imitazione di Cristo e per la gloria del tuo nome,"
              }
            ],
            [
              {
                "type": "text",
                "text": "manifesta i tuoi prodigi, o Padre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "che riveli nei deboli la tua potenza e doni agli inermi la forza del martirio,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo Signore nostro."
              }
            ],
            [
              {
                "type": "text",
                "text": "E noi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con tutti gli angeli del cielo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "a te innalziamo sulla terra il nostro canto e proclamiamo senza fine la tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette préface se dit aux solennités et fêtes des saints martyrs. On peut la dire aux mémoires des martyrs."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nous reconnaissons un signe éclatant de ta grâce dans le martyre de saint"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "de sainte, des saints, des saintes"
              },
              {
                "type": "rubric",
                "text": ") N."
              },
              {
                "type": "text",
                "text": ";"
              }
            ],
            [
              {
                "type": "text",
                "text": "en répandant son (leur) propre sang comme le Christ,"
              }
            ],
            [
              {
                "type": "text",
                "text": "il a (elle a, ils ont, elles ont) glorifié ton nom."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est ta puissance qui se déploie dans la faiblesse quand tu donnes à des êtres fragiles de te rendre témoignage par le Christ, notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi, avec les puissances des cieux,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous pouvons te bénir sur la terre et t’adorer sans fin en proclamant :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Märtyrern genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und in den Heiligen deine Größe zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Im Martyrium des"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "der"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "heiligen"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "offenbarst du das Wunder deiner Gnade,"
              }
            ],
            [
              {
                "type": "text",
                "text": "denn in der menschlichen Schwachheit bringst du deine göttliche Kraft zur Vollendung."
              }
            ],
            [
              {
                "type": "text",
                "text": "Er"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "Sie"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "ist"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "sind"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "Christus nachgefolgt auf dem Weg des Leidens und hat"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "haben"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "sein"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "ihr"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "Blut vergossen als Zeuge"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "n"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "des Glaubens."
              }
            ],
            [
              {
                "type": "text",
                "text": "Darum preisen wir dich in deiner Kirche und vereinen uns mit den Engeln und Heiligen zum Hochgesang von deiner göttlichen Herrlichkeit:"
              }
