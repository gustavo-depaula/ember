            "verse": {
              "lines": {
                "la": [
                  [
                    {
                      "type": "response",
                      "text": "Allelúia."
                    },
                    {
                      "type": "text",
                      "text": "Qui odit ánimam suam in hoc mundo, in vitam aetérnam custódiet eam."
                    },
                    {
                      "type": "response",
                      "text": "Allelúia."
                    }
                  ]
                ],
                "es": [
                  [
                    {
                      "type": "response",
                      "text": "Aleluya."
                    },
                    {
                      "type": "text",
                      "text": "El que se aborrece a sí mismo en este mundo, se guardará para la vida eterna."
                    },
                    {
                      "type": "response",
                      "text": "Aleluya."
                    }
                  ]
                ],
                "fr": [
                  [
                    {
                      "type": "response",
