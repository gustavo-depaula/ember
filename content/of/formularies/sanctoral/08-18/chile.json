{
  "id": "sanctorale.08-18.chile",
  "kind": "sanctoral",
  "scope": "chile",
  "structure": "mass",
  "title": {
    "es": "San Alberto Hurtado Cruchaga, presbítero"
  },
  "color": "white",
  "rank": "feast",
  "cycleScheme": "fixed",
  "includeGloria": true,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Vengan benditos de mi Padre -dice el Señor"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "porque estuve enfermo y me visitaron."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "En verdad les digo que cuanto hicieron con el más pequeño de mis hermanos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "conmigo lo hicieron."
                }
              ]
            ]
          },
          "citation": {
            "es": "Mt 25, 34.36.40"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Dios y Padre nuestro, que en san Alberto, presbítero,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos diste un signo admirable de tu amor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por su intercesión, concédenos perseverar unidos en el Evangelio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "acompañando con el amor de Cristo a nuestro hermanos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "especialmente los abandonados y los pobres,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y promover así el reino de justicia, de amor y de paz."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo tu Hijo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que vive y reina contigo en la unidad del Espíritu Santo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y es Dios, por los siglos de los siglos."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Recibe, Señor, los dones de tu pueblo"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y concédenos que, al recordar las maravillas"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que el amor de tu Hijo realizó con nosotros,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos reafirmemos, a ejemplo de san Alberto"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en el amor a ti y al prójimo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Nadie tiene amor más grande que el que da la vida por sus amigos."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "O bien"
                },
                {
                  "type": "reference",
                  "text": "Cf. Jn 13, 35"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "La señal por la que conocerán que son discípulos míos será que se amen unos a otros, dice el Señor."
                }
              ]
            ]
          },
          "citation": {
            "es": "Jn 15, 13"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Alimentados con estos sagrados misterios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te pedimos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos ayudes a seguir los ejemplos de san Alberto"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que te rindió culto con devoción constante,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y se entregó a tu pueblo en un continuo servicio de amor."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo nuestro Señor."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
