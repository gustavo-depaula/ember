{
  "id": "sanctorale.01-10.spain",
  "kind": "sanctoral",
  "scope": "spain",
  "structure": "mass",
  "title": {
    "es": "Beata Ana de los Ángeles Monteagudo, virgen"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, en tu bondad,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "otorgaste a la beata Ana de los Ángeles, virgen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "los dones de la contemplación, el espíritu de penitencia"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y el continuo servicio de amor al prójimo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, imitándola, te adoremos con el sacrificio de alabanza,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y, a través de los signos de nuestro tiempo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sepamos conocer, con diligencia, tu voluntad."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
