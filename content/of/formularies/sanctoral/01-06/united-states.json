{
  "id": "sanctorale.01-06.united-states",
  "kind": "sanctoral",
  "scope": "united-states",
  "structure": "mass",
  "title": {
    "en-US": "Saint André Bessette, Religious"
  },
  "color": "white",
  "rank": "memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Lord our God, friend of the lowly,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who gave your servant, Saint André Bessette,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a great devotion to Saint Joseph"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and a special commitment to the poor and afflicted,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "help us through his intercession"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to follow his example of prayer and love"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and so come to share with him in your glory."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
