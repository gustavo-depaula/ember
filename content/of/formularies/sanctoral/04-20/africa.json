{
  "id": "sanctorale.04-20.africa",
  "kind": "sanctoral",
  "scope": "africa",
  "structure": "mass",
  "title": {
    "en-US": "Saint Marcellinus, Bishop"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, our Father,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who desire all peoples of the world"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to recognise Jesus as the one you sent to save us;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "look with kindness o us,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "as we celebrate the memorial of Saint Marcellinus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and fill us with the same missionary zeal and spirit."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
