{
  "id": "sanctorale.01-09.africa",
  "kind": "sanctoral",
  "scope": "africa",
  "structure": "mass",
  "title": {
    "en-US": "Saint Adrian of Canterbury, Abbot"
  },
  "color": "white",
  "rank": "optional-memorial",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O Father of mercy,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who called Saint Adrian to follow the Lord"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "as a monk and a missionary;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant, we beseech you,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that we may be filled with the same faith and zeal,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and walk always as children of the light."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
