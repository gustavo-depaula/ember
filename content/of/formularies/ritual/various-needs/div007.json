{
  "id": "ritual.various-needs.div007",
  "kind": "ritual",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "I. PRO SANCTA ECCLESIA 3. PRO EPISCOPO",
    "es": "I. POR LA SANTA IGLESIA 3. POR EL OBISPO",
    "en-US": "I. for Holy Church 3. for the Bishop",
    "pt-BR": "I. pela Santa Igreja 3. pelo bispo",
    "it": "I. PER LA SANTA CHIESA 3. Per il Vescovo Specialmente nell’anniversario dell’ordinazione",
    "fr": "I. POUR LA SAINTE ÉGLISE 3. POUR L’ÉVÊQUE",
    "de": "I. FÜR DIE HEILIGE KIRCHE 3. FÜR DEN BISCHOF"
  },
  "color": "green",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Visitábo oves meas, dicit Dóminus, et suscitábo pastórem qui pascat eas; ego autem Dóminus ero eis in Deum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Buscaré a mis ovejas, dice el Señor, y suscitaré un pastor que las apaciente:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "yo, el Señor, seré su Dios."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "I will look after my sheep, says the Lord,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and I will appoint a shepherd to pasture them, and I, the Lord, will be their God."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Visitarei minhas ovelhas, diz o Senhor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e suscitarei um pastor que as apascentará;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "eu, o Senhor, serei o seu Deus."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "«Io cercherò le mie pecore», dice il Signore, «e susciterò un pastore che le pascerà: io, il Signore, sarò il loro Dio»."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Voici que je m’occuperai de mes brebis, dit le Seigneur ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "je susciterai à leur tête un berger, qui les fera paître."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Alors moi, le Seigneur, je serai leur Dieu."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "So spricht Gott, der Herr: Ich selbst will meine Herde aufsuchen und für sie einen Hirten einsetzen, der sie auf die Weide führt. Ich selbst, der Herr,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "werde ihr Gott sein."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Da, quǽsumus, Dómine, fámulo tuo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", quem pascéndo gregi tuo in Apostolórum successióne præfecísti, spíritum consílii et fortitúdinis, spíritum sciéntiæ et pietátis, ut, pópulum sibi créditum fidéliter gubérnans, Ecclésiæ ædíficet in mundo sacraméntum. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te rogamos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que concedas a tu siervo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a quien pusiste al frente de tu pueblo como sucesor de los apóstoles,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "el espíritu de consejo y de fortaleza,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de ciencia y de piedad,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, pastoreando fielmente al pueblo que le ha sido encomendado,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "edifique la Iglesia como sacramento en el mundo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O Lord, who for the feeding of your flock have set your servant"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "over it as a successor to the apostles,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant him, we pray,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a spirit of counsel and fortitude,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a spirit of knowledge and piety,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that, by faithfully governing the people entrusted to him, he may build up in the world the sacrament of the Church."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, que fizestes o vosso servo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "sucessor dos Apóstolos para apascentar o vosso rebanho,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dai-lhe o espírito de conselho e fortaleza,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "o espírito de ciência e piedade para que, governando fielmente o povo que lhe foi confiado,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "edifique no mundo a Igreja como sacramento da salvação."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Dona, o Signore, al tuo servo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", che nella successione apostolica hai posto a guidare il tuo gregge, uno spirito di consiglio e di fortezza, di scienza e di pietà, perché, governando fedelmente il popolo a lui affidato, edifichi nel mondo la tua Chiesa, sacramento di salvezza. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Nous t’en prions,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Seigneur :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "donne à ton serviteur"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "que tu as placé, dans la succession apostolique,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "comme pasteur à la tête de ton troupeau,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "un esprit de conseil et de force,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "un esprit de science et de piété,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "afin qu’il gouverne fidèlement le peuple que tu lui as confié et construise ainsi l’Église, sacrement du salut dans le monde."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gott, du Herr der Kirche, du hast deinen Diener N. dazu berufen, in der Nachfolge der Apostel deine Herde zu weiden. Erfülle ihn mit dem Geist des Rates und der Stärke, der Erkenntnis und der Frömmigkeit, damit er das Volk, das du ihm anvertraut hast,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "gewissenhaft führt und die Kirche auferbaut als Zeichen des Heils für die Welt. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Hæc oblátio, Dómine, pro fámulo tuo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "delátasit tibi munus accéptum, et, quem sacerdótem magnum in tuo pópulo suscitásti,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "apostolicárum virtútum munéribus, ad gregis proféctum, exórna. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "acepta la ofrenda que te presentamos por tu siervo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y dígnate enriquecer con virtudes apostólicas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para bien de tu grey,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "al que pusiste como pontífice al frente de tu pueblo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "May this oblation, O Lord,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "which we have presented for your servant"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", become an offering acceptable to you,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "for the good of the flock,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "may he, whom you have raised up among your people to be high Priest,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "be endowed, by your gift, with apostolic virtues."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, seja do vosso agrado esta oblação apresentada em favor do vosso servo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e, para o proveito do rebanho,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "revesti com os dons das virtudes apostólicas aquele que, do meio de vosso povo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "suscitastes como sumo sacerdote."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ti sia gradita, o Signore, l’offerta che portiamo all’altare per il tuo servo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "il vescovo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ": tu, che lo hai scelto in mezzo al tuo popolo per la pienezza del sacerdozio, rivestilo delle virtù degli apostoli per la crescita del tuo santo gregge. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Accueille,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Seigneur, cette offrande que nous te présentons pour ton serviteur"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "que tu as appelé comme grand prêtre au milieu de ton peuple ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour que progresse le troupeau,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-lui d’être revêtu des qualités dont firent preuve les Apôtres."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast deinen Diener N. zum Hohenpriester in deinem Volk berufen. Für ihn bringen wir diese Gabe dar;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "schenke ihm zum Wohl deiner Kirche die Weisheit und Tatkraft der Apostel."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Fílius hóminis non venit ministrári, sed ministráre, et dare ánimam suam redemptiónem pro multis."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "El Hijo del hombre no ha venido a ser servido sino a servir y a dar su vida en rescate por muchos."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The Son of Man did not come to be served, but to serve, and to give his life as a ransom for many."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "O Filho do homem não veio para ser servido,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "mas para servir e dar a sua vida como resgate em favor de muitos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Il Figlio dell’uomo non è venuto per essere servito, ma per servire e dare la propria vita in riscatto per molti."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Le Fils de l’homme n’est pas venu pour être servi, mais pour servir,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et donner sa vie en rançon pour la multitude."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Der Menschensohn ist nicht gekommen, um sich bedienen zu lassen, sondern um zu dienen und sein Leben hinzugeben als Lösegeld für viele."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Huius, Dómine, virtúte mystérii, in fámulo tuo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "epíscopo nostro grátiæ tuæ dona multíplica, ut et tibi digne persólvat pastorále ministérium, et fidélis dispensatiónis ætérna prǽmia consequátur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, por la eficacia de este sacramento multiplica en tu siervo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", nuestro obispo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "los dones de tu gracia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que ejerza dignamente en tu servicio el ministerio pastoral y, por su fidelidad,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "consiga los premios eternos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "By the power of this sacrament, O Lord,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "increase the gifts of your grace in"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", your servant and our Bishop,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that he may serve you worthily in the pastoral ministry and receive the eternal rewards of a faithful steward."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, pela força deste mistério,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "multiplicai os dons da vossa graça no vosso servo, nosso Bispo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que exerça com dignidade o ministério pastoral e, pela fidelidade no vosso serviço,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "alcance o prêmio eterno."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Per la potenza di questo mistero, o Signore, moltiplica i doni della tua grazia nel tuo servo, il vescovo"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", perché compia degnamente davanti a te il ministero pastorale e riceva il premio eterno promesso agli amministratori fedeli. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur, par la force du mystère que nous avons célébré,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "multiplie les dons de ta grâce en ton serviteur"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", notre évêque :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’il s’acquitte de son ministère pastoral d’une manière digne de toi,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et reçoive dans l’éternité la récompense promise aux intendants fidèles."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gütiger Gott, schenke durch die Kraft dieses heiligen Opfers unserem Bischof N. deine Gnadengaben in reicher Fülle. Hilf ihm,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sein Hirtenamt gut zu verwalten, und lohne ihm die Treue im Heilsdienst mit der ewigen Freude. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
