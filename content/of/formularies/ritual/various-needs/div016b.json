{
  "id": "ritual.various-needs.div016b",
  "kind": "ritual",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "I. PRO SANCTA ECCLESIA 11. IN ANNIVERSARIIS MATRIMONII B In XXV anniversario",
    "es": "I. POR LA SANTA IGLESIA 11. EN LOS ANIVERSARIOS DEL MATRIMONIO B En el XXV aniversario (bodas de plata)",
    "en-US": "I. for Holy Church 11. on the Anniversaries of Marriage B On the Twenty-Fifth Anniversary",
    "pt-BR": "I. Pela Santa Igreja 11. nos Aniversários de Casamento B No 25º aniversário",
    "it": "I. PER LA SANTA CHIESA 11. PER L’ANNIVERSARIO DEL MATRIMONIO B.Nel venticinquesimo anniversario",
    "fr": "I. POUR LA SAINTE ÉGLISE 11. POUR LES ANNIVERSAIRES DE MARIAGE B Pour le 25e anniversaire",
    "de": "I. FÜR DIE HEILIGE KIRCHE"
  },
  "color": "green",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Cantáte et psállite in córdibus vestris Dómino, grátias agéntes semper pro ómnibus in nómine Dómini nostri Iesu Christi Deo et Patri."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Cantad y tocad con toda el alma para el Señor. Dad siempre gracias a Dios Padre por todo, en nombre de nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Sing and make music to the Lord in your hearts, always thanking god the father for all things in the name of our Lord Jesus Christ."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Cantai e celebrai o Senhor de todo o vosso coração."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Em todo o tempo e a propósito de tudo rendei graças a Deus Pai em nome de nosso Senhor Jesus Cristo."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Chantez le Seigneur et célébrez-le de tout votre cœur."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "À tout moment et pour toutes choses,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "au nom de notre Seigneur Jésus Christ,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "rendez grâce à Dieu le Père."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Singt und jubelt aus vollen Herzen zum Lob des Herrn! Sagt Gott, dem Vater,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "jederzeit Dank für alles im Namen unseres Herrn Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Dómine, qui hos fámulos tuos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "indissolúbili matrimónii nexu coniunxísti, et animórum communióne dignátus es inter labóres et gáudia sustentáre, eórum,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "quǽsumus, auge et purífica caritátem, ut mútua (cum prole sua)"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sanctificatióne læténtur. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, que unciste a estos siervos tuyos,"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "con el vínculo indisoluble del matrimonio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y los has mantenido cordialmente unidos en sus trabajos y alegrías,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "acrecienta y purifica su amor para que"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "["
                },
                {
                  "type": "text",
                  "text": "juntamente con sus hijos"
                },
                {
                  "type": "rubric",
                  "text": "]"
                },
                {
                  "type": "text",
                  "text": "se alegren con su mutua santidad."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O Lord, who have joined these your servants"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in the unbreakable bond of marriage and have been pleased to sustain them in communion of spirit amid toil and joy,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "increase, we pray, and purify their love,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that (together with their children) they may rejoice in the sanctification they bring to each other."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, unistes estes vossos filhos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "pelo vínculo indissolúvel do Matrimônio e vos dignastes conservar os seus corações unidos nas fadigas e nas alegrias;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nós vos pedimos:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aumentai e purificai o seu amor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que juntamente com seus filhos se alegrem com a mútua santificação."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu ne fermes jamais ton cœur à la prière de tes serviteurs en détresse ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous te rendons grâce pour ta grande bonté,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et nous te supplions humblement :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fais que, délivrés de tout mal,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous te servions toujours dans la joie."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, du hast deine Diener N. und N. in unauflöslicher Ehe verbunden. In guten und bösen Tagen bist du ihnen nahe geblieben. Mehre und läutere ihre Liebe, gib,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dass sie einander bestehen auf dem Weg zu dir und (mit ihren Kindern) in deiner Gnade wachsen. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Hæc múnera, Deus, in gratiárum actiónem pro fámulis tuis"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "dignánter assúme,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ut exínde pacem et gáudium abundánter exháuriant. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Acoge con bondad, Señor, estos dones que te presentamos en acción de gracias por tus siervos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que obtengan como fruto paz y alegría."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Be pleased, o God, to receive these offerings in thanksgiving for your servants"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that from them they may draw peace and joy in abundance."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, acolhei benigno estas oferendas em ação de graças pelos vossos filhos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ";"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e fazei que se tornem para eles fonte inesgotável de paz e alegria."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur, tu nous as donné ton Fils pour que dans sa bonté il nous arrache à la mort et à tous les maux ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’en prions : dans ta clémence, accepte le sacrifice que nous t’offrons en action de grâce pour avoir été délivrés des épreuves."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, nimm die Gaben an, die wir in Dankbarkeit für deine Diener am Tag ihrer Silberhochzeit darbringen. Lass sie aus diesem Opfer Segen und Freude empfangen. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf061",
      "label": {
        "la": "PRÆFATIO COMMUNIS IV",
        "es": "PREFACIO COMÚN IV",
        "en-US": "Common Preface Iv",
        "pt-BR": "Prefácio Comum Iv o",
        "it": "PREFAZIO COMUNE IV",
        "fr": "PRÉFACE COMMUNE N°4",
        "de": "PRÄFATION FÜR DIE WOCHENTAGE IV"
      },
      "excerpt": {
        "la": "De laude, dono Dei",
        "es": "Nuestra misma acción de gracias es un don de Dios",
        "en-US": "Praise, the gift of God",
        "pt-BR": "louvor, dom de Deus",
        "it": "La lode, dono di Dio",
        "fr": "La louange, don de Dieu",
        "de": "Gotteslob als Gottesgeschenk"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in Missis, quæ præfatione propria carent, nec sumere debent præfationem de témpore."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Quia, cum nostra laude non égeas,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tuum tamen est donum quod tibi grates rependámus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nam te non augent nostra præcónia,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sed nobis profíciunt ad salútem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, choris angélicis sociáti,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te laudámus in gáudio confiténtes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "Este prefacio se dice en las misas que carecen de prefacio propio y no deben tomar un prefacio del tiempo."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Pues aunque no necesitas nuestra alabanza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ni nuestras bendiciones te enriquecen,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tú inspiras y haces tuya nuestra acción de gracias,"
              }
            ],
            [
              {
                "type": "text",
                "text": "para que nos sirva de salvación,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "unidos a los coros angélicos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos proclamando llenos de alegría:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said in Masses that have no proper Preface, and for which a Preface related to a specific liturgical time is not indicated."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For, although you have no need of our praise,"
              }
            ],
            [
              {
                "type": "text",
                "text": "yet our thanksgiving is itself your gift,"
              }
            ],
            [
              {
                "type": "text",
                "text": "since our praises add nothing to your greatness but profit us for salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, in company with the choirs of Angels,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we praise you, and with joy we proclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas Missas que não têm prefácio próprio e quando não se deve usar um prefácio do tempo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Ainda que nossos louvores não vos sejam necessários,"
              }
            ],
            [
              {
                "type": "text",
                "text": "vós nos concedeis o dom de vos louvar."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nossos hinos de louvor não acrescentam nada à vossa infinita grandeza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "mas nos ajudam alcançar a salvação,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, associados aos coros dos Anjos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nós vos louvamos com alegria,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Si dice nelle Messe che non hanno prefazio proprio e quando non è richiesto il prefazio del Tempo."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "lodarti e ringraziarti sempre per i tuoi benefici,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu non hai bisogno della nostra lode,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ma per un dono del tuo amore ci chiami a renderti grazie;"
              }
            ],
            [
              {
                "type": "text",
                "text": "i nostri inni di benedizione non accrescono la tua grandezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ma ci ottengono la grazia che ci salva,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo nostro Signore."
              }
            ],
            [
              {
                "type": "text",
                "text": "E noi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con tutti gli angeli del cielo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "innalziamo a te il nostro canto,"
              }
            ],
            [
              {
                "type": "text",
                "text": "e proclamiamo insieme la tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les Messes qui n’ont pas de Préface propre et ne doivent pas prendre une Préface du temps."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu n’as pas besoin de notre louange,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et pourtant c’est toi qui nous donnes de répondre à tes bienfaits en te rendant grâce :"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos chants n’ajoutent rien à ce que tu es,"
              }
            ],
            [
              {
                "type": "text",
                "text": "mais nous font progresser vers le salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par le Christ notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "unissant nos voix à celles des anges,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous te louons dans la joie en proclamant :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird in den Messen genommen, die keine eigene Präfation haben und in denen nicht die Präfation von der jeweiligen Zeit im Kirchenjahr zu nehmen ist."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und deine Größe zu preisen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Du bedarfst nicht unseres Lobes, es ist ein Geschenk deiner Gnade, dass wir dir danken. Unser Lobpreis kann deine Größe nicht mehren, doch uns bringt er Segen und Heil durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn rühmen wir jetzt und in Ewigkeit dein Erbarmen und singen mit den Chören der Engel das Lob deiner Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Quid retríbuam Dómino pro ómnibus quæ retríbuit mihi? Cálicem salutáris accípiam, et nomen Dómini invocábo."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "¿Cómo pagaré al Señor todo el bien que me ha hecho? Alzaré la copa de la salvación, invocando el nombre del Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "How can I repay the Lord for all his goodness to me? the chalice of salvation I will raise,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and I will call on the name of the Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Que poderei retribuir ao Senhor Deus por tudo aquilo que ele fez em meu favor?"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Elevo o cálice da minha salvação,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "invocando o nome santo do Senhor."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Comment rendrai-je au Seigneur tout le bien qu’il m’a fait ?"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "J’élèverai la coupe du salut,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "j’invoquerai le nom du Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Wie kann ich dem Herrn all das vergelten, was er mir Gutes getan hat? Ich will den Kelch des Heils erheben und anrufen den Namen des Herrn."
                }
              ]
            ]
          },
          "citation": {
            "la": "Ps 115, 12-13",
            "es": "Ps 115, 12-13",
            "en-US": "Ps 115, 12-13",
            "pt-BR": "Cf. Sl 115, 12-13",
            "fr": "Ps 115, 12-13",
            "de": "Ps 116 (115), 12-13"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, qui ad mensam famíliæ tuæ hos cóniuges"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "(cum líberis et amícis) propítius admisísti, da eis fórtiter et alácriter in mútuam communiónem sic prógredi, ut usque ad cæléste convívium, tuo múnere, coniungántur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que has admitido en tu bondad a la mesa de tu familia a estos esposos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                },
                {
                  "type": "rubric",
                  "text": "N."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "["
                },
                {
                  "type": "text",
                  "text": "en compañía de sus hijos y amigos"
                },
                {
                  "type": "rubric",
                  "text": "]"
                },
                {
                  "type": "text",
                  "text": ", concédeles avanzar con fortaleza y alegría en el amor mutuo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de modo que puedan, por tu gracia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "participar juntos en el banquete del cielo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, who have graciously welcomed this married couple"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "(together with their children and friends)"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to the table of your family,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant that they may continue to grow in strong and eager communion with each other,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that by your gift they may be united,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "until they reach the heavenly banquet."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, em vossa bondade admitistes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "à mesa da vossa família,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "estes esposos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "junto com seus filhos e amigos;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-lhes progredir,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "com firmeza e alegria, na mútua comunhão de modo que possam, por vossa graça,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "chegar unidos ao banquete celeste."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as accueilli à la table de ta famille les époux"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "(avec leurs enfants et leurs amis) ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "donne-leur force et empressement pour progresser encore dans leur amour mutuel,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "jusqu’au jour où, par ta grâce,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ils prendront place ensemble au banquet du ciel."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Himmlischer Vater, du hast die Eheleute N. und N. (mit ihren Kindern und Freunden) an deinem Tisch versammelt. Lass sie froh und zuversichtlich ihren gemeinsamen Weg weitergehen und einst zum himmlischen Gastmahl vereint sein. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
