{
  "id": "ritual.various-needs.div070",
  "kind": "ritual",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "II. PRO CIRCUMSTANTIIS PUBLICIS IN TEMPORE UNIVERSALIS CONTAGII",
    "es": "II. POR LAS NECESIDADES PÚBLICAS EN TIEMPO DE PANDEMIA",
    "en-US": "Ii. for Civil Needs in Time of Pandemic",
    "pt-BR": "Ii. pelas Circunstâncias da Vida Pública em Tempo de Pandemia",
    "it": "PER LA SOCIETÀ CIVILE IN TEMPO DI PANDEMIA",
    "fr": "II. POUR DES CIRCONSTANCES PUBLIQUES En temps de contagion universel",
    "de": "II. FÜR STAAT UND GESELLSCHAFT IN DER ZEIT DER PANDEMIE"
  },
  "color": "green",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Vere languóres nostros ipse tulit et dolóres nostros ipse portávit."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "El Señor soportó nuestros sufrimientos y aguantó nuestros dolores."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Truly the Lord has borne our infirmities,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and he has carried our sorrows."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ele suportou as nossas enfermidades e tomou sobre si as nossas dores."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Egli si è caricato delle nostre sofferenze,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "si è addossato i nostri dolori."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Vraiment, c’étaient nos souffrances que portait le Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos douleurs dont il était chargé."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Der Herr hat unsere Krankheiten getragen und unsere Schmerzen auf sich geladen."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Omnípotens sempitérne Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in omni perículo singuláre præsídium,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui fílios tuos in tribulatióne fide supplicántes exáudis,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nobis propitiáre benígnus, et præsta, quǽsumus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "defúnctis réquiem ætérnam, solámen plorántibus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "salútem infírmis, moriéntibus pacem,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "operántibus pro fratrum sanitáte robur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "spíritum sapiéntiæ illis qui nos in potestáte moderántur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et ánimum ad omnes benévole accedéndi ut cuncti nomen sanctum tuum glorificáre valeámus. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Dios todopoderoso y eterno,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "refugio en toda clase de peligro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a quien nos dirigimos en nuestra angustia;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te pedimos con fe que mires compasivamente nuestra aflicción,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concede descanso eterno a los que han muerto,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "consuela a los que lloran,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sana a los enfermos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "da paz a los moribundos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fuerza a los trabajadores sanitarios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sabiduría a nuestros gobernantes y valentía para llegar a todos con amor glorificando juntos tu santo nombre."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Almighty and eternal God,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "our refuge in every danger,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to whom we turn in our distress;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in faith we pray look with compassion on the afflicted,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant eternal rest to the dead, comfort to mourners,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "healing to the sick, peace to the dying,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "strength to healthcare workers, wisdom to our leaders and the courage to reach out to all in love,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so that together we may give glory to your holy name."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Deus eterno e onipotente, nosso refúgio em todos os perigos, olhai benignamente para as nossas aflições e angústias."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Como filhos, com fé Vos pedimos: concedei o eterno descanso aos que morreram, conforto aos que choram, cura aos doentes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "paz aos moribundos, força aos que trabalham na saúde, sabedoria aos nossos governantes e coragem para chegarmos amorosamente a todos glorificando juntos o vosso Santo Nome."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Dio onnipotente ed eterno,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "provvido rifugio in ogni pericolo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "rivolgi propizio il tuo sguardo verso di noi che con fede ti supplichiamo nella tribolazione e concedi l’eterno riposo ai defunti, sollievo a chi piange,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "salute agli ammalati, pace a chi muore,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "forza agli operatori sanitari,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "spirito di sapienza ai governanti,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e l’animo di accostarsi a tutti con amore per glorificare insieme il tuo santo nome."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e vive e regna con te,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nell’unità dello Spirito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Dieu tout-puissant et éternel,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "secours infaillible en tout danger,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "toi qui exauces tes enfants qui t’invoquent avec foi dans la détresse,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sois-nous favorable et accorde, nous t’en prions,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "le repos éternel aux défunts,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la consolation aux affligés,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la guérison aux malades, la paix aux mourants,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la force à ceux qui travaillent pour la santé de leurs frères,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "l’esprit de sagesse à ceux qui nous gouvernent,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et un cœur bienveillant envers tous,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "afin que nous puissions tous glorifier ton saint nom."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger und ewiger Gott,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "du bist unsere Zuflucht in jeder Gefahr;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "an dich wenden wir uns in unserem Schmerz und bitten dich voll Vertrauen:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Hab Erbarmen mit unserer Not."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Gewähre den Verstorbenen die ewige Ruhe,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tröste die Trauernden,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "heile die Kranken."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Schenke den Sterbenden den Frieden,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "den Pflegenden Stärke,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "den Verantwortungsträgern Weisheit und ermutige alle, sich einander in Liebe zuzuwenden,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "damit wir gemeinsam deinem heiligen Namen die Ehre erweisen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Jesus Christus, deinen Sohn,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "unseren Herrn und Gott,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "der in der Einheit des Heiligen Geistes mit dir lebt und herrscht in alle Ewigkeit."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Súscipe, Dómine, múnera quæ,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in hodiérnis perículis, tibi offérimus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et fac, quǽsumus, ut, omnipoténtia tua,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "in fontem sanitátis pacísque convertántur."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Acepta, Señor, los dones que te ofrecemos en este tiempo de peligro;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y haz que, por tu poder,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "se conviertan para nosotros en fuente de sanación y de paz."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Accept, O Lord, the gifts we offer in this time of peril."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "May they become for us, by your power,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a source of healing and peace."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Recebei, Senhor, os dons que Vos oferecemos em tempo de tribulação;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que eles se tornem para nós, pela força do vosso Espírito,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fonte de consolação e de paz. Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Accetta, Signore, i doni che ti offriamo in questo tempo di pericolo e,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "per la tua potenza, diventino per noi fonte di guarigione e di pace."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Reçois, Seigneur, les offrandes que nous te présentons en ces temps de péril,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et fais, nous t’en prions, que par ta toute-puissance,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "elles se transforment en source de santé et de paix."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Nimm an, o Herr, die Gaben,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "die wir dir in dieser Zeit der Gefahr darbringen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "und mache sie für uns zu einer Quelle der Heilung und des Friedens."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Veníte ad me, omnes, qui laborátis et oneráti estis,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et ego refíciam vos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dicit Dóminus."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Venid a mi todos los que estáis cansados y agobiados, y yo os aliviaré, dice el Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Come to me, all who labour and are burdened,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and I will refresh you, says the Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Vinde a mim, todos vós que andais cansados e oprimidos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e eu vos aliviarei, diz o Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Venite a me, voi tutti che siete stanchi e oppressi,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e io vi darò ristoro, dice il Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Venez à moi, vous tous qui peinez sous le poids du fardeau,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et moi, je vous procurerai le repos, dit le Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "So spricht der Herr:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Kommt alle zu mir, die ihr mühselig und beladen seid!"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Ich will euch erquicken."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, a quo recépimus vitæ ætérnæ medicínam,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concéde, quǽsumus, ut,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "per hoc sacraméntum de cæléstis remédii plenitúdine gloriémur."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh Dios, de quien hemos recibido la medicina de la vida eterna,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos que, por medio de este sacramento,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "podamos gloriarnos plenamente de los auxilios del cielo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, from whose hand we have received the medicine of eternal life,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant that through this sacrament we may glory in the fullness of heavenly healing."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor nosso Deus, que nos saciastes com o remédio de vida eterna,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-nos, pela participação neste sacramento, a plenitude da alegria na glória celeste. Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Abbiamo ricevuto, o Dio, dalla tua mano il farmaco della vita eterna,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fa' che, per questo sacramento,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ci gloriamo pienamente della guarigione celeste."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Dieu, de qui nous recevons le remède de la vie éternelle,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous, nous t’en prions,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’à travers ce sacrement,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous réjouissions de la plénitude du remède céleste."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gott, aus deiner Hand haben wir die Medizin des ewigen Lebens empfangen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Lass uns durch dieses Sakrament die Fülle der himmlischen Heilung erlangen."
                }
              ],
              [
                {
                  "type": "text",
