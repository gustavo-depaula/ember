{
  "id": "common.doctors-of-the-church.doct2",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE DOCTORUM ECCLESIÆ 2",
    "es": "Común de Doctores de la Iglesia 2",
    "en-US": "Common of Doctors of the Church 2",
    "pt-BR": "Comum dos doutores da Igreja 2",
    "it": "COMUNE DEI DOTTORI DELLA CHIESA 2",
    "fr": "COMMUN DES DOCTEURS DE L’ÉGLISE 2",
    "de": "COMMUNE-TEXTE FÜR KIRCHENLEHRER 2"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Sapiéntiam Sanctórum narrent pópuli, et laudes eórum núntiet Ecclésia; nómina autem eórum vivent in sǽculum sǽculi"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Los pueblos hablarán de su sabiduría y la asamblea proclamará su alabanza, y su nombre vive por los siglos de los siglos"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Let the peoples recount the wisdom of the Saints,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and let the Church proclaim their praise."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Their names will live on and on"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Proclamem os povos a sabedoria dos santos e a Igreja celebre os seus louvores;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "seus nomes permanecerão pelos séculos dos séculos"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "I popoli parlino della sapienza dei santi, e l’assemblea ne celebri la lode;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "il loro nome vivrà per sempre"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Les peuples raconteront la sagesse des saints,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "l’Église proclamera leurs louanges,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et leur nom reste vivant pour toutes les générations"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Die Menschen erfahren von der Weisheit der Heiligen, die Kirche lobt sie. Sie werden leben in Ewigkeit"
                },
                {
                  "type": "rubric",
                  "text": "Österl. Zeit"
                },
                {
                  "type": "text",
                  "text": "Halleluja"
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Sir 44, 15",
            "es": "Cf. Eclo 44, 15",
            "en-US": "Cf. Sir 44, 15",
            "pt-BR": "Cf. Eclo 44, 15",
            "it": "Cf. Sir 44, 15.14",
            "fr": "Cf. Sir 44, 15",
            "de": "Vgl. Sir 44, 15"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Dómine Deus, qui beátum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "cælésti doctrína imbúere dignátus es, da nobis, ipsíus intervéntu, eándem doctrínam fidéliter custodíre et móribus profitéri. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que te has dignado instruir en la sabiduría celestial a san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "guardar fielmente su doctrina y manifestarla en nuestras obras."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Lord God, who graciously imbued blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "with heavenly doctrine,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant, through his intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that we may keep that same teaching faithfully and express it in what we do."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor nosso Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que vos dignastes impregnar São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "de ensinamentos celestes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-nos, por sua intercessão,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "guardar fielmente os mesmos ensinamentos e professá-los na vida."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Signore Dio, che hai arricchito della tua sapienza san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "concedi a noi, con il suo aiuto, di custodirla fedelmente e di professarla con la nostra vita. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as donné à saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "une profonde connaissance de la doctrine venue de toi ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous, par son intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de garder fidèlement ce qu’il a enseigné et d’en témoigner par notre vie."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast dem heiligen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Einsicht und Weisheit geschenkt und ihn zum Lehrer deiner Kirche bestellt. Gib uns die Kraft, an seinem Wort festzuhalten und durch unser Tun davon Zeugnis zu geben."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Illa nos, quǽsumus, Dómine, divína tractántes, Spíritus Sanctus fídei luce perfúndat, qua beátum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ad glóriæ tuæ propagatiónem iúgiter collustrávit. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Al celebrar estos divinos misterios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te pedimos, Señor, que el Espíritu Santo nos ilumine con aquella luz de la fe que iluminó a san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "para propagar siempre tu gloria."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "As we celebrate the divine mysteries,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "O Lord, we pray,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "may the Holy Spirit fill us with that light of faith by which he constantly enlightened blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "for the spreading of your glory."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ao celebrarmos os divinos mistérios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "o Espírito Santo infunda em nós a luz da fé que iluminou São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "para difundir a vossa glória."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Signore, lo Spirito Santo infonda in noi, che celebriamo i divini misteri,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la stessa luce di fede che illuminò sempre san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "per la diffusione della tua gloria. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Tandis que nous célébrons tes mystères, Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que ton Esprit Saint répande sur nous la lumière de la foi,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dont il n’a cessé d’éclairer saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "pour que rayonne ta gloire."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, sende uns in dieser Opferfeier den Heiligen Geist, der den Kirchenlehrer"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "befähigt hat, deine Herrlichkeit zu verkünden. Lass auch uns im Licht dieses Geistes den Glauben tiefer erfassen."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Nos prædicámus Christum crucifíxum, Christum, Dei virtútem et Dei sapiéntiam"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Nosotros predicamos a Cristo crucificado, fuerza de Dios y sabiduría de Dios"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "We proclaim Christ crucified;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Christ, the power of God and the wisdom of God"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Nós anunciamos Cristo crucificado,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "poder e sabedoria de Deus"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Noi annunciamo Cristo crocifisso, potenza di Dio e sapienza di Dio"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Nous proclamons le Christ crucifié,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "le Christ, puissance de Dieu et sagesse de Dieu."
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Wir verkündigen Christus als Gekreuzigten; Christus, Gottes Kraft und Gottes Weisheit"
                },
                {
                  "type": "rubric",
                  "text": "Österl. Zeit"
                },
                {
                  "type": "text",
                  "text": "Halleluja"
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Cælésti alimónia refécti, súpplices te, Dómine, deprecámur, ut, beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "mónitis obsequéntes, de accéptis donis semper in gratiárum actióne maneámus. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Saciados con el alimento celestial,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te suplicamos humildemente, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "siguiendo con fidelidad las enseñanzas de san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos mantengamos en continua acción de gracias por los dones recibidos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Refreshed by heavenly food,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "we humbly implore you, O Lord,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "attentive to the teaching of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "we may abide at all times in thanksgiving for the gifts we have received."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Refeitos com o pão do céu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nós vos pedimos humildemente, Senhor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, obedecendo aos ensinamentos de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "possamos permanecer sempre em ação de graças pelos dons que recebemos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Nutriti dal pane del cielo, ti supplichiamo, o Signore: concedi a noi di seguire gli insegnamenti di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e di vivere in perenne rendimento di grazie per i doni ricevuti. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Déjà réconfortés par le pain du ciel,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’adressons, Seigneur, cette humble prière :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’en suivant les leçons de saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous demeurions toujours dans l’action de grâce pour les dons que nous avons reçus."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast uns mit dem Brot des Lebens gespeist. Gib, dass wir den Mahnungen des heiligen"
