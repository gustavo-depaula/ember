{
  "id": "common.pastors.past3",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE PASTORUM II. PRO EPISCOPO 1",
    "es": "COMÚN DE PASTORES II. Para un obispo 1",
    "en-US": "Common of Pastors Ii. For a Bishop 1",
    "pt-BR": "Comum dos Pastores Ii. para Um bispo 1",
    "it": "COMUNE DEI PASTORI II. Per un vescovo 1.",
    "fr": "COMMUN DES PASTEURS II. Pour un évêque 1",
    "de": "COMMUNE-TEXTE FÜR HIRTEN DER KIRCHE II. Für einen Bischof 1"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Iste est fidélis et prudens dispensátor, quem constítuit Dóminus super famíliam suam, ut det illis in témpore trítici mensúram"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Este es el administrador fiel y prudente a quien el Señor pondrá al frente de su servidumbre para que reparta la ración de alimento a sus horas"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "This is the steward, faithful and prudent, whom the Lord set over his household to give them their allowance of food at the proper time"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Servo fiel e prudente,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a quem o Senhor confiou a sua família para dar-lhes na hora certa a sua porção de trigo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ecco il servo fedele e prudente, che il Signore ha messo a capo della sua famiglia, per nutrirla al tempo opportuno"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Voici l’intendant fidèle et avisé que le maître a établi sur sa maison,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour donner à chacun, en temps voulu, sa part de blé"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Lc 12, 42",
            "es": "Cf. Lc 12, 42",
            "en-US": "Lk 12: 42",
            "pt-BR": "Cf. Lc 12, 42",
            "it": "Cf. Lc 12, 42",
            "fr": "Cf. Lc 12, 42"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Omnípotens ætérne Deus, qui beátum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "epíscopum Ecclésiæ tuæ sanctæ dedísti, præsta, ut, quod ille divíno afflátus spíritu dócuit, nostris iúgiter stabiliátur in córdibus, et, quem patrónum, te donánte, ampléctimur, eum apud tuam misericórdiam defensórem habeámus. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Dios todopoderoso y eterno,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que diste a tu santa Iglesia a san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", como obispo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos que arraigue siempre en nuestros corazones lo que él enseñó inspirado por el divino Espíritu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y tengamos como defensor ante tu misericordia a quien consideramos, por tu gracia, como protector."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Almighty and eternal God, who gave your holy Church blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "as Bishop, grant that what he taught when moved by the divine Spirit may always stay firm in our hearts; and as by your gift we embrace him as our patron, may we also have him as our defender to entreat your mercy."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Deus onipotente e eterno,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que destes à vossa Igreja São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "como bispo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "gravai para sempre em nossos corações o que ele ensinou inspirado pelo sopro do divino Espírito;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "seja nosso defensor junto à vossa misericórdia aquele que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por vossa graça, acolhemos como protetor."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Dio onnipotente ed eterno, che hai dato alla tua Chiesa il santo vescovo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", donaci di tenere sempre fissi nei nostri cuori gli insegnamenti che, illuminato dallo Spirito, egli ha trasmesso, e mentre lo accogliamo da te come nostro patrono, donaci di averlo come difensore presso la tua misericordia. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Dieu éternel et tout-puissant,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as donné saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "comme évêque à ta sainte Église ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fais que s’enracine à jamais en nos cœurs ce qu’il a enseigné sous ton inspiration divine ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et puisque, par ta grâce,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous l’avons reçu comme protecteur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’il soit aussi notre défenseur auprès de ta miséricorde."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Hóstias, quǽsumus, Dómine, quas in festivitáte beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "sacris altáribus exhibémus, propítius réspice, ut,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nobis indulgéntiam largiéndo, tuo nómini dent honórem. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Mira con bondad, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "las ofrendas que presentamos en este santo altar en la fiesta de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que glorifiquen tu nombre y nos obtengan el perdón."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Look with favor, O Lord, we pray, on the offerings we set upon this sacred altar on the feast day of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", that, bestowing on us your pardon, our oblations may give honor to your name."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, nós vos pedimos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "olhai benigno as oferendas que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "na memória de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", apresentamos no sagrado altar,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, obtendo-nos o perdão,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "deem honra ao vosso nome."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Guarda con bontà, o Signore, il sacrificio che presentiamo al tuo santo altare nella memoria di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", perché a noi ottenga il perdono e renda onore al tuo nome. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "En cette fête de saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Seigneur, nous t’en prions,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "regarde avec bonté les offrandes que nous déposons sur l’autel qui t’est consacré ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en nous procurant ton pardon,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’elles servent à la gloire de ton nom."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, schau gnädig auf die Gaben, die wir am Gedenktag des heiligen Bischofs"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "auf deinen Altar legen. Das heilige Opfer verherrliche deinen Namen und erwirke uns Vergebung der Sünden."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf056",
      "label": {
        "la": "PRÆFATIO DE SANCTIS PASTORIBUS",
        "es": "PREFACIO DE LOS SANTOS PASTORES",
        "en-US": "Preface of Holy Pastors",
        "pt-BR": "Prefácio dos Santos Pastores a",
        "it": "PREFAZIO DEI SANTI PASTORI I",
        "fr": "PRÉFACE DES SAINTS PASTEURS",
        "de": "PRÄFATION VON DEN HIRTEN DER KIRCHE"
      },
      "excerpt": {
        "la": "De præsentia sanctorum Pastorum in Ecclésia",
        "es": "La presencia de los santos pastores en la Iglesia",
        "en-US": "The presence of holy Pastors in the Church",
        "pt-BR": "presença dos Santos Pastores na Igreja",
        "it": "La presenza dei santi Pastori nella Chiesa",
        "fr": "La présence des saints pasteurs dans l’Église",
        "de": "Das Wirken der heiligen Hirten für uns"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Ss. Pastorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Quia sic tríbuis Ecclésiam tuam sancti"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "festivitáte gaudére,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ut eam exémplo piæ conversatiónis corróbores,"
              }
            ],
            [
              {
                "type": "text",
                "text": "verbo prædicatiónis erúdias,"
              }
            ],
            [
              {
                "type": "text",
                "text": "gratáque tibi supplicatióne tueáris."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Angelórum atque Sanctórum turba,"
              }
            ],
            [
              {
                "type": "text",
                "text": "hymnum laudis tibi cánimus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de los santos Pastores. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque nos concedes la alegría de celebrar hoy la fiesta de san"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              }
            ],
            [
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "fortaleciendo a tu Iglesia con el ejemplo de su vida santa,"
              }
            ],
            [
              {
                "type": "text",
                "text": "instruyéndola con su palabra y protegiéndola con su intercesión."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los ángeles y con la multitud de los santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te cantamos el himno de alabanza diciendo sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Pastors. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "For, as on the festival of Saint"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "you bid your Church rejoice,"
              }
            ],
            [
              {
                "type": "text",
                "text": "so, too, you strengthen her by the example of his holy life,"
              }
            ],
            [
              {
                "type": "text",
                "text": "teach her by his words of preaching,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and keep her safe in answer to his prayers."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with the company of Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we sing the hymn of your praise,"
              }
            ],
            [
              {
                "type": "text",
                "text": "as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas dos Santos Pastores; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vós nos concedeis a alegria de celebrar a memória"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "festa, solenidade"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "de São"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "e fortaleceis a vossa Igreja com o exemplo de sua vida,"
              }
            ],
            [
              {
                "type": "text",
                "text": "o ensinamento de sua pregação e o auxílio de suas preces."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com a multidão dos Anjos e dos Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "entoamos o hino da vossa glória,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Il seguente prefazio si dice nelle solennità e nelle feste dei santi pastori. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta, nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "rendere grazie sempre e in ogni luogo a te, Signore, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo Signore nostro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu doni alla tua Chiesa la gioia di celebrare la festa [memoria] di san N.:"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi esempi la rafforzi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi insegnamenti l’ammaestri,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la sua intercessione la proteggi."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo dono della tua benevolenza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la moltitudine degli angeli e dei santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantiamo senza fine l’inno della tua lode:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saints Pasteurs. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par le Christ, notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu donnes à ton Église de se réjouir en la fête de saint"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "des saints"
              },
              {
                "type": "rubric",
                "text": ") N."
              },
              {
                "type": "text",
                "text": ":"
              }
            ],
            [
              {
                "type": "text",
                "text": "par l’exemple qu’il a"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "qu’ils ont"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "donné, tu nous encourages,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par son"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "enseignement, tu nous éclaires,"
              }
            ],
            [
              {
                "type": "text",
                "text": "à sa"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "prière, tu veilles sur nous."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "avec la multitude des anges et des saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous chantons l’hymne de ta gloire et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Hirten der Kirche genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, Dir, Vater im Himmel, zu danken und am Fest des heiligen"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "deine Größe zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Sein Leben aus dem Glauben ist uns ein Vorbild, die Botschaft seiner Predigt belehrt uns, seine Fürbitte erwirkt uns Schutz und Hilfe durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen wir dich in deiner Kirche und vereinen uns mit den Engeln und Heiligen zum Hochgesang von deiner göttlichen Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Beátus ille servus, quem, cum vénerit dóminus eius, et pulsáverit iánuam,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "invénerit vigilántem"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Bienaventurado aquel criado, a quien el Señor, cuando venga y llame a la puerta, lo encuentre en vela"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Blessed is that servant, whom his lord finds awake when he comes and knocks at the gate"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Feliz o servo que o Senhor, ao chegar e bater à porta, encontrar acordado"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Beato quel servo che il padrone troverà ancora sveglio, quando verrà e busserà alla porta"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Heureux ce serviteur que le maître,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "quand il arrivera et frappera à la porte,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "trouvera en train de veiller"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Lc 12, 36-37",
            "es": "Cf. Lc 12, 36-37",
            "en-US": "Lk 12: 36-37",
            "pt-BR": "Cf. Lc 12, 36-37",
            "it": "Cf. Lc 12, 36-37",
            "fr": "Cf. Lc 12, 36-37"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Refécti sacris mystériis, Dómine, humíliter deprecámur, ut, beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "exémplo, studeámus confitéri quod crédidit, et ópere exercére quod dócuit. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Alimentados por estos sacramentos te pedimos humildemente, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a ejemplo de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos esforcemos en proclamar lo que él creyó y en poner en práctica lo que enseñó."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Renewed by the sacred mysteries, we humbly pray, O Lord, that, following the example of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", we may strive to profess what he believed and to practice what he taught."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, refeitos pelos sagrados mistérios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "humildemente vos pedimos que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a exemplo de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos empenhemos em professar o que ele acreditou e realizar por obras o que ensinou."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Saziati dai santi misteri, ti preghiamo umilmente, o Signore: fa' che sull’esempio di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "professiamo la verità in cui egli ha creduto, e testimoniamo nelle opere l’insegnamento che ci ha trasmesso. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Déjà rénovés par ces mystères très saints,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous te supplions humblement, Seigneur :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "puissions-nous, en prenant exemple sur saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "professer ce qu’il a cru et pratiquer ce qu’il a enseigné."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast uns am Fest des heiligen Bischofs"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "mit dem Leib und Blut Christi genährt. Hilf uns,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nach seinem Beispiel den Glauben, den er gelehrt hat, zu bekennen und durch gute Werke zu bezeugen. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
