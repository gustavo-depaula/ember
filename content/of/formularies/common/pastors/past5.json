{
  "id": "common.pastors.past5",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE PASTORUM III. PRO PASTORIBUS A. Pro pluribus pastoribus",
    "es": "COMÚN DE PASTORES III. PASTORES A. Para varios pastores",
    "en-US": "Common of Pastors Iii. For Pastors a. For Several Pastors",
    "pt-BR": "Comum dos Pastores Iii. Para Pastores a. Para vários pastores",
    "it": "COMUNE DEI PASTORI III. Per i pastori A. Per più pastori",
    "fr": "COMMUN DES PASTEURS III. POUR DES PASTEURS A. Pour plusieurs pasteurs",
    "de": "COMMUNE-TEXTE FÜR HIRTEN DER KIRCHE III. Für Seelsorger A. Für mehrere Seelsorger"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Sacerdótes Dei, benedícite Dóminum; sancti et húmiles corde, laudáte Deum"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Sacerdotes del Señor, bendecid al Señor, santos y humildes de corazón,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "bendecid al Señor"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Priests of God, bless the Lord; praise the Lord, all who are holy and humble of heart"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Sacerdotes de Deus, bendizei o Senhor;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "santos e humildes, louvai o Senhor"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Benedite, sacerdoti del Signore, il Signore; lodate Dio, santi e umili di cuore"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Prêtres du Seigneur, bénissez le Seigneur !"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Saints et humbles de cœur, louez Dieu"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Preist den Herrn, ihr Priester; preist den Herrn, ihr Frommen und Demütigen."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Dan 3, 84",
            "es": "Cf. Dan 3, 84",
            "en-US": "Dn 3: 84, 87",
            "pt-BR": "Cf. Dn 3, 84",
            "it": "Cf. Dn 3, 84.87",
            "fr": "Cf. Dan 3, 84",
            "de": "Dan 3, 84"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, qui beátos epíscopos"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ad pascéndum pópulum tuum spíritu veritátis et dilectiónis implevísti, præsta, ut, quorum festivitátem venerándo ágimus, eórum imitatióne proficiámus, et intercessióne sublevémur. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que infundiste en los santos"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "["
                },
                {
                  "type": "text",
                  "text": "obispos"
                },
                {
                  "type": "rubric",
                  "text": "] N."
                },
                {
                  "type": "text",
                  "text": "y"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "el espíritu de la verdad y del amor para apacentar a tu pueblo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concede, a cuantos celebramos con veneración su fiesta,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "imitarles cada día más y recibir la ayuda de su intercesión."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, who to pasture your people filled (the Bishops) blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "with a spirit of truth and of love, grant that, as we celebrate their feast day with honor, we may benefit by imitating them and be given relief through their intercession."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, que infundistes nos Santos bispos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "o espírito de verdade e amor para apascentarem o vosso povo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ao venerarmos sua memória,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-nos imitar seu exemplo e receber o auxílio de sua intercessão."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, che hai plasmato con il tuo Spirito di verità e di amore i santi"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "["
                },
                {
                  "type": "text",
                  "text": "vescovi"
                },
                {
                  "type": "rubric",
                  "text": "] N."
                },
                {
                  "type": "text",
                  "text": "e"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "perché fossero pastori del tuo popolo, concedi a noi, che ne celebriamo la memoria, di imitare il loro esempio e di trarre sostegno dalla loro intercessione. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour que les saints évêques"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "soient les pasteurs de ton peuple,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu les as comblés d’un esprit d’amour et de vérité ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "puisque nous célébrons leur fête,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous de progresser en les imitant,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et de trouver dans leur intercession un soutien inébranlable."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gütiger Gott, du hast die heiligen (Bischöfe)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "mit dem Geist der Wahrheit und der Liebe erfüllt und sie befähigt, dein Volk zu leiten. Höre auf ihre Fürsprache, lass uns nach ihrem Vorbild leben und stets deine Hilfe erfahren. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Laudis tibi, Dómine, hóstias offérimus in tuórum commemoratióne Sanctórum,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "quibus nos et præséntibus éxui malis confídimus et futúris. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te ofrecemos, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "este sacrificio de alabanza en la conmemoración de tus santos;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por ellos confiamos vernos libres de los males presentes y futuros."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "We offer you a sacrifice of praise in commemoration of your Saints, O Lord, by which we trust to be delivered from evils both present and to come."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, na comemoração dos vossos santos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nós vos oferecemos este sacrifício de louvor;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por ele confiamos ser libertos dos males presentes e futuros."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ti offriamo, o Signore, il sacrificio di lode nella memoria dei tuoi santi:"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "donaci per loro intercessione di essere liberati dai mali presenti e futuri."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "En célébrant, Seigneur, la mémoire des saints,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’offrons ce sacrifice de louange ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "par lui, délivre-nous du mal aujourd’hui et demain,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "comme nous en avons l’espérance."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, nimm die Gaben deines Volkes an, die es dir am Gedenktag der heiligen (Bischöfe)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "darbringt. Nimm sie entgegen und schenke uns durch dieses Opfer das ewige Heil. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf056",
      "label": {
        "la": "PRÆFATIO DE SANCTIS PASTORIBUS",
        "es": "PREFACIO DE LOS SANTOS PASTORES",
        "en-US": "Preface of Holy Pastors",
        "pt-BR": "Prefácio dos Santos Pastores a",
        "it": "PREFAZIO DEI SANTI PASTORI I",
        "fr": "PRÉFACE DES SAINTS PASTEURS",
        "de": "PRÄFATION VON DEN HIRTEN DER KIRCHE"
      },
      "excerpt": {
        "la": "De præsentia sanctorum Pastorum in Ecclésia",
        "es": "La presencia de los santos pastores en la Iglesia",
        "en-US": "The presence of holy Pastors in the Church",
        "pt-BR": "presença dos Santos Pastores na Igreja",
        "it": "La presenza dei santi Pastori nella Chiesa",
        "fr": "La présence des saints pasteurs dans l’Église",
        "de": "Das Wirken der heiligen Hirten für uns"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Ss. Pastorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Quia sic tríbuis Ecclésiam tuam sancti"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "festivitáte gaudére,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ut eam exémplo piæ conversatiónis corróbores,"
              }
            ],
            [
              {
                "type": "text",
                "text": "verbo prædicatiónis erúdias,"
              }
            ],
            [
              {
                "type": "text",
                "text": "gratáque tibi supplicatióne tueáris."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Angelórum atque Sanctórum turba,"
              }
            ],
            [
              {
                "type": "text",
                "text": "hymnum laudis tibi cánimus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de los santos Pastores. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque nos concedes la alegría de celebrar hoy la fiesta de san"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              }
            ],
            [
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "fortaleciendo a tu Iglesia con el ejemplo de su vida santa,"
              }
            ],
            [
              {
                "type": "text",
                "text": "instruyéndola con su palabra y protegiéndola con su intercesión."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los ángeles y con la multitud de los santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te cantamos el himno de alabanza diciendo sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Pastors. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "For, as on the festival of Saint"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "you bid your Church rejoice,"
              }
            ],
            [
              {
                "type": "text",
                "text": "so, too, you strengthen her by the example of his holy life,"
              }
            ],
            [
              {
                "type": "text",
                "text": "teach her by his words of preaching,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and keep her safe in answer to his prayers."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with the company of Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we sing the hymn of your praise,"
              }
            ],
            [
              {
                "type": "text",
                "text": "as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas dos Santos Pastores; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vós nos concedeis a alegria de celebrar a memória"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "festa, solenidade"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "de São"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "e fortaleceis a vossa Igreja com o exemplo de sua vida,"
              }
            ],
            [
              {
                "type": "text",
                "text": "o ensinamento de sua pregação e o auxílio de suas preces."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com a multidão dos Anjos e dos Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "entoamos o hino da vossa glória,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Il seguente prefazio si dice nelle solennità e nelle feste dei santi pastori. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta, nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "rendere grazie sempre e in ogni luogo a te, Signore, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo Signore nostro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu doni alla tua Chiesa la gioia di celebrare la festa [memoria] di san N.:"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi esempi la rafforzi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi insegnamenti l’ammaestri,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la sua intercessione la proteggi."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo dono della tua benevolenza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la moltitudine degli angeli e dei santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantiamo senza fine l’inno della tua lode:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saints Pasteurs. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par le Christ, notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu donnes à ton Église de se réjouir en la fête de saint"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "des saints"
              },
              {
                "type": "rubric",
                "text": ") N."
              },
              {
                "type": "text",
                "text": ":"
              }
            ],
            [
              {
                "type": "text",
                "text": "par l’exemple qu’il a"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "qu’ils ont"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "donné, tu nous encourages,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par son"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "enseignement, tu nous éclaires,"
              }
            ],
            [
              {
                "type": "text",
                "text": "à sa"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "prière, tu veilles sur nous."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "avec la multitude des anges et des saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous chantons l’hymne de ta gloire et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Hirten der Kirche genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, Dir, Vater im Himmel, zu danken und am Fest des heiligen"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "deine Größe zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Sein Leben aus dem Glauben ist uns ein Vorbild, die Botschaft seiner Predigt belehrt uns, seine Fürbitte erwirkt uns Schutz und Hilfe durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen wir dich in deiner Kirche und vereinen uns mit den Engeln und Heiligen zum Hochgesang von deiner göttlichen Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Fílius hóminis non venit ministrári, sed ministráre, et dare ánimam suam redemptiónem pro multis"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "El Hijo del Hombre ha venido a dar su vida en rescate por muchos"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The Son of Man did not come to be served but to serve, and to give his life as a ransom for many"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "O Filho do homem não veio para ser servido,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "mas para servir e dar a sua vida como resgate em favor de muitos"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Il Figlio dell’uomo non è venuto per essere servito, ma per servire e dare la propria vita in riscatto per molti"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Le Fils de l’homme n’est pas venu pour être servi, mais pour servir,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et donner sa vie en rançon pour la multitude"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Der Menschensohn ist nicht gekommen, um sich bedienen zu lassen, sondern um zu dienen und sein Leben hinzugeben als Lösegeld für viele."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Súmpsimus, Dómine, sanctórum tuórum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "memóriam celebrántes, sacraménta cæléstia; præsta,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "quǽsumus, ut, quod temporáliter gérimus, ætérnis gáudiis consequámur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Hemos recibido, Señor, los sacramentos del cielo celebrando la memoria de tus santos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ";"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos gozar en la eternidad de lo que hemos celebrado en este mundo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "We have received this heavenly Sacrament, O Lord, as we commemorate your Saints"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "; grant, we pray, that what we celebrate in time we may attain with eternal joy."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, pelos celestes sacramentos que recebemos na comemoração dos vossos Santos"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nós vos pedimos que esta celebração na terra nos alcance as alegrias do céu."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ci siamo nutriti, o Signore, dei tuoi sacramenti celebrando la memoria dei santi"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ": fa' che gustiamo nella gioia eterna il mistero che ci conforta nel pellegrinaggio terreno. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Nous avons reçu, Seigneur, le sacrement du ciel en faisant mémoire des saints"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ";"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’en prions :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "donne-nous de posséder dans la joie éternelle ce que nous célébrons dans le temps de cette vie."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, am Gedenktag der heiligen (Bischöfe)"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "haben wir das Sakrament des Altares empfangen. Gib, dass wir im Himmel unverhüllt schauen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "was wir auf Erden unter heiligen Zeichen empfangen haben. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
