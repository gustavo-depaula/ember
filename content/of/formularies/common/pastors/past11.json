{
  "id": "common.pastors.past11",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE PASTORUM V. PRO MISSIONARIIS 2",
    "es": "COMÚN DE PASTORES V. Para misioneros 2",
    "en-US": "Common of Pastors V. For Missionaries 2",
    "pt-BR": "Comum dos Pastores V. para Missionários 2",
    "it": "COMUNE DEI PASTORI V. Per i missionari 2.",
    "fr": "COMMUN DES PASTEURS V. POUR DES MISSIONNAIRES 2",
    "de": "COMMUNE-TEXTE FÜR HIRTEN DER KIRCHE V. Für Glaubensboten 2"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Quam pulchri super montes pedes annuntiántis et prædicántis pacem,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "annuntiántis bonum, prædicántis salútem"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Qué hermosos son sobre los montes los pies del mensajero que proclama la paz,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que anuncia la buena noticia, que pregona la justicia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "How beautiful upon the mountains are the feet of him who brings glad tidings of peace, bearing good news, announcing salvation"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Como são belos sobre os montes os pés do mensageiro que anuncia a paz,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que anuncia a felicidade e prega a salvação"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia!"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Come sono belli sui monti i piedi del messaggero che annuncia la pace, del messaggero di buone notizie che annuncia la salvezza"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Comme ils sont beaux sur les montagnes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "les pas du messager,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "celui qui annonce la paix,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui porte la bonne nouvelle,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui annonce le salut"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Willkommen ist der Freudenbote, der den Frieden ankündigt, der gute Nachricht bringt und die Rettung verheißt."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, qui Ecclésiam tuam beáti"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "religiónis zelo et apostólicis curis amplificásti, eius intercessióne concéde, ut fídei et sanctitátis nova semper increménta suscípiat. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que extendiste tu Iglesia mediante el celo por la fe y los trabajos apostólicos de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "crecer siempre en la fe y en la santidad."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, who gave increase to your Church through the zeal for religion and apostolic labors of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", grant, through his intercession, that she may always receive new growth in faith and in holiness."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, que fizestes crescer vossa Igreja pelo zelo ardente e dedicação apostólica de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-lhe, por sua intercessão,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "progredir sempre mais na fé e na santidade."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, che hai dilatato i confini della Chiesa con lo zelo ardente e la dedizione apostolica di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", per sua intercessione concedi al tuo popolo santo di raccogliere frutti sempre nuovi di fede e di grazia. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as voulu que l'œuvre apostolique de saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et son zèle à te servir fassent grandir ton Église ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "par son intercession, qu’elle obtienne une foi et une sainteté toujours en progrès."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gott, unser Heil, durch die Predigt und das apostolische Wirken des heiligen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "hast du deiner Kirche viele Menschen zugeführt."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Gib uns auf seine Fürsprache neue Kraft und mehre den Glauben und die Heiligkeit in deinem Volk. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Propitiáre, Dómine, supplicatiónibus nostris, et nos ab omni culpa líberos esse concéde, ut, purificánte grátia tua, iísdem quibus famulámur mystériis emundémur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Escucha con bondad nuestras súplicas, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y líbranos de todas nuestras culpas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, limpios por tu gracia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos transforme el misterio que ahora celebramos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Look with favor on our supplications, O Lord, and free us from every fault, so that through the purifying action of your grace we may be cleansed by the very mysteries through which we render you service."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor, atendei benigno as nossas súplicas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e livrai-nos de toda a culpa,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, por vossa graça purificadora,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sejamos perdoados pelos mistérios que celebramos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ascolta con bontà, o Signore, le nostre preghiere e rendici liberi da ogni colpa, perché dai misteri che celebriamo, per l’azione purificatrice della tua grazia, otteniamo la pienezza del perdono. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Sois favorable, Seigneur, à nos supplications et accorde-nous d’être libérés de toute faute :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "puissions-nous, par un effet de ta grâce, être purifiés par ces mystères que nous célébrons."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Barmherziger Gott, erhöre unser Gebet: Befreie uns von aller Schuld und läutere uns durch das Geheimnis des Glaubens, das wir jetzt im Auftrag deines Sohnes feiern. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf056",
      "label": {
        "la": "PRÆFATIO DE SANCTIS PASTORIBUS",
        "es": "PREFACIO DE LOS SANTOS PASTORES",
        "en-US": "Preface of Holy Pastors",
        "pt-BR": "Prefácio dos Santos Pastores a",
        "it": "PREFAZIO DEI SANTI PASTORI I",
        "fr": "PRÉFACE DES SAINTS PASTEURS",
        "de": "PRÄFATION VON DEN HIRTEN DER KIRCHE"
      },
      "excerpt": {
        "la": "De præsentia sanctorum Pastorum in Ecclésia",
        "es": "La presencia de los santos pastores en la Iglesia",
        "en-US": "The presence of holy Pastors in the Church",
        "pt-BR": "presença dos Santos Pastores na Igreja",
        "it": "La presenza dei santi Pastori nella Chiesa",
        "fr": "La présence des saints pasteurs dans l’Église",
        "de": "Das Wirken der heiligen Hirten für uns"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Ss. Pastorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Quia sic tríbuis Ecclésiam tuam sancti"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "festivitáte gaudére,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ut eam exémplo piæ conversatiónis corróbores,"
              }
            ],
            [
              {
                "type": "text",
                "text": "verbo prædicatiónis erúdias,"
              }
            ],
            [
              {
                "type": "text",
                "text": "gratáque tibi supplicatióne tueáris."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Angelórum atque Sanctórum turba,"
              }
            ],
            [
              {
                "type": "text",
                "text": "hymnum laudis tibi cánimus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de los santos Pastores. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque nos concedes la alegría de celebrar hoy la fiesta de san"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              }
            ],
            [
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "fortaleciendo a tu Iglesia con el ejemplo de su vida santa,"
              }
            ],
            [
              {
                "type": "text",
                "text": "instruyéndola con su palabra y protegiéndola con su intercesión."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los ángeles y con la multitud de los santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te cantamos el himno de alabanza diciendo sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Pastors. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "For, as on the festival of Saint"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "you bid your Church rejoice,"
              }
            ],
            [
              {
                "type": "text",
                "text": "so, too, you strengthen her by the example of his holy life,"
              }
            ],
            [
              {
                "type": "text",
                "text": "teach her by his words of preaching,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and keep her safe in answer to his prayers."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with the company of Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we sing the hymn of your praise,"
              }
            ],
            [
              {
                "type": "text",
                "text": "as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas dos Santos Pastores; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vós nos concedeis a alegria de celebrar a memória"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "festa, solenidade"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "de São"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "e fortaleceis a vossa Igreja com o exemplo de sua vida,"
              }
            ],
            [
              {
                "type": "text",
                "text": "o ensinamento de sua pregação e o auxílio de suas preces."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com a multidão dos Anjos e dos Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "entoamos o hino da vossa glória,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Il seguente prefazio si dice nelle solennità e nelle feste dei santi pastori. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta, nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "rendere grazie sempre e in ogni luogo a te, Signore, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo Signore nostro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu doni alla tua Chiesa la gioia di celebrare la festa [memoria] di san N.:"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi esempi la rafforzi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi insegnamenti l’ammaestri,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la sua intercessione la proteggi."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo dono della tua benevolenza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la moltitudine degli angeli e dei santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantiamo senza fine l’inno della tua lode:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saints Pasteurs. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par le Christ, notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu donnes à ton Église de se réjouir en la fête de saint"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "des saints"
              },
              {
                "type": "rubric",
                "text": ") N."
              },
              {
                "type": "text",
                "text": ":"
              }
            ],
            [
              {
                "type": "text",
                "text": "par l’exemple qu’il a"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "qu’ils ont"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "donné, tu nous encourages,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par son"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "enseignement, tu nous éclaires,"
              }
            ],
            [
              {
                "type": "text",
                "text": "à sa"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "prière, tu veilles sur nous."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "avec la multitude des anges et des saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous chantons l’hymne de ta gloire et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Hirten der Kirche genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, Dir, Vater im Himmel, zu danken und am Fest des heiligen"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "deine Größe zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Sein Leben aus dem Glauben ist uns ein Vorbild, die Botschaft seiner Predigt belehrt uns, seine Fürbitte erwirkt uns Schutz und Hilfe durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen wir dich in deiner Kirche und vereinen uns mit den Engeln und Heiligen zum Hochgesang von deiner göttlichen Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Manéte in me, et ego in vobis, dicit Dóminus. Qui manet in me et ego in eo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "hic fert fructum multum"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "permaneced en mí y yo en vosotros, dice el Señor; el que permanece en mí y yo en él, ese da fruto abundante"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Remain in me, as I remain in you, says the Lord. Whoever remains in me and I in him bears fruit in plenty"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Permanecei em mim e eu permanecerei em vós, diz o Senhor."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Aquele que permanece em mim, e eu nele,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "esse produz muito fruto"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "«Rimanete in me e io in voi», dice il Signore. «Chi rimane in me, e io in lui,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "porta molto frutto»"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Demeurez en moi, comme moi en vous, dit le Seigneur."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Celui qui demeure en moi,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et en qui je demeure,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "celui-là porte beaucoup de fruit"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "So spricht der Herr: Bleibt in mir, dann bleibe ich in euch. Wer in mir bleibt und in wem ich bleibe, der bringt reiche Frucht."
                }
              ]
            ]
          },
          "citation": {
            "la": "Io 15, 4-5",
            "es": "Jn 15, 4-5",
            "en-US": "Jn 15: 4-5",
            "pt-BR": "Jo 15, 4-5",
            "it": "Gv 15, 4-5",
            "fr": "Jn 15, 4-5",
            "de": "Joh 15, 4-5"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Sacraménta quæ súmpsimus, Dómine Deus noster, illam nobis fidem innútriant,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "quam et apostólica dócuit prædicátio, et beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "sollicitúdo custodívit. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, Dios nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que los sacramentos que hemos recibido alimenten en nosotros aquella fe que nos enseñó la predicación apostólica y que san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "conservó celosamente."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "May the Sacrament we have received, O Lord our God, nourish in us that faith taught by the preaching of the Apostles and kept safe by the labors of blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor nosso Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "os sacramentos que recebemos alimentem em nós a mesma fé transmitida pela pregação apostólica e que São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "guardou com solicitude."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "I sacramenti che abbiamo ricevuto, Signore Dio nostro, alimentino in noi quella fede che la predicazione apostolica ha trasmesso e l’amorosa dedizione di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ha custodito. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur notre Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que le sacrement reçu nourrisse en nous la foi enseignée par la prédication des Apôtres et gardée avec sollicitude par saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Ewiger Gott, lass uns in der Kraft dieses Mahles den Glauben unversehrt bewahren, der von den Aposteln verkündet und uns vom heiligen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "in treuer Sorge überliefert wurde. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
