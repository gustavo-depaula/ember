{
  "id": "common.pastors.past7",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE PASTORUM III. PRO PASTORIBUS B. Pro uno pastore 2",
    "es": "COMÚN DE PASTORES III. PASTORES B. Para un pastor 2",
    "en-US": "Common of Pastors Iii. For Pastors B. For One Pastor 2",
    "pt-BR": "Comum dos Pastores Iii. Para Pastores B. Para um pastor 2",
    "it": "COMUNE DEI PASTORI",
    "fr": "COMMUN DES PASTEURS III. POUR DES PASTEURS B. Pour un pasteur 2",
    "de": "COMMUNE-TEXTE FÜR HIRTEN DER KIRCHE III. Für Seelsorger B. Für einen Seelsorger 2"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Elégit eum Dóminus sacerdótem sibi, ad sacrificándum ei hóstiam laudis"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "El Señor lo eligió como su sacerdote, para ofrecer el sacrificio de alabanza"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The Lord chose him as a priest for himself,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "to offer him a sacrifice of praise"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "O Senhor o escolheu como sacerdote para si,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a fim de oferecer um sacrifício de louvor"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Il Signore lo scelse per sé, perché gli offrisse sacrifici di lode"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Le Seigneur l’a choisi comme son prêtre,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour qu’il lui offre le sacrifice de louange"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "es": "Cf. Eclo 45, 16",
            "en-US": "Sir 45:20",
            "it": "Cf. Sir 45, 16"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, fidélium lumen et pastor animárum, qui beátum"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "epíscopum in Ecclésia posuísti, ut oves tuas verbo pásceret et informáret exémplo, da nobis, eius intercessióne, et fidem serváre, quam verbo dócuit, et viam sequi, quam exémplo monstrávit. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "luz de los fieles y pastor de las almas, que pusiste en la Iglesia a"
                },
                {
                  "type": "rubric",
                  "text": "["
                },
                {
                  "type": "text",
                  "text": "al obispo"
                },
                {
                  "type": "rubric",
                  "text": "]"
                },
                {
                  "type": "text",
                  "text": "san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para apacentar a tus ovejas con su palabra e instruirlas con su ejemplo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "guardar la fe que enseñó con su predicación y seguir el camino que mostró con su vida."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, light of the faithful and shepherd of souls,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who set (the Bishop)"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "in the Church to feed your sheep by his words and form them by his example,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "grant that through his intercession we may keep the faith he taught by his words and follow the way he showed by his example."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, luz dos fiéis e pastor das almas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "destes à Igreja o bispo São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "para apascentar vossas ovelhas pela palavra e ensiná-las com o exemplo;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedei-nos, por sua intercessão,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "guardar a fé que ensinou com a palavra e seguir o caminho que nos mostrou pelo exemplo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nosso Senhor Jesus Cristo, vosso Filho, que é Deus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "e convosco vive e reina, na unidade do Espírito Santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por todos os séculos dos séculos."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, luce del tuo popolo e pastore delle anime, che hai posto nella Chiesa san"
                },
                {
                  "type": "rubric",
                  "text": "N. ["
                },
                {
                  "type": "text",
                  "text": "il santo vescovo"
                },
                {
                  "type": "rubric",
                  "text": "N.]"
                },
                {
                  "type": "text",
                  "text": "a pascere con la parola il tuo gregge e a formarlo con l’esempio, donaci per sua intercessione di custodire la fede che ha insegnato e di seguire la via da lui indicata. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Lumière des fidèles et pasteur des âmes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu qui as donné à ton Église l’évêque saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour être le berger de ton troupeau,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "le nourrir par sa parole et l’instruire par son exemple,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous, par son intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de garder la foi que sa parole a transmise,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et de suivre le chemin que son exemple a tracé."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gott, du Licht deiner Gläubigen, du Hirt der Seelen. Du hast den heiligen (Bischof)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "dazu berufen, durch seine Predigt und sein Beispiel der Kirche zu dienen. Seine Fürsprache helfe uns, den Glauben zu bewahren, den er gelehrt, und den Weg zu gehen den er durch sein Leben gewiesen hat. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Maiestátem tuam supplíciter implorámus, omnípotens Deus, ut, sicut glóriam divínæ poténtiæ múnera pro beáto"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "obláta testántur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sic nobis efféctum tuæ salvatiónis impéndant. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Dios todopoderoso,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "humildemente imploramos de tu divina Majestad que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "así como estos dones ofrecidos en honor de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "manifiestan la gloria de tu poder divino,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "del mismo modo nos alcancen el fruto de tu salvación."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "We humbly implore your majesty, almighty God,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "that, just as the offerings made in honor of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "bear witness to the glory of divine power,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "so they may impart to us the effects of your salvation."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus onipotente,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "suplicantes imploramos à vossa majestade para que os dons oferecidos em honra de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "como manifestam a glória do poder divino,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "assim nos obtenham os frutos da vossa salvação."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Accogli, o Signore, i nostri doni nella memoria di san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e fa' che il sacrificio eucaristico che proclama la tua gloria ci ottenga la salvezza eterna. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Dieu de puissance et de majesté,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous te supplions humblement :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "puisque les dons offerts en l’honneur de saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "attestent la gloire de ta puissance,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’ils nous procurent le fruit de ton salut."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, die Gaben, die wir am Gedenktag des heiligen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "darbringen, bezeugen deine Macht und Größe. Diese Opferfeier erwirke uns die Frucht der Erlösung. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf056",
      "label": {
        "la": "PRÆFATIO DE SANCTIS PASTORIBUS",
        "es": "PREFACIO DE LOS SANTOS PASTORES",
        "en-US": "Preface of Holy Pastors",
        "pt-BR": "Prefácio dos Santos Pastores a",
        "it": "PREFAZIO DEI SANTI PASTORI I",
        "fr": "PRÉFACE DES SAINTS PASTEURS",
        "de": "PRÄFATION VON DEN HIRTEN DER KIRCHE"
      },
      "excerpt": {
        "la": "De præsentia sanctorum Pastorum in Ecclésia",
        "es": "La presencia de los santos pastores en la Iglesia",
        "en-US": "The presence of holy Pastors in the Church",
        "pt-BR": "presença dos Santos Pastores na Igreja",
        "it": "La presenza dei santi Pastori nella Chiesa",
        "fr": "La présence des saints pasteurs dans l’Église",
        "de": "Das Wirken der heiligen Hirten für uns"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Ss. Pastorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Christum Dóminum nostrum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Quia sic tríbuis Ecclésiam tuam sancti"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "festivitáte gaudére,"
              }
            ],
            [
              {
                "type": "text",
                "text": "ut eam exémplo piæ conversatiónis corróbores,"
              }
            ],
            [
              {
                "type": "text",
                "text": "verbo prædicatiónis erúdias,"
              }
            ],
            [
              {
                "type": "text",
                "text": "gratáque tibi supplicatióne tueáris."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Angelórum atque Sanctórum turba,"
              }
            ],
            [
              {
                "type": "text",
                "text": "hymnum laudis tibi cánimus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de los santos Pastores. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Señor nuestro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque nos concedes la alegría de celebrar hoy la fiesta de san"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              }
            ],
            [
              {
                "type": "text",
                "text": ","
              }
            ],
            [
              {
                "type": "text",
                "text": "fortaleciendo a tu Iglesia con el ejemplo de su vida santa,"
              }
            ],
            [
              {
                "type": "text",
                "text": "instruyéndola con su palabra y protegiéndola con su intercesión."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los ángeles y con la multitud de los santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te cantamos el himno de alabanza diciendo sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Pastors. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God,"
              }
            ],
            [
              {
                "type": "text",
                "text": "through Christ our Lord."
              }
            ],
            [
              {
                "type": "text",
                "text": "For, as on the festival of Saint"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "you bid your Church rejoice,"
              }
            ],
            [
              {
                "type": "text",
                "text": "so, too, you strengthen her by the example of his holy life,"
              }
            ],
            [
              {
                "type": "text",
                "text": "teach her by his words of preaching,"
              }
            ],
            [
              {
                "type": "text",
                "text": "and keep her safe in answer to his prayers."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with the company of Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we sing the hymn of your praise,"
              }
            ],
            [
              {
                "type": "text",
                "text": "as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas dos Santos Pastores; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "por Cristo, Senhor nosso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vós nos concedeis a alegria de celebrar a memória"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "festa, solenidade"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "de São"
              },
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "e fortaleceis a vossa Igreja com o exemplo de sua vida,"
              }
            ],
            [
              {
                "type": "text",
                "text": "o ensinamento de sua pregação e o auxílio de suas preces."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com a multidão dos Anjos e dos Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "entoamos o hino da vossa glória,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Il seguente prefazio si dice nelle solennità e nelle feste dei santi pastori. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta, nostro dovere e fonte di salvezza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "rendere grazie sempre e in ogni luogo a te, Signore, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno,"
              }
            ],
            [
              {
                "type": "text",
                "text": "per Cristo Signore nostro."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu doni alla tua Chiesa la gioia di celebrare la festa [memoria] di san N.:"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi esempi la rafforzi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con i suoi insegnamenti l’ammaestri,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la sua intercessione la proteggi."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo dono della tua benevolenza,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con la moltitudine degli angeli e dei santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantiamo senza fine l’inno della tua lode:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saints Pasteurs. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par le Christ, notre Seigneur."
              }
            ],
            [
              {
                "type": "text",
                "text": "Tu donnes à ton Église de se réjouir en la fête de saint"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "des saints"
              },
              {
                "type": "rubric",
                "text": ") N."
              },
              {
                "type": "text",
                "text": ":"
              }
            ],
            [
              {
                "type": "text",
                "text": "par l’exemple qu’il a"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "qu’ils ont"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "donné, tu nous encourages,"
              }
            ],
            [
              {
                "type": "text",
                "text": "par son"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "enseignement, tu nous éclaires,"
              }
            ],
            [
              {
                "type": "text",
                "text": "à sa"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "leur"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "prière, tu veilles sur nous."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "avec la multitude des anges et des saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous chantons l’hymne de ta gloire et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Hirten der Kirche genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, Dir, Vater im Himmel, zu danken und am Fest des heiligen"
              }
            ],
            [
              {
                "type": "rubric",
                "text": "N."
              },
              {
                "type": "text",
                "text": "deine Größe zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Sein Leben aus dem Glauben ist uns ein Vorbild, die Botschaft seiner Predigt belehrt uns, seine Fürbitte erwirkt uns Schutz und Hilfe durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen wir dich in deiner Kirche und vereinen uns mit den Engeln und Heiligen zum Hochgesang von deiner göttlichen Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Ecce ego vobíscum sum ómnibus diébus usque ad consummatiónem sǽculi, dicit Dóminus"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Sabed que yo estoy con vosotros todos los días, hasta el final de los tiempos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dice el Señor"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Behold, I am with you always,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "even to the end of the age, says the Lord"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Eis que estarei convosco todos os dias,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "até o fim do mundo, diz o Senhor"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "aleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ecco, io sono con voi tutti i giorni, sino alla fine del mondo"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Je suis avec vous tous les jours, dit le Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "jusqu’à la fin du monde"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Ich bin alle Tage bei euch bis zum Ende der Welt – so spricht der Herr."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Refectióne sacra enutrítos, fac nos, omnípotens Deus, exémpla beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "iúgiter sequéntes, te pérpeti devotióne cólere, et indeféssa ómnibus caritáte profícere. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Fortalecidos con el alimento santo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te rogamos, Dios todopoderoso,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "siguiendo siempre el ejemplo de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos concedas servirte con entrega constante y progresar en el amor incansable hacia todos."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Make us, who have been nourished by this sacred meal, almighty God,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "always follow the example of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "in serving you with constant devotion and assisting all with untiring charity."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus onipotente, fazei que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "alimentados na mesa sagrada e seguindo em tudo o exemplo de São"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "vos sirvamos com dedicação constante e a todos amemos com incansável caridade."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Dio onnipotente, che ci hai nutriti al tuo santo convito, fa' che, seguendo gli esempi di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ti onoriamo con fedele servizio e ci prodighiamo verso tutti con carità instancabile. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Tu nous as fortifiés par cette nourriture sainte,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu tout-puissant :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fais qu’en imitant les exemples de saint"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’honorions par un attachement sans limite,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et soyons au service de tous par une inlassable charité."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Allmächtiger Gott, du hast uns mit dem heiligen Mahl gestärkt. Hilf uns, nach dem Beispiel des heiligen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "dich allezeit zu ehren und den Menschen in brüderlicher Liebe zu dienen. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
