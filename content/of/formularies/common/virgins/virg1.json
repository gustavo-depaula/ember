{
  "id": "common.virgins.virg1",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE VIRGINUM II. PRO UNA VIRGINE 1",
    "es": "COMÚN DE VÍRGENES II. Para una virgen 1",
    "en-US": "Common of Virgins Ii. For One Virgin 1",
    "pt-BR": "Comum das virgens 1",
    "it": "COMUNE DELLE VERGINI II. Per una vergine 1.",
    "fr": "COMMUN DES VIERGES II. POUR UNE VIERGE 1",
    "de": "COMMUNE-TEXTE FÜR JUNGFRAUEN 1."
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "O quam pulchra es, virgo Christi, quæ corónam Dómini digna fuísti accípere,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "corónam perpétuæ virginitátis"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Qué hermosa eres, virgen de Cristo, que fuiste digna de recibir la corona del Señor, la corona de la perpetua virginidad"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "How beautiful you are, O virgin of Christ, who were worthy to receive the Lord's crown, the crown of perpetual virginity"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Come sei bella, o vergine di Cristo, degna di ricevere la corona del Signore,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la corona della verginità eterna"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Que tu es belle, vierge du Christ !"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Tu as mérité de recevoir la couronne du Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la couronne de la virginité à jamais"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Exáudi nos, Deus, salutáris noster, ut, sicut de beátæ"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "vírginis commemoratióne gaudémus, ita piæ devotiónis erudiámur afféctu. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Escúchanos, Dios, Salvador nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, alegres en la fiesta de santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", virgen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aprendamos a servirte con amor."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Hear us, God our Savior, that, as we rejoice in commemorating the Virgin blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", we may be instructed by her loving devotion."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Deus e Salvador nosso, ouvi a nossa súplica, para que, alegrando-nos com a festa da virgem santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "aprendamos a vos servir com amor. Por nosso Senhor Jesus Cristo, vosso Filho, na unidade do Espírito Santo."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, nostra salvezza, esaudisci la preghiera della tua Chiesa, perché celebrando con gioia la memoria della santa vergine"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", impariamo a servirti con amore. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Exauce nos prières, Dieu notre Sauveur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "afin qu’en célébrant dans la joie la mémoire de la vierge sainte"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous apprenions à te servir avec un amour sincère."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gott, unser Heil, wir feiern heute den Gedenktag der heiligen Jungfrau"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Erhöre unser Gebet und mache uns bereit, dir mit jener Hingabe zu dienen, die wir an dieser Heiligen bewundern. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "In beáta vírgine"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "te, Dómine, mirábilem prædicántes, maiestátem tuam supplíciter exorámus, ut, sicut eius tibi grata sunt mérita, sic nostræ servitútis accépta reddántur offícia. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "al proclamarte admirable en santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "virgen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "suplicamos humildemente a tu majestad que, así como te agradaron sus méritos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aceptes de igual modo nuestro servicio."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "As we proclaim your wonders, O Lord, in the Virgin blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", we humbly implore your majesty that, as her merits are pleasing to you, so, too, our dutiful service may find favor in your sight."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, ouvi as nossas preces, ao proclamarmos as vossas maravilhas em santa"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", e, assim como vos agradou por sua vida, seja de vosso agrado o nosso culto. Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, mirabile nei tuoi santi, accogli questi doni che ti presentiamo nel ricordo di santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e come ti fu gradita la sua testimonianza verginale, ti sia ben accetta l’offerta del nostro sacrificio."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Nous proclamons tes merveilles,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accomplies en la bienheureuse vierge, sainte"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Seigneur, Dieu de majesté,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et nous te supplions humblement :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "toi qui appréciais les mérites de sa vie,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accepte l’hommage de notre service."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Wir preisen dich, Herr, denn du bist groß in deinen Heiligen. Das Leben der heiligen Jungfrau"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "hat dir wohlgefallen. Nimm mit diesen Gaben auch unseren Dienst an. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf057",
      "label": {
        "la": "PRÆFATIO DE SANCTIS VIRGINIBUS ET RELIGIOSIS",
        "es": "PREFACIO DE SANTAS VÍRGENES Y RELIGIOSOS",
        "en-US": "Preface of Holy Virgins and Religious",
        "pt-BR": "Prefácio das Santas Virgens e Religiosos o",
        "it": "PREFAZIO DELLE SANTE VERGINI E DEI SANTI RELIGIOSI",
        "fr": "PRÉFACE DES SAINTES VIERGES, ET DES SAINTS RELIGIEUX OU RELIGIEUSES",
        "de": "PRÄFATION VON DEN HEILIGEN JUNGFRAUEN UND ORDENSLEUTEN"
      },
      "excerpt": {
        "la": "De signo vitæ Deo consecratæ",
        "es": "Significado de la vida de consagración exclusiva a Dios",
        "en-US": "The sign of a life consecrated to God",
        "pt-BR": "sinal da vida consagrada a Deus",
        "it": "Il segno della vita consacrata a Dio",
        "fr": "Signification de la vie consacrée",
        "de": "Die Zeichenhaftigkeit des gottgeweihten Lebens"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Sanctarum Virginum et Sanctorum Religiosorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "In Sanctis enim, qui Christo se dedicavérunt propter regnum cælórum,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tuam decet providéntiam celebráre mirábilem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "qua humánam substántiam et ad primæ oríginis révocas sanctitátem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et perdúcis ad experiénda dona,"
              }
            ],
            [
              {
                "type": "text",
                "text": "quæ in novo sǽculo sunt habénda."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Sanctis et Angelis univérsis,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te collaudámus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de las santas Vírgenes y de los santos Religiosos. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar, Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque celebramos tu providencia admirable en los santos que se entregaron a Cristo por el reino de los cielos."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por ella llamas de nuevo a la humanidad a la santidad primera que de ti había recibido,"
              }
            ],
            [
              {
                "type": "text",
                "text": "y la conduces a gustar los dones que espera recibir en el cielo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los santos y todos los ángeles,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos, proclamando sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Virgins and Religious. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For in the Saints who consecrated themselves to Christ for the sake of the Kingdom of Heaven,"
              }
            ],
            [
              {
                "type": "text",
                "text": "it is right to celebrate the wonders of your providence,"
              }
            ],
            [
              {
                "type": "text",
                "text": "by which you call human nature back to its original holiness and bring it to experience on this earth the gifts you promise in the new world to come."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with all the Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we praise you, as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas das Santas Virgens e dos Santos Religiosos; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Recordando os Santos e Santas que se consagraram a Cristo por amor ao reino dos céus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "celebramos a vossa admirável providência;"
              }
            ],
            [
              {
                "type": "text",
                "text": "por ela, reconduzis a humanidade à santidade original e nos fazeis saborear, já aqui na terra,"
              }
            ],
            [
              {
                "type": "text",
                "text": "os dons reservados para o céu."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com todos os Anjos e Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nós vos louvamos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Si dice nelle solennità e nelle feste delle sante vergini e dei santi religiosi. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta,"
              }
            ],
            [
              {
                "type": "text",
                "text": "renderti grazie e innalzare a te l’inno di benedizione e di lode,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nei tuoi santi, che per il regno dei cieli hanno consacrato la vita a Cristo tuo Figlio,"
              }
            ],
            [
              {
                "type": "text",
                "text": "noi celebriamo, o Padre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "l’iniziativa mirabile del tuo amore,"
              }
            ],
            [
              {
                "type": "text",
                "text": "poiché tu riporti l’uomo alla santità della sua prima origine e gli fai pregustare i doni che a lui prepari nel mondo rinnovato."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo segno della tua bontà,"
              }
            ],
            [
              {
                "type": "text",
                "text": "uniti agli angeli e ai santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con voce unanime cantiamo l’inno della tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saintes vierges et des saints religieux ou religieuses. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nous célébrons les prévenances de ton amour pour tant d’hommes et de femmes parvenus à la sainteté en se donnant au Christ à cause du royaume des Cieux."
              }
            ],
            [
              {
                "type": "text",
                "text": "Par ce mystère d’alliance,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tu veux que notre condition humaine retrouve sa splendeur première,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et que, dès ici-bas, nous ayons un avant-goût des biens que tu nous donneras dans le monde à venir."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi, avec les saints et tous les anges,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous te louons et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Jungfrauen und Ordensleuten genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und in den Heiligen deine Gnade zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Inmitten der Kirche berufst du Menschen, sich Christus zu weihen und mit ganzer Hingabe das Himmelreich zu suchen. In ihnen offenbarst du deinen Ratschluss, uns Menschen die ursprüngliche Heiligkeit neu zu schenken und uns schon jetzt mit Freude an den Gütern der kommenden Welt zu erfüllen durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen dich Himmel und Erde, Engel und Menschen und singen wie aus einem Munde das Lob deiner Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Unum pétii a Dómino, hoc requíram: ut inhábitem in domo Dómini ómnibus diébus vitæ meæ"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Una cosa pido al Señor, eso buscaré: habitar en la casa del Señor por los días de mi vida"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "There is one thing I ask of the Lord, only this do I seek: to live in the house of the Lord all the days of my life"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Una cosa ho chiesto al Signore, questa sola io cerco: abitare nella casa del Signore tutti i giorni della mia vita"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "J’ai demandé une chose au Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "la seule que je cherche :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "habiter la maison du Seigneur tous les jours de ma vi"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Ps 26, 4",
            "es": "Sal 26,4",
            "en-US": "Ps 27 (26): 4",
            "it": "Sal 26,4",
            "fr": "Cf. Ps 26, 4"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Divíni múneris participatióne refécti, quǽsumus, Dómine Deus noster, ut,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "exémplo beátæ"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", mortificatiónem Iesu in córpore nostro circumferéntes, tibi soli adhærére studeámus. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, Dios nuestro,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "alimentados por la participación en estos dones divinos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "te pedimos que, a ejemplo de santa"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "llevando en nuestro cuerpo la muerte de Jesús,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos esforcemos por unirnos solamente a ti."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Renewed by partaking of this divine gift, we pray, O Lord our God, that by the example of the blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", bearing in our body the Death of Jesus, we may strive to hold fast to you alone."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Senhor nosso Deus, fortalecidos pela participação nesta Eucaristia, fazei que,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "a exemplo de santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", nos esforcemos por servir unicamente a vós, trazendo em nosso corpo os sinais dos sofrimentos de Jesus."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Que vive e reina para sempre."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Rinvigoriti dalla partecipazione ai santi doni, ti preghiamo, Signore Dio nostro: fa' che sull’esempio di santa"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "portiamo nel nostro corpo la passione di Cristo Gesù, per aderire a te, unico e sommo bene."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "En participant au don que tu nous as fait,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Seigneur notre Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous avons renouvelé nos forces,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et nous te supplions encore :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qu’à l’exemple de sainte"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "portant dans notre corps la mort de Jésus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous cherchions à nous attacher à toi seul."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast uns gestärkt durch die Teilnahme am heiligen Mahl."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Da wir das Todesleiden Jesu an unserem Leibe tragen, lehre uns nach dem Vorbild der heiligen Jungfrau"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", dir unser ganzes Leben als ungeteilten Dienst zu weihen. Darum bitten wir durch Christus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
