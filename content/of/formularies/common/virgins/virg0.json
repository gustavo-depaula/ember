{
  "id": "common.virgins.virg0",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE VIRGINUM I. PRO PLURIBUS VIRGINIBUS",
    "es": "COMÚN DE VÍRGENES I. Para varias vírgenes",
    "en-US": "Common of Virgins I. For Several Virgins",
    "pt-BR": "Comum das virgens 4",
    "it": "COMUNE DELLE VERGINI I. Per più vergini",
    "fr": "COMMUN DES VIERGES I. POUR PLUSIEURS VIERGES",
    "de": "COMMUNE-TEXTE FÜR JUNGFRAUEN 4. Für mehrere Jungfrauen"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Afferéntur Regi vírgines in lætítia et exsultátione, adducéntur in templo Regi Dómino"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Llevarán ante el rey al séquito de vírgenes entre alegría y algazara; serán conducidas al templo del Rey y Señor"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The virgins to the King are escorted amid gladness and joy; they are led within the temple to the Lord and King"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Condotte in gioia ed esultanza, sono presentate nel palazzo del re"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Les vierges sont conduites vers le roi dans la joie et l’allégresse ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "elles entrent au palais du roi, le Seigneur"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Ps 44, 16",
            "es": "Cf. Sal 44, 16",
            "en-US": "Ps 45 (44): 16",
            "it": "Sal 44, 16",
            "fr": "Cf. Ps 44, 16"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Multíplica super nos, quǽsumus, Dómine, misericórdiam tuam, ut, sicut in beatárum vírginum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "festivitáte pia devotióne lætámur, ita eárum perpétua societáte, te largiénte, fruámur. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Derrama, Señor, sobre nosotros la abundancia de tu misericordia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para que, así como nos alegramos fervorosamente al celebrar la fiesta de las santas vírgenes"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "gocemos también, por tu gracia,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de su eterna compañía."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Bestow your mercy upon us, Lord, we pray, that, as we rejoice with loving devotion on the feast day of the Virgins blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", so by your gift we may know the eternal delight of their company."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, mostrai-nos sempre mais a vossa misericórdia, e, ao celebrarmos com alegria a festa das virgens santas"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", concedei-nos também o seu eterno convívio. Por nosso Senhor Jesus Cristo, vosso Filho, na unidade do Espírito Santo."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Effondi, o Padre, l’abbondanza della tua misericordia su noi che ci rallegriamo nella memoria delle sante vergini"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", perché possiamo condividere, per tua grazia, la loro beatitudine nel cielo. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Multiplie pour nous, Seigneur, les signes de ta miséricorde,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et puisque nous avons la joie de célébrer avec ferveur la fête des saintes vierges"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "donne-nous le bonheur d’être en leur compagnie à jamais."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Barmherziger Gott, wir begehen in Freude und Dankbarkeit den Gedenktag der heiligen Jungfrauen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Schenke uns auf ihre Fürsprache dein reiches Erbarmen und lass uns in der Gemeinschaft mit deinen Heiligen bei dir die Vollendung finden. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "In sanctárum vírginum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "commemoratióne te, Dómine, mirábilem prædicántes,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "múnera votíva deférimus; præsta, quǽsumus, ut, sicut eárum tibi grata sunt mérita, sic nostræ servitútis accépta reddántur offícia. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor, te proclamamos admirable al conmemorar a las santas vírgenes"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en cuyo honor presentamos estos dones,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y te rogamos que, así como te agradaron sus méritos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aceptes de igual modo nuestro humilde servicio."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "As we proclaim your wonders, O Lord, in the commemoration of the holy Virgins"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", we bring you these offerings and prayers; grant, we ask, that, as their merits are pleasing to you, so, too, our dutiful service may find favor in your sight."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Deus, nós vos trazemos nossas oferendas proclamando as vossas maravilhas na festa de santas"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Assim como vos agradaram os méritos das vossas virgens, seja de vosso agrado o nosso culto. Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Ti presentiamo, o Signore, le nostre offerte, proclamando le tue meraviglie nella memoria delle sante"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", come ti fu gradita la loro testimonianza verginale, ti sia ben accetta l’offerta del nostro sacrificio. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Nous proclamons tes merveilles, Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en la mémoire des vierges saintes"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et nous te présentons nos offrandes :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as reconnu les mérites de leur vie,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accepte, nous t’en prions, l’hommage de ceux qui te servent."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Wir preisen dich, Herr, denn du bist groß in deinen Heiligen. Das Leben der Heiligen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "hat dir wohlgefallen; nimm mit diesen Gaben auch unseren Dienst an. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf057",
      "label": {
        "la": "PRÆFATIO DE SANCTIS VIRGINIBUS ET RELIGIOSIS",
        "es": "PREFACIO DE SANTAS VÍRGENES Y RELIGIOSOS",
        "en-US": "Preface of Holy Virgins and Religious",
        "pt-BR": "Prefácio das Santas Virgens e Religiosos o",
        "it": "PREFAZIO DELLE SANTE VERGINI E DEI SANTI RELIGIOSI",
        "fr": "PRÉFACE DES SAINTES VIERGES, ET DES SAINTS RELIGIEUX OU RELIGIEUSES",
        "de": "PRÄFATION VON DEN HEILIGEN JUNGFRAUEN UND ORDENSLEUTEN"
      },
      "excerpt": {
        "la": "De signo vitæ Deo consecratæ",
        "es": "Significado de la vida de consagración exclusiva a Dios",
        "en-US": "The sign of a life consecrated to God",
        "pt-BR": "sinal da vida consagrada a Deus",
        "it": "Il segno della vita consacrata a Dio",
        "fr": "Signification de la vie consacrée",
        "de": "Die Zeichenhaftigkeit des gottgeweihten Lebens"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Sanctarum Virginum et Sanctorum Religiosorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "In Sanctis enim, qui Christo se dedicavérunt propter regnum cælórum,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tuam decet providéntiam celebráre mirábilem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "qua humánam substántiam et ad primæ oríginis révocas sanctitátem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et perdúcis ad experiénda dona,"
              }
            ],
            [
              {
                "type": "text",
                "text": "quæ in novo sǽculo sunt habénda."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Sanctis et Angelis univérsis,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te collaudámus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de las santas Vírgenes y de los santos Religiosos. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar, Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque celebramos tu providencia admirable en los santos que se entregaron a Cristo por el reino de los cielos."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por ella llamas de nuevo a la humanidad a la santidad primera que de ti había recibido,"
              }
            ],
            [
              {
                "type": "text",
                "text": "y la conduces a gustar los dones que espera recibir en el cielo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los santos y todos los ángeles,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos, proclamando sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Virgins and Religious. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For in the Saints who consecrated themselves to Christ for the sake of the Kingdom of Heaven,"
              }
            ],
            [
              {
                "type": "text",
                "text": "it is right to celebrate the wonders of your providence,"
              }
            ],
            [
              {
                "type": "text",
                "text": "by which you call human nature back to its original holiness and bring it to experience on this earth the gifts you promise in the new world to come."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with all the Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we praise you, as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas das Santas Virgens e dos Santos Religiosos; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Recordando os Santos e Santas que se consagraram a Cristo por amor ao reino dos céus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "celebramos a vossa admirável providência;"
              }
            ],
            [
              {
                "type": "text",
                "text": "por ela, reconduzis a humanidade à santidade original e nos fazeis saborear, já aqui na terra,"
              }
            ],
            [
              {
                "type": "text",
                "text": "os dons reservados para o céu."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com todos os Anjos e Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nós vos louvamos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Si dice nelle solennità e nelle feste delle sante vergini e dei santi religiosi. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta,"
              }
            ],
            [
              {
                "type": "text",
                "text": "renderti grazie e innalzare a te l’inno di benedizione e di lode,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nei tuoi santi, che per il regno dei cieli hanno consacrato la vita a Cristo tuo Figlio,"
              }
            ],
            [
              {
                "type": "text",
                "text": "noi celebriamo, o Padre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "l’iniziativa mirabile del tuo amore,"
              }
            ],
            [
              {
                "type": "text",
                "text": "poiché tu riporti l’uomo alla santità della sua prima origine e gli fai pregustare i doni che a lui prepari nel mondo rinnovato."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo segno della tua bontà,"
              }
            ],
            [
              {
                "type": "text",
                "text": "uniti agli angeli e ai santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con voce unanime cantiamo l’inno della tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saintes vierges et des saints religieux ou religieuses. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nous célébrons les prévenances de ton amour pour tant d’hommes et de femmes parvenus à la sainteté en se donnant au Christ à cause du royaume des Cieux."
              }
            ],
            [
              {
                "type": "text",
                "text": "Par ce mystère d’alliance,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tu veux que notre condition humaine retrouve sa splendeur première,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et que, dès ici-bas, nous ayons un avant-goût des biens que tu nous donneras dans le monde à venir."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi, avec les saints et tous les anges,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous te louons et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Jungfrauen und Ordensleuten genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und in den Heiligen deine Gnade zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Inmitten der Kirche berufst du Menschen, sich Christus zu weihen und mit ganzer Hingabe das Himmelreich zu suchen. In ihnen offenbarst du deinen Ratschluss, uns Menschen die ursprüngliche Heiligkeit neu zu schenken und uns schon jetzt mit Freude an den Gütern der kommenden Welt zu erfüllen durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen dich Himmel und Erde, Engel und Menschen und singen wie aus einem Munde das Lob deiner Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Qui díligit me, diligétur a Patre meo, et ad eum veniémus, et mansiónem apud eum faciémus"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Al que me ama, lo amará mi Padre, y vendremos a él y haremos morada en él"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Whoever loves me will be loved by my Father, and I will come to him and reveal myself to him"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Aquele que me ama será amado por meu Pai. Nós viremos a ele, e faremos nele nossa morada."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Chi mi ama sarà amato dal Padre mio e verremo a lui e prenderemo dimora presso di lui"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Celui qui m’aime sera aimé de mon Père,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dit le Seigneur ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous viendrons vers lui et, chez lui, nous ferons une demeure"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Wer mich liebt, wird von meinem Vater geliebt werden, und wir werden zu ihm kommen und bei ihm wohnen - so spricht der Herr"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "Österl. Zeit"
                },
                {
                  "type": "text",
                  "text": "Halleluja"
                }
              ]
            ]
          },
          "citation": {
            "la": "Io 14, 21",
            "es": "Jn 14, 21",
            "en-US": "Jn 14: 21, 23",
            "pt-BR": "Jo 14, 21",
            "it": "Gv 14, 21",
            "fr": "Jn 14, 21",
            "de": "Joh 14, 21"
          }
        }
      }
    ]
  },
  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Sumpta mystéria, quǽsumus, Dómine, in hac festivitáte beatárum vírginum"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", íncitent nos iúgiter et illústrent, ut digne advéntum Fílii tui præstolémur, et ad supérnas eius núptias admittámur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "el sacramento que hemos recibido en esta fiesta de las santas vírgenes"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "y"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nos estimule e ilumine siempre,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para preparar dignamente la venida de tu Hijo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y seamos admitidos en sus bodas eternas."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "May the mysteries we have received, O Lord, on this feast day of the Virgins blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "and"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "constantly bestir and enlighten us, we pray, so that we may stand ready for the coming of your Son and be admitted to his wedding feast on high."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "pt-BR": [
              [
                {
                  "type": "text",
                  "text": "Ó Pai, a Eucaristia que recebemos na festa das virgens santas"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "nos desperte e ilumine; fazei que esperemos vigilantes a chegada de vosso Filho e sejamos admitidos às suas núpcias eternas. Por Cristo, nosso Senhor."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Il sacramento che abbiamo ricevuto, o Signore, nella memoria delle sante vergini"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "e"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ci renda vigilanti e alimenti le lampade della nostra fede, perché possiamo attendere la venuta del tuo Figlio ed essere introdotti al banchetto delle nozze eterne."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Que cette communion à tes mystères, Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en la fête des saintes vierges"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "et"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous encourage et nous éclaire,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "pour que nous sachions attendre la venue de ton Fils et soyons admis à ses noces dans le Royaume."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Lui qui vit et règne pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gütiger Gott, das heilige Sakrament, das wir am Fest der heiligen Jungfrauen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "und"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "empfangen haben,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "mache uns bereit, gleich ihnen die Ankunft deines Sohnes zu erwarten und am Hochzeitsmahl des Lammes teilzunehmen. Darum bitten wir durch Christus,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
