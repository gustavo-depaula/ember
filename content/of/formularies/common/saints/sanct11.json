                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Bienaventurados los pobres en el espíritu, porque de ellos es el reino de los cielos"
                },
                {
                  "type": "rubric",
                  "text": "[T.P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                },
                {
                  "type": "rubric",
                  "text": "]"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Blessed are the poor in spirit, for theirs is the Kingdom of Heaven"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Beati i poveri in spirito: di essi è il regno dei cieli"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T.P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
