  "postcommunion": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Quǽsumus, omnípotens Deus, ut, qui huius sacraménti munímur virtúte, exémplo beáti"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", discámus te super ómnia semper inquírere,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et novi hóminis formam in hoc sǽculo portáre. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Te rogamos, Dios todopoderoso,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que, fortalecidos por este sacramento,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "aprendamos a buscarte siempre sobre todas las cosas a ejemplo de san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y llevar en este mundo la imagen del hombre nuevo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "We pray, almighty God, that we, who are fortified by the power of this Sacrament, may learn through the example of blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "to seek you always above all things and to bear in this world the likeness of the New Man."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Dio onnipotente, fa' che, sostenuti dalla forza di questo sacramento,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "sull’esempio di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "impariamo a cercare sempre te sopra ogni cosa e a portare in questa vita l’immagine dell’uomo nuovo. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Soutenus par la force de ce sacrement,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous t’en prions, Dieu tout-puissant :"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que nous apprenions, en suivant l’exemple de saint(e)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "à te rechercher sans cesse par-dessus tout et à revêtir en ce monde la condition de l’homme nouveau."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Ewiger Gott, du Ursprung und Fülle der Heiligkeit, du hast den heiligen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "zur Vollendung geführt. Lass durch die Kraft deines Sakramentes auch uns in der Liebe wachsen und vollende am Tag Jesu Christi das Werk der Gnade, das du in uns begonnen hast. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  }
}
