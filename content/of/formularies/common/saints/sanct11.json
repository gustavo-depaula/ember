{
  "id": "common.saints.sanct11",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE SANCTORUM ET SANCTARUM II. PRO MONACHIS ET RELIGIOSIS D. Pro religiosis 2",
    "es": "COMÚN DE SANTOS Y SANTAS II. Para monjes y religiosos D. Para religiosos 2",
    "en-US": "Common of Holy Men and Women Ii. For Monks and Religious D. For Religious 2",
    "it": "COMMUNE SANCTORUM ET SANCTARUM II. PRO MONACHIS ET RELIGIOSIS D. Pro religiosis 1",
    "fr": "COMMUN DES SAINTS ET DES SAINTES II. POUR LES RELIGIEUX D. Pour des religieux 2",
    "de": "COMMUNE-TEXTE FÜR Hl. MÄNNER UND Hl. FRAUEN 8. Für Ordensleute"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Lætétur cor quæréntium Dóminum; quǽritis Dóminum et confirmámini, quǽrite fáciem eius semper"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Que se alegren los que buscan al Señor. Recurrid al Señor y a su poder, buscad continuamente su rostro"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Let the hearts that seek the Lord rejoice; turn to the Lord and his strength;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "constantly seek his face"
                },
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Gioisca il cuore di chi cerca il Signore. Cercate il Signore e la sua potenza,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "cercate sempre il suo volto"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Joie pour les cœurs qui cherchent Dieu."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Cherchez le Seigneur, et vous serez affermis,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "recherchez sans trêve sa face"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Ps 104, 3-4",
            "es": "Cf. Sal 104, 3-4",
            "en-US": "Ps 105 (104): 3-4",
            "it": "Sal 104, 3-4",
            "fr": "Cf. Ps 104, 3-4"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, qui beátum"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "ad tuum regnum in hoc sǽculo perquiréndum, per caritátis perféctæ prosecutiónem vocásti, concéde, ut, eius intercessióne roboráti, in dilectiónis via spíritu gaudéntes progrediámur. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que has llamado a san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "para que buscase tu reino en este mundo por el camino de la caridad perfecta,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fortalecidos por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "avanzar, alegres en el espíritu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por las sendas del amor."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por nuestro Señor Jesucristo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, who called blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "to seek your Kingdom in this world through the pursuit of perfect charity, grant, we pray, through his"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "her intercession that we may advance with joyful spirit along the way of love."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through our Lord Jesus Christ, your Son,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, che hai chiamato san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "a cercare con tutte le forze il regno dei cieli in questo mondo nella via della carità perfetta,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concedi anche a noi di essere rafforzati dalla sua intercessione, per progredire con la gioia dello Spirito nel cammino dell’amore. Per il nostro Signore Gesù Cristo, tuo Figlio, che è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as appelé saint(e)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "à rechercher en ce monde ton Royaume en s’efforçant de pratiquer une charité parfaite ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "fais que, fortifiés par son intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous avancions dans la joie spirituelle sur le chemin de l’amour."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par Jésus Christ, ton Fils, notre Seigneur,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, unser Gott, du hast den heiligen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "berufen,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nach der vollkommenen Liebe zu streben und schon in dieser Welt dein Reich zu suchen. Gib uns auf seine Fürsprache die Freude des Geistes und die Kraft, auf dem Weg der Liebe voranzuschreiten. Darum bitten wir durch Jesus Christus."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Accépta tibi sint, quǽsumus, Dómine, múnera nostræ servitútis pro beáti"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "commemoratióne altári tuo propósita, et concéde,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ut, a terrénis impediméntis absolúti, te solo dívites efficiámur. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Acepta, Señor,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "los dones de nuestro servicio que presentamos sobre tu altar en la conmemoración de san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "y concédenos que, libres de las ataduras terrenas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "seas tú nuestra única riqueza."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo, nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "May these offerings of our service, placed on your altar in commemoration of blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", be acceptable to you, O Lord, we pray,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "and grant that, released from earthly attachments, we may have our riches in you alone."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Accetta, o Signore, i doni del nostro servizio, deposti sul tuo altare nella memoria di san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", e fa' che, liberi dagli affanni del mondo, diventiamo ricchi di te, unico nostro bene. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Accepte, Seigneur, comme un hommage de tes serviteurs l’offrande que nous déposons sur ton autel en faisant mémoire de saint(e)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ";"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et permets que, libérés des fardeaux d’ici-bas,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nous n’ayons d’autre richesse que toi."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Herr, im Gedenken an die Hingabe des heiligen"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "bringen wir mit diesen Gaben uns selber dar. Nimm uns alles, was uns von dir trennt, damit du allein unser Reichtum bist. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf057",
      "label": {
        "la": "PRÆFATIO DE SANCTIS VIRGINIBUS ET RELIGIOSIS",
        "es": "PREFACIO DE SANTAS VÍRGENES Y RELIGIOSOS",
        "en-US": "Preface of Holy Virgins and Religious",
        "pt-BR": "Prefácio das Santas Virgens e Religiosos o",
        "it": "PREFAZIO DELLE SANTE VERGINI E DEI SANTI RELIGIOSI",
        "fr": "PRÉFACE DES SAINTES VIERGES, ET DES SAINTS RELIGIEUX OU RELIGIEUSES",
        "de": "PRÄFATION VON DEN HEILIGEN JUNGFRAUEN UND ORDENSLEUTEN"
      },
      "excerpt": {
        "la": "De signo vitæ Deo consecratæ",
        "es": "Significado de la vida de consagración exclusiva a Dios",
        "en-US": "The sign of a life consecrated to God",
        "pt-BR": "sinal da vida consagrada a Deus",
        "it": "Il segno della vita consacrata a Dio",
        "fr": "Signification de la vie consacrée",
        "de": "Die Zeichenhaftigkeit des gottgeweihten Lebens"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Sanctarum Virginum et Sanctorum Religiosorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "In Sanctis enim, qui Christo se dedicavérunt propter regnum cælórum,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tuam decet providéntiam celebráre mirábilem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "qua humánam substántiam et ad primæ oríginis révocas sanctitátem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et perdúcis ad experiénda dona,"
              }
            ],
            [
              {
                "type": "text",
                "text": "quæ in novo sǽculo sunt habénda."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Sanctis et Angelis univérsis,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te collaudámus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de las santas Vírgenes y de los santos Religiosos. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar, Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque celebramos tu providencia admirable en los santos que se entregaron a Cristo por el reino de los cielos."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por ella llamas de nuevo a la humanidad a la santidad primera que de ti había recibido,"
              }
            ],
            [
              {
                "type": "text",
                "text": "y la conduces a gustar los dones que espera recibir en el cielo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los santos y todos los ángeles,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos, proclamando sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Virgins and Religious. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For in the Saints who consecrated themselves to Christ for the sake of the Kingdom of Heaven,"
              }
            ],
            [
              {
                "type": "text",
                "text": "it is right to celebrate the wonders of your providence,"
              }
            ],
            [
              {
                "type": "text",
                "text": "by which you call human nature back to its original holiness and bring it to experience on this earth the gifts you promise in the new world to come."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with all the Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we praise you, as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas das Santas Virgens e dos Santos Religiosos; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Recordando os Santos e Santas que se consagraram a Cristo por amor ao reino dos céus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "celebramos a vossa admirável providência;"
              }
            ],
            [
              {
                "type": "text",
                "text": "por ela, reconduzis a humanidade à santidade original e nos fazeis saborear, já aqui na terra,"
              }
            ],
            [
              {
                "type": "text",
                "text": "os dons reservados para o céu."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com todos os Anjos e Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nós vos louvamos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Si dice nelle solennità e nelle feste delle sante vergini e dei santi religiosi. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta,"
              }
            ],
            [
              {
                "type": "text",
                "text": "renderti grazie e innalzare a te l’inno di benedizione e di lode,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nei tuoi santi, che per il regno dei cieli hanno consacrato la vita a Cristo tuo Figlio,"
              }
            ],
            [
              {
                "type": "text",
                "text": "noi celebriamo, o Padre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "l’iniziativa mirabile del tuo amore,"
              }
            ],
            [
              {
                "type": "text",
                "text": "poiché tu riporti l’uomo alla santità della sua prima origine e gli fai pregustare i doni che a lui prepari nel mondo rinnovato."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo segno della tua bontà,"
              }
            ],
            [
              {
                "type": "text",
                "text": "uniti agli angeli e ai santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con voce unanime cantiamo l’inno della tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saintes vierges et des saints religieux ou religieuses. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nous célébrons les prévenances de ton amour pour tant d’hommes et de femmes parvenus à la sainteté en se donnant au Christ à cause du royaume des Cieux."
              }
            ],
            [
              {
                "type": "text",
                "text": "Par ce mystère d’alliance,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tu veux que notre condition humaine retrouve sa splendeur première,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et que, dès ici-bas, nous ayons un avant-goût des biens que tu nous donneras dans le monde à venir."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi, avec les saints et tous les anges,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous te louons et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Jungfrauen und Ordensleuten genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und in den Heiligen deine Gnade zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Inmitten der Kirche berufst du Menschen, sich Christus zu weihen und mit ganzer Hingabe das Himmelreich zu suchen. In ihnen offenbarst du deinen Ratschluss, uns Menschen die ursprüngliche Heiligkeit neu zu schenken und uns schon jetzt mit Freude an den Gütern der kommenden Welt zu erfüllen durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen dich Himmel und Erde, Engel und Menschen und singen wie aus einem Munde das Lob deiner Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Beáti páuperes spíritu, quóniam ipsórum est regnum cælórum"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
