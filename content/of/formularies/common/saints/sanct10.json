{
  "id": "common.saints.sanct10",
  "kind": "common",
  "scope": "universal",
  "structure": "mass",
  "title": {
    "la": "COMMUNE SANCTORUM ET SANCTARUM II. PRO MONACHIS ET RELIGIOSIS D. Pro religiosis 1",
    "es": "COMÚN DE SANTOS Y SANTAS II. Para monjes y religiosos D. Para religiosos 1",
    "en-US": "Common of Holy Men and Women Ii. For Monks and Religious D. For Religious 1",
    "it": "COMUNE DEI SANTI E DELLE SANTE",
    "fr": "COMMUN DES SAINTS ET DES SAINTES II. POUR LES RELIGIEUX D. Pour des religieux 1",
    "de": "COMMUNE-TEXTE FÜR Hl. MÄNNER UND Hl. FRAUEN 7. Für Ordensleute"
  },
  "color": "white",
  "rank": "weekday",
  "cycleScheme": "fixed",
  "includeGloria": false,
  "entranceAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Dóminus sponsávit eam sibi in sempitérnum, in fide et misericórdia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "El Señor se ha desposado con ella para siempre, en fe y misericordia"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The Lord has taken her as his bride for ever in faithfulness and mercy"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Il Signore l’ha resa sua sposa per sempre, nella benevolenza e nell’amore"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Le Seigneur l’a fiancée à lui pour toujours,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "dans la fidélité et la miséricorde"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "alléluia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ]
          },
          "citation": {
            "la": "Cf. Os 2, 21-22",
            "es": "Cf. Os 2, 21-22",
            "en-US": "Hos 2: 21-22",
            "it": "Cf. Os 2, 21-22",
            "fr": "Cf. Os 2, 21-22"
          }
        }
      }
    ]
  },
  "collect": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Deus, cuius múnere beátus"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Christum páuperem et húmilem perseverávit imitári, concéde nobis, ipso intercedénte, ut, in vocatióne nostra fidéliter ambulántes, ad eam perfectiónem, quam nobis in Fílio tuo proposuísti, perveníre valeámus. Per Dóminum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Oh, Dios,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que otorgaste al bienaventurado"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "la gracia de perseverar en la imitación de Cristo pobre y humilde,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "por su intercesión,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "avanzar fielmente en nuestra vocación,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "para llegar a la perfección que nos propusiste en tu Hijo."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Él, que vive y reina contigo."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "O God, by whose gift blessed"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "persevered in imitating Christ, poor and lowly, grant us through his"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "her intercession that,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "faithfully walking in our own vocation, we may reach the perfection you have set before us in your Son. Who lives and reigns with you in the unity of the Holy Spirit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "one God, for ever and ever."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "O Dio, che hai donato a san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "la grazia di perseverare nell’imitazione di Cristo, povero e umile, concedi anche a noi,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "per sua intercessione, di vivere fedelmente la nostra vocazione, per giungere alla perfezione che ci hai rivelato nel tuo Figlio. Egli è Dio, e vive e regna con te, nell’unità dello Spirito Santo, per tutti i secoli dei secoli."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Seigneur Dieu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "tu as donné à saint(e)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "d’imiter avec persévérance le Christ humble et pauvre ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous, par son intercession,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "de marcher dans la fidélité à l’appel que nous avons reçu,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "et de parvenir ainsi à la perfection que tu nous as montrée en ton Fils."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Lui qui vit et règne avec toi dans l’unité du Saint-Esprit,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Dieu, pour les siècles des siècles."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gütiger Gott, mit deiner Hilfe ist der heilige"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "Christus in seiner Armut und Demut nachgefolgt."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Hilf uns, dass auch wir unserer Berufung treu bleiben und die Vollendung erreichen, zu der uns dein Sohn den Weg gezeigt hat, der in der Einheit des Heiligen Geistes mit dir lebt und herrscht in alle Ewigkeit."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prayerOverOfferings": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Clementíssime Deus, qui, vétere hómine consúmpto, novum secúndum te in beáto"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "creáre dignátus es, concéde propítius, ut nos páriter renováti hanc placatiónis hóstiam tibi acceptábilem offerámus. Per Christum."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Dios misericordioso,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "que destruiste el hombre viejo y quisiste crear el hombre nuevo a tu imagen en san"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ","
                }
              ],
              [
                {
                  "type": "text",
                  "text": "concédenos, renovados del mismo modo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "ofrecer este sacrificio de reconciliación,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "agradable a ti."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Por Jesucristo,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "nuestro Señor."
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "Most merciful God, who were pleased to create in blessed"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "the New Man in your image, the old having passed away, graciously grant, we pray, that, renewed like him"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "her, we may offer you the acceptable sacrifice of conciliation."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Through Christ our Lord."
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Padre clementissimo, che in san"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "hai distrutto l’uomo vecchio e hai creato l’uomo nuovo a tua immagine, nella tua bontà concedi anche a noi di essere rinnovati, per offrirti degnamente questo sacrificio di riconciliazione. Per Cristo nostro Signore."
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
                  "text": "Dieu de grande bonté,"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "en saint(e)"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": ", tu as détruit l’homme ancien pour créer un homme nouveau à ton image ;"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "accorde-nous d’être renouvelés comme lui (elle),"
                }
              ],
              [
                {
                  "type": "text",
                  "text": "afin que nous puissions te plaire en t’offrant ce sacrifice qui nous réconcilie avec toi."
                }
              ],
              [
                {
                  "type": "text",
                  "text": "Par le Christ, notre Seigneur."
                }
              ]
            ],
            "de": [
              [
                {
                  "type": "text",
                  "text": "Gütiger Gott, du hast dem heiligen"
                },
                {
                  "type": "rubric",
                  "text": "N."
                },
                {
                  "type": "text",
                  "text": "die Kraft gegeben, den alten Menschen der Sünde abzulegen und den neuen Menschen anzuziehen, der nach deinem Bild geschaffen ist. Erneuere auch uns nach deinem Bild und stärke uns, damit wir dir wohlgefallen und das Opfer der Versöhnung würdig feiern. Darum bitten wir durch Christus, unseren Herrn."
                }
              ]
            ]
          }
        }
      }
    ]
  },
  "prefaces": [
    {
      "id": "pf057",
      "label": {
        "la": "PRÆFATIO DE SANCTIS VIRGINIBUS ET RELIGIOSIS",
        "es": "PREFACIO DE SANTAS VÍRGENES Y RELIGIOSOS",
        "en-US": "Preface of Holy Virgins and Religious",
        "pt-BR": "Prefácio das Santas Virgens e Religiosos o",
        "it": "PREFAZIO DELLE SANTE VERGINI E DEI SANTI RELIGIOSI",
        "fr": "PRÉFACE DES SAINTES VIERGES, ET DES SAINTS RELIGIEUX OU RELIGIEUSES",
        "de": "PRÄFATION VON DEN HEILIGEN JUNGFRAUEN UND ORDENSLEUTEN"
      },
      "excerpt": {
        "la": "De signo vitæ Deo consecratæ",
        "es": "Significado de la vida de consagración exclusiva a Dios",
        "en-US": "The sign of a life consecrated to God",
        "pt-BR": "sinal da vida consagrada a Deus",
        "it": "Il segno della vita consacrata a Dio",
        "fr": "Signification de la vie consacrée",
        "de": "Die Zeichenhaftigkeit des gottgeweihten Lebens"
      },
      "body": {
        "lines": {
          "la": [
            [
              {
                "type": "rubric",
                "text": "Sequens præfatio dicitur in sollemnitatibus et festis Sanctarum Virginum et Sanctorum Religiosorum. Dici potest in memoriis ipsorum."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vere dignum et iustum est,"
              }
            ],
            [
              {
                "type": "text",
                "text": "æquum et salutáre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nos tibi semper et ubíque grátias ágere:"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dómine, sancte Pater, omnípotens ætérne Deus:"
              }
            ],
            [
              {
                "type": "text",
                "text": "In Sanctis enim, qui Christo se dedicavérunt propter regnum cælórum,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tuam decet providéntiam celebráre mirábilem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "qua humánam substántiam et ad primæ oríginis révocas sanctitátem,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et perdúcis ad experiénda dona,"
              }
            ],
            [
              {
                "type": "text",
                "text": "quæ in novo sǽculo sunt habénda."
              }
            ],
            [
              {
                "type": "text",
                "text": "Et ídeo, cum Sanctis et Angelis univérsis,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te collaudámus, sine fine dicéntes:"
              }
            ]
          ],
          "es": [
            [
              {
                "type": "rubric",
                "text": "El siguiente prefacio se dice en las solemnidades y fiestas de las santas Vírgenes y de los santos Religiosos. Se puede decir también en las memorias de los mismos."
              }
            ],
            [
              {
                "type": "text",
                "text": "En verdad es justo y necesario,"
              }
            ],
            [
              {
                "type": "text",
                "text": "es nuestro deber y salvación darte gracias siempre y en todo lugar, Señor, Padre santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dios todopoderoso y eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Porque celebramos tu providencia admirable en los santos que se entregaron a Cristo por el reino de los cielos."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por ella llamas de nuevo a la humanidad a la santidad primera que de ti había recibido,"
              }
            ],
            [
              {
                "type": "text",
                "text": "y la conduces a gustar los dones que espera recibir en el cielo."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por eso,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con los santos y todos los ángeles,"
              }
            ],
            [
              {
                "type": "text",
                "text": "te alabamos, proclamando sin cesar:"
              }
            ]
          ],
          "en-US": [
            [
              {
                "type": "rubric",
                "text": "The following Preface is said on the Solemnities and Feasts of Holy Virgins and Religious. It may also be said on their Memorials."
              }
            ],
            [
              {
                "type": "text",
                "text": "It is truly right and just, our duty and our salvation,"
              }
            ],
            [
              {
                "type": "text",
                "text": "always and everywhere to give you thanks,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Lord, holy Father, almighty and eternal God."
              }
            ],
            [
              {
                "type": "text",
                "text": "For in the Saints who consecrated themselves to Christ for the sake of the Kingdom of Heaven,"
              }
            ],
            [
              {
                "type": "text",
                "text": "it is right to celebrate the wonders of your providence,"
              }
            ],
            [
              {
                "type": "text",
                "text": "by which you call human nature back to its original holiness and bring it to experience on this earth the gifts you promise in the new world to come."
              }
            ],
            [
              {
                "type": "text",
                "text": "And so, with all the Angels and Saints,"
              }
            ],
            [
              {
                "type": "text",
                "text": "we praise you, as without end we acclaim:"
              }
            ]
          ],
          "pt-BR": [
            [
              {
                "type": "rubric",
                "text": "Este prefácio deve ser usado nas solenidades e festas das Santas Virgens e dos Santos Religiosos; ele pode ser rezado também em suas memórias."
              }
            ],
            [
              {
                "type": "text",
                "text": "Na verdade, é digno e justo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "é nosso dever e salvação dar-vos graças,"
              }
            ],
            [
              {
                "type": "text",
                "text": "sempre e em todo lugar,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Senhor, Pai santo,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Deus eterno e todo-poderoso."
              }
            ],
            [
              {
                "type": "text",
                "text": "Recordando os Santos e Santas que se consagraram a Cristo por amor ao reino dos céus,"
              }
            ],
            [
              {
                "type": "text",
                "text": "celebramos a vossa admirável providência;"
              }
            ],
            [
              {
                "type": "text",
                "text": "por ela, reconduzis a humanidade à santidade original e nos fazeis saborear, já aqui na terra,"
              }
            ],
            [
              {
                "type": "text",
                "text": "os dons reservados para o céu."
              }
            ],
            [
              {
                "type": "text",
                "text": "Por isso, com todos os Anjos e Santos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nós vos louvamos,"
              }
            ],
            [
              {
                "type": "text",
                "text": "cantando"
              },
              {
                "type": "rubric",
                "text": "("
              },
              {
                "type": "text",
                "text": "dizendo"
              },
              {
                "type": "rubric",
                "text": ")"
              },
              {
                "type": "text",
                "text": "a uma só voz:"
              }
            ]
          ],
          "it": [
            [
              {
                "type": "rubric",
                "text": "Si dice nelle solennità e nelle feste delle sante vergini e dei santi religiosi. Si può dire anche nelle loro memorie."
              }
            ],
            [
              {
                "type": "text",
                "text": "È veramente cosa buona e giusta,"
              }
            ],
            [
              {
                "type": "text",
                "text": "renderti grazie e innalzare a te l’inno di benedizione e di lode,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dio onnipotente ed eterno."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nei tuoi santi, che per il regno dei cieli hanno consacrato la vita a Cristo tuo Figlio,"
              }
            ],
            [
              {
                "type": "text",
                "text": "noi celebriamo, o Padre,"
              }
            ],
            [
              {
                "type": "text",
                "text": "l’iniziativa mirabile del tuo amore,"
              }
            ],
            [
              {
                "type": "text",
                "text": "poiché tu riporti l’uomo alla santità della sua prima origine e gli fai pregustare i doni che a lui prepari nel mondo rinnovato."
              }
            ],
            [
              {
                "type": "text",
                "text": "Per questo segno della tua bontà,"
              }
            ],
            [
              {
                "type": "text",
                "text": "uniti agli angeli e ai santi,"
              }
            ],
            [
              {
                "type": "text",
                "text": "con voce unanime cantiamo l’inno della tua gloria:"
              }
            ]
          ],
          "fr": [
            [
              {
                "type": "rubric",
                "text": "Cette Préface se dit pendant les solennités et les fêtes des saintes vierges et des saints religieux ou religieuses. On peut aussi l’utiliser dans le cas d’une mémoire liturgique."
              }
            ],
            [
              {
                "type": "text",
                "text": "Vraiment, il est juste et bon,"
              }
            ],
            [
              {
                "type": "text",
                "text": "pour ta gloire et notre salut,"
              }
            ],
            [
              {
                "type": "text",
                "text": "de t’offrir notre action de grâce,"
              }
            ],
            [
              {
                "type": "text",
                "text": "toujours et en tout lieu,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Seigneur, Père très saint,"
              }
            ],
            [
              {
                "type": "text",
                "text": "Dieu éternel et tout-puissant."
              }
            ],
            [
              {
                "type": "text",
                "text": "Nous célébrons les prévenances de ton amour pour tant d’hommes et de femmes parvenus à la sainteté en se donnant au Christ à cause du royaume des Cieux."
              }
            ],
            [
              {
                "type": "text",
                "text": "Par ce mystère d’alliance,"
              }
            ],
            [
              {
                "type": "text",
                "text": "tu veux que notre condition humaine retrouve sa splendeur première,"
              }
            ],
            [
              {
                "type": "text",
                "text": "et que, dès ici-bas, nous ayons un avant-goût des biens que tu nous donneras dans le monde à venir."
              }
            ],
            [
              {
                "type": "text",
                "text": "C’est pourquoi, avec les saints et tous les anges,"
              }
            ],
            [
              {
                "type": "text",
                "text": "nous te louons et sans fin nous proclamons :"
              }
            ]
          ],
          "de": [
            [
              {
                "type": "rubric",
                "text": "Diese Präfation wird an Hochfesten und Festen von Jungfrauen und Ordensleuten genommen."
              }
            ],
            [
              {
                "type": "text",
                "text": "In Wahrheit ist es würdig und recht, dir, allmächtiger Vater, zu danken und in den Heiligen deine Gnade zu rühmen."
              }
            ],
            [
              {
                "type": "text",
                "text": "Inmitten der Kirche berufst du Menschen, sich Christus zu weihen und mit ganzer Hingabe das Himmelreich zu suchen. In ihnen offenbarst du deinen Ratschluss, uns Menschen die ursprüngliche Heiligkeit neu zu schenken und uns schon jetzt mit Freude an den Gütern der kommenden Welt zu erfüllen durch unseren Herrn Jesus Christus."
              }
            ],
            [
              {
                "type": "text",
                "text": "Durch ihn preisen dich Himmel und Erde, Engel und Menschen und singen wie aus einem Munde das Lob deiner Herrlichkeit:"
              }
            ]
          ]
        }
      }
    }
  ],
  "communionAntiphon": {
    "options": [
      {
        "body": {
          "lines": {
            "la": [
              [
                {
                  "type": "text",
                  "text": "Pars mea Dóminus: bonus est ánimæ quærénti illum"
                },
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "allelúia"
                },
                {
                  "type": "rubric",
                  "text": "."
                }
              ]
            ],
            "es": [
              [
                {
                  "type": "text",
                  "text": "Mi lote es el Señor: es bueno para quien en él espera"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Aleluya"
                }
              ]
            ],
            "en-US": [
              [
                {
                  "type": "text",
                  "text": "The Lord is my portion: he is good to the soul that seeks him"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "E. T."
                },
                {
                  "type": "text",
                  "text": "alleluia"
                }
              ]
            ],
            "it": [
              [
                {
                  "type": "text",
                  "text": "Mia eredità è il Signore: buono è il Signore con chi spera in lui"
                }
              ],
              [
                {
                  "type": "rubric",
                  "text": "T. P."
                },
                {
                  "type": "text",
                  "text": "Alleluia"
                }
              ]
            ],
            "fr": [
              [
                {
                  "type": "text",
