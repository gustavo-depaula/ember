{
  "id": "morrow-my-catholic-faith",
  "name": {
    "en-US": "My Catholic Faith: A Catechism in Pictures"
  },
  "author": {
    "en-US": "Bp. Louis LaRavoire Morrow"
  },
  "description": {
    "en-US": "A complete pictorial catechism in 193 illustrated lessons, presenting the doctrines and practices of the Catholic Church in three parts: What to Believe (the Creed), What to Do (the Commandments), and Means of Grace (the Sacraments and Prayer). First published in 1949 by the Bishop of Krishnagar."
  },
  "composed": 1949,
  "languages": [
    "en-US"
  ],
  "sources": [
    {
      "language": "en-US",
      "url": "https://fsspx.asia/sites/default/files/documents/my-catholic-faith.pdf",
      "description": "PDF of the 2021 revised edition published by FSSPX Asia."
    }
  ],
