  },
  "description": {
    "en-US": "The four Naples 1273 catechetical sermon-cycles — on the Creed, the Lord's Prayer, the Hail Mary, and the Ten Commandments. Aquinas Institute bilingual edition. (The Collins 1939 English of the same sermons lives in `book/aquinas-catechetical-instructions`.)",
    "la": "Quattuor cycli sermonum catecheticorum Neapolitanorum (1273) — super Symbolum Apostolorum, Pater Noster, Ave Maria, Decem Praecepta. Editio bilinguis Instituti Aquinatis."
  },
  "composed": 1273,
  "languages": [
    "en-US",
    "la"
  ],
  "sources": [
    {
      "language": "en-US",
      "url": "https://aquinas.cc/la/en/~In Symbolum Apostolorum",
      "description": "Translation from aquinas.cc (Aquinas Institute), distinct from the Collins 1939 PD edition."
    },
    {
      "language": "la",
      "url": "https://aquinas.cc/la/en/~In Symbolum Apostolorum",
      "description": "Latin text from the Leonine / Marietti editions (public domain), mirrored from aquinas.cc."
    }
  ],
