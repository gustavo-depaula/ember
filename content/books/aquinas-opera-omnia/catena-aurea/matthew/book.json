{
  "id": "aquinas-catena-aurea-matthew",
  "name": {
    "en-US": "Catena Aurea on Matthew",
    "la": "Catena Aurea in Evangelium secundum Matthaeum"
  },
  "author": {
    "en-US": "St. Thomas Aquinas",
    "la": "Sanctus Thomas Aquinas"
  },
  "description": {
    "en-US": "Aquinas's verse-by-verse gloss on the Gospel of Matthew, weaving the Greek and Latin Fathers into a single continuous commentary. Commissioned by Pope Urban IV. English translation by John Henry Parker (J.G.F. and J. Rivington, London, 1841–1845); the project that produced the *Library of the Fathers* under Newman, Pusey, and Keble.",
    "la": "Glossa textualis super Evangelium secundum Matthaeum, ex commentariis sanctorum patrum graecorum et latinorum confecta, Urbano IV pontifice iubente."
  },
  "composed": "1262–1268",
  "languages": [
    "en-US",
    "la"
  ],
  "sources": [
    {
      "language": "en-US",
      "url": "https://github.com/Geremia/AquinasOperaOmnia",
      "description": "John Henry Parker translation, London 1841–1845 (J.G.F. and J. Rivington), with the dedication translated by Joseph Kenny OP. Public domain. Mirrored from dhspriory.org via the Geremia/AquinasOperaOmnia GitHub repository."
    },
    {
      "language": "la",
      "url": "https://github.com/Geremia/AquinasOperaOmnia",
      "description": "Latin text from Aquinas's autograph (Marietti edition), public domain. Mirrored via Geremia."
    }
  ],
