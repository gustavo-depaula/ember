  },
  "composed": "1265–1266",
  "languages": [
    "en-US",
    "la"
  ],
  "sources": [
    {
      "language": "en-US",
      "url": "https://github.com/Geremia/AquinasOperaOmnia",
      "description": "English translation by the English Dominican Fathers, *On the Power of God* (Newman Press, 1952; Burns Oates & Washbourne, London, 1932–34). Translation status: the 1932 edition is mirrored via the Geremia/AquinasOperaOmnia GitHub repository."
    },
    {
      "language": "la",
      "url": "https://github.com/Geremia/AquinasOperaOmnia",
