    {
      "id": "g5",
      "title": {
        "en-US": "Book 5 — Continuation of Peter of Auvergne",
        "la": "Liber 5"
      },
      "children": [
        {
          "id": "g5-c007",
          "title": {
            "en-US": "Lecture 7",
            "la": "Lectio 7"
          }
        },
        {
          "id": "g5-c008",
          "title": {
            "en-US": "Lecture 8 — Utrum unum an plures dominari conveniat; et si plures, num optimates, an divites, an multitudo.",
            "la": "Lectio 8"
          }
        },
        {
          "id": "g5-c009",
          "title": {
            "en-US": "Lecture 9 — Multitudini committendam esse electionem magistratuum et administratarum rerum examen; magistratus autem legibus obtemperare debere, et solum in his quae lex cavere non valuit arbitrium habere.",
            "la": "Lectio 9"
          }
        },
        {
          "id": "g5-c010",
          "title": {
            "en-US": "Lecture 10 — Magistratus non esse distribuendos secundum excessum cuiuslibet boni.",
            "la": "Lectio 10"
          }
        },
        {
          "id": "g5-c011",
          "title": {
            "en-US": "Lecture 11 — Utrum nobilibus, an opulentis, an virtute praeditis, an potentioribus, attribuendi sint magistratus.",
            "la": "Lectio 11"
          }
        },
        {
          "id": "g5-c012",
          "title": {
            "en-US": "Lecture 12 — Post longam discussionem concludit excellentem probitate virum ceteris praeferendum, cum natura talis sit cui debeant omnes subesse.",
            "la": "Lectio 12"
          }
        },
        {
          "id": "g5-c013",
          "title": {
            "en-US": "Lecture 13 — Quinque regum species proponit et de qua disputaturus sit eligit.",
            "la": "Lectio 13"
          }
        },
        {
          "id": "g5-c014",
          "title": {
            "en-US": "Lecture 14 — Utrum a legibus an ab optimo rege melius sit civitatem gubernari; et de eius successione et custodia.",
            "la": "Lectio 14"
          }
        },
        {
          "id": "g5-c015",
          "title": {
            "en-US": "Lecture 15 — Obiectiones continet quae adversus regiam potestatem adduci possunt.",
            "la": "Lectio 15"
          }
        },
        {
          "id": "g5-c016",
          "title": {
            "en-US": "Lecture 16 — Declarat quibus civitatibus regem creare conveniat, et quibus optimatum administrationem.",
            "la": "Lectio 16"
          }
        }
      ]
    }
  ]
