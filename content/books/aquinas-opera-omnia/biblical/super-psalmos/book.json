{
  "id": "aquinas-super-psalmos",
  "name": {
    "en-US": "Commentary on the Psalms",
    "la": "Postilla super Psalmos"
  },
  "author": {
    "en-US": "St. Thomas Aquinas",
    "la": "Sanctus Thomas Aquinas"
  },
  "description": {
    "en-US": "Aquinas's final commentary, on the Psalms — incomplete. He reached only Psalm 54 (numbered Ps 51 in the Hebrew, depending on the system) before his death.",
    "la": "Expositio ultima Thomae, in Psalmos — opus inchoatum, morte interruptum. Solum usque ad Psalmum 54 (vel 51, secundum numerationem) pervenit."
  },
  "composed": "1273",
  "languages": [
    "en-US",
    "la"
  ],
  "sources": [
