{
  "expo": {
    "name": "Ember",
    "slug": "ember",
    "scheme": "ember",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0E0D0C",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.dpgu.ember",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"],
        "EMBER_CUSTODY_APP_GROUP": "group.me.dpgu.ember"
      },
      "entitlements": {
        "com.apple.developer.family-controls": true,
        "com.apple.security.application-groups": ["group.me.dpgu.ember"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "me.dpgu.ember",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-notifications",
      "expo-audio",
      "expo-image",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Ember to use your location to find Mass and confession times at nearby churches."
        }
      ],
      "expo-maps",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ember to attach a photo (e.g. a parish bulletin) to your correction."
        }
      ],
      "expo-status-bar",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0E0D0C",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0E0D0C"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID",
          "appGroup": "group.me.dpgu.ember"
        }
      ],
      [
        "./plugins/withCustodyIOS",
        {
          "appGroup": "group.me.dpgu.ember"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f282c90-7689-4b7e-b8c0-707279d09c5c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4f282c90-7689-4b7e-b8c0-707279d09c5c"
    }
  }
}
