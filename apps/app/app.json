{
  "expo": {
    "name": "Ember",
    "slug": "ember",
    "scheme": "ember",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.dpgu.ember",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Prayer Book",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": ["me.dpgu.ember.pray"]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "me.dpgu.ember.pray",
            "UTTypeDescription": "Prayer Book",
            "UTTypeConformsTo": ["public.zip-archive"],
            "UTTypeTagSpecification": {
              "public.filename-extension": ["pray"]
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "me.dpgu.ember",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            {
              "mimeType": "application/octet-stream",
              "pathPattern": ".*\\.pray"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f282c90-7689-4b7e-b8c0-707279d09c5c"
      }
    }
  }
}
